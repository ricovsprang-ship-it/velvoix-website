---
import LegalPage from '../../components/LegalPage.astro';
import { legalContent } from '../../content/legal';
import { siteContent } from '../../content/site';
import Layout from '../../layouts/Layout.astro';

const locale = 'es' as const;
const page = legalContent[locale].privacy;
const footer = siteContent[locale].footer;
---

<Layout
  locale={locale}
  title={page.meta.title}
  description={page.meta.description}
  ogTitle={page.meta.ogTitle}
  ogDescription={page.meta.ogDescription}
  path="/es/privacy-policy"
  alternatePaths={{
    nl: '/privacy-policy',
    en: '/en/privacy-policy',
    de: '/de/privacy-policy',
    es: '/es/privacy-policy',
  }}
>
  <LegalPage
    locale={locale}
    content={page}
    footer={footer}
    languagePaths={{
      nl: '/privacy-policy',
      en: '/en/privacy-policy',
      de: '/de/privacy-policy',
      es: '/es/privacy-policy',
    }}
  />
</Layout>
