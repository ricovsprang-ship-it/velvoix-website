---
import type { FooterContent, Locale, NavItem } from '../content/site';
import type { LegalPageContent } from '../content/legal';
import Footer from './Footer.astro';
import Header from './Header.astro';

interface Props {
  locale: Locale;
  content: LegalPageContent;
  footer: FooterContent;
  languagePaths: {
    nl: string;
    en: string;
  };
}

const { locale, content, footer, languagePaths } = Astro.props;
const basePath = locale === 'nl' ? '' : '/en';

const nav: NavItem[] = [
  { label: 'Home', href: `${basePath}/#home` },
  { label: locale === 'nl' ? 'Hoe het werkt' : 'How it works', href: `${basePath}/#how-it-works` },
  { label: locale === 'nl' ? 'Waarom Velvoix' : 'Why Velvoix', href: `${basePath}/#why-velvoix` },
  { label: 'Pilot', href: `${basePath}/#pilot` },
  { label: locale === 'nl' ? 'Contact' : 'Contact', href: `${basePath}/#contact` },
];
---

<div class="site-shell">
  <Header locale={locale} nav={nav} languagePaths={languagePaths} />

  <main>
    <section class="border-b border-slate-200/80 bg-[linear-gradient(180deg,rgba(246,249,252,0.98),rgba(241,246,250,0.94))]">
      <div class="section-shell py-14 md:py-18">
        <div class="max-w-[50rem]">
          <p class="eyebrow">{content.eyebrow}</p>
          <h1 class="mt-4 text-4xl font-extrabold tracking-tight text-slate-950 md:text-5xl">{content.title}</h1>
          <p class="mt-6 max-w-[46rem] text-lg leading-8 text-slate-600">{content.intro}</p>
          <p class="mt-5 text-sm font-medium text-slate-500">
            {content.updatedLabel}: <span class="text-slate-700">{content.lastUpdated}</span>
          </p>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="section-shell grid gap-10 lg:grid-cols-[17rem_minmax(0,1fr)] lg:items-start">
        <aside class="lg:sticky lg:top-28">
          <div class="rounded-[1.35rem] border border-slate-200/85 bg-white/92 p-5 shadow-[0_18px_32px_rgba(31,53,87,0.05)]">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.tocLabel}</p>
            <nav class="mt-4 flex flex-col gap-1.5">
              {content.sections.map((section) => (
                <a
                  href={`#${section.id}`}
                  class="rounded-[0.9rem] px-3 py-2.5 text-sm font-medium leading-5 text-slate-600 transition-colors hover:bg-slate-50 hover:text-slate-950"
                >
                  {section.title}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <div class="rounded-[1.7rem] border border-slate-200/85 bg-white/96 p-6 shadow-[0_24px_42px_rgba(31,53,87,0.06)] md:p-8 lg:p-10">
          <div class="space-y-10">
            {content.sections.map((section) => (
              <section id={section.id} class="scroll-mt-28 border-t border-slate-200/75 pt-10 first:border-t-0 first:pt-0">
                <h2 class="text-2xl font-bold tracking-tight text-slate-950 md:text-[1.9rem]">{section.title}</h2>
                <div class="mt-5 space-y-4">
                  {section.paragraphs.map((paragraph) => (
                    <p class="text-[1rem] leading-8 text-slate-600">{paragraph}</p>
                  ))}
                </div>
                {section.bullets && (
                  <ul class="mt-5 space-y-3 rounded-[1.2rem] border border-slate-200/80 bg-slate-50/78 px-5 py-5">
                    {section.bullets.map((bullet) => (
                      <li class="flex items-start gap-3 text-[0.98rem] leading-7 text-slate-700">
                        <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </section>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} content={footer} />
</div>
