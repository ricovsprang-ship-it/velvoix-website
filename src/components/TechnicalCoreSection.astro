---
import type { TechnicalCoreContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: TechnicalCoreContent;
}

const { content } = Astro.props;
---

<section class="section-block surface-band-alt" id="technical-core" data-technical-core>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
    <div class="max-w-[31rem]" data-technical-core-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div class="space-y-3.5" data-technical-core-rows>
      {content.rows.map((row) => (
        <article
          class="technical-row rounded-[1.28rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(244,248,251,0.92))] px-5 py-5 shadow-[0_12px_24px_rgba(31,53,87,0.045)] md:px-6"
          data-technical-row
        >
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="shrink-0 md:w-[4.15rem]">
              <p class="text-[0.74rem] font-bold uppercase tracking-[0.2em] text-slate-400">{row.index}</p>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-[1.13rem] font-semibold tracking-tight text-slate-950">{row.title}</h3>
              <p class="mt-2 max-w-[44rem] text-sm leading-6 text-slate-600">{row.description}</p>
              <p class="mt-3 flex items-start gap-2.5 text-[0.88rem] font-medium text-slate-700">
                <span class="mt-[0.42rem] size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                <span>{row.effect}</span>
              </p>
            </div>
          </div>
        </article>
      ))}

      <p class="rounded-[1.1rem] border border-slate-200/82 bg-white/84 px-5 py-4 text-sm leading-7 text-slate-600 shadow-[0_10px_20px_rgba(31,53,87,0.035)]">
        {content.closingLine}
      </p>
    </div>
  </div>
</section>

<style>
  [data-technical-core] .technical-row {
    transition: border-color 180ms ease, box-shadow 180ms ease, transform 180ms ease;
  }
  [data-technical-core] .technical-row:hover {
    border-color: rgba(187, 197, 210, 0.96);
    box-shadow: 0 16px 28px rgba(31, 53, 87, 0.06);
    transform: translateY(-1px);
  }
  @media (max-width: 767px) {
    [data-technical-core] .technical-row:hover {
      transform: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const blocks = document.querySelectorAll('[data-technical-core]');

  for (const block of blocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector<HTMLElement>('[data-technical-core-intro]');
    const rows = Array.from(block.querySelectorAll<HTMLElement>('[data-technical-row]'));

    if (prefersReducedMotion) continue;

    gsap.set([intro, ...rows], { autoAlpha: 0, y: 16 });

    gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: {
        trigger: block,
        start: 'top 74%',
        once: true,
      },
      onComplete: () => {
        gsap.set([intro, ...rows], { clearProps: 'opacity,visibility,transform' });
      },
    })
      .to(intro, { autoAlpha: 1, y: 0, duration: 0.42 })
      .to(rows, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.07 }, '-=0.18');
  }
</script>
