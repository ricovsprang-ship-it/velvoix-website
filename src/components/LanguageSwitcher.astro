---
import type { Locale } from '../content/site';

interface Props {
  locale: Locale;
  nlPath?: string;
  enPath?: string;
}

const { locale, nlPath = '/', enPath = '/en/' } = Astro.props;
const isNl = locale === 'nl';
---

<div class="inline-flex items-center gap-2 text-sm font-medium text-slate-500">
  <a
    href={nlPath}
    class:list={[
      'relative px-0.5 py-1 transition-colors',
      isNl ? 'font-semibold text-slate-950' : 'text-slate-500 hover:text-slate-800',
    ]}
    aria-current={isNl ? 'page' : undefined}
  >
    NL
    {isNl && <span class="absolute inset-x-0 -bottom-0.5 h-px bg-slate-900"></span>}
  </a>
  <span class="text-slate-300">|</span>
  <a
    href={enPath}
    class:list={[
      'relative px-0.5 py-1 transition-colors',
      !isNl ? 'font-semibold text-slate-950' : 'text-slate-500 hover:text-slate-800',
    ]}
    aria-current={!isNl ? 'page' : undefined}
  >
    EN
    {!isNl && <span class="absolute inset-x-0 -bottom-0.5 h-px bg-slate-900"></span>}
  </a>
</div>
