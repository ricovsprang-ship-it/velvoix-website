---
import type { Locale } from '../content/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const isNl = locale === 'nl';
---

<div class="language-pill inline-flex items-center gap-1 text-sm font-semibold text-slate-700">
  <a
    href="/"
    class:list={[
      'rounded-full px-3 py-2',
      isNl ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-white/80',
    ]}
    aria-current={isNl ? 'page' : undefined}
  >
    NL
  </a>
  <span class="text-slate-300">|</span>
  <a
    href="/en/"
    class:list={[
      'rounded-full px-3 py-2',
      !isNl ? 'bg-slate-900 text-white shadow-sm' : 'text-slate-600 hover:bg-white/80',
    ]}
    aria-current={!isNl ? 'page' : undefined}
  >
    EN
  </a>
</div>
