---
import { localeRootPaths } from '../content/site';
import type { Locale } from '../content/site';

interface Props {
  locale: Locale;
  languagePaths?: Partial<Record<Locale, string>>;
}

const { locale, languagePaths = {} } = Astro.props;
const paths: Record<Locale, string> = {
  ...localeRootPaths,
  ...languagePaths,
};

const languages: Array<{ code: string; locale: Locale; href: string }> = [
  { code: 'NL', locale: 'nl', href: paths.nl },
  { code: 'EN', locale: 'en', href: paths.en },
  { code: 'DE', locale: 'de', href: paths.de },
  { code: 'ES', locale: 'es', href: paths.es },
];

const activeLanguage = languages.find((language) => language.locale === locale) ?? languages[0];
const otherLanguages = languages.filter((language) => language.locale !== locale);
---

<details class="language-switcher" data-language-switcher>
  <summary class="language-switcher__summary">
    <span>{activeLanguage.code}</span>
    <svg
      class="language-switcher__chevron"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </summary>

  <div class="language-switcher__menu" role="listbox" aria-label="Language switcher">
    <a
      href={activeLanguage.href}
      class="language-switcher__item is-active"
      aria-current="page"
      data-language-link
      data-language-locale={activeLanguage.locale}
    >
      {activeLanguage.code}
    </a>
    {otherLanguages.map((language) => (
      <a
        href={language.href}
        class="language-switcher__item"
        data-language-link
        data-language-locale={language.locale}
      >
        {language.code}
      </a>
    ))}
  </div>
</details>

<style>
  .language-switcher {
    position: relative;
  }

  .language-switcher__summary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2.55rem;
    padding: 0.45rem 0.8rem 0.45rem 0.9rem;
    border: 1px solid rgba(211, 220, 230, 0.96);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.94);
    color: rgb(15 23 42);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    list-style: none;
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }

  .language-switcher__summary::-webkit-details-marker {
    display: none;
  }

  .language-switcher__summary:hover,
  .language-switcher__summary:focus-visible {
    border-color: rgba(20, 184, 166, 0.28);
    background: rgba(248, 252, 251, 0.98);
    color: rgb(15 118 110);
  }

  .language-switcher__chevron {
    width: 0.95rem;
    height: 0.95rem;
    color: rgb(100 116 139);
    transition: transform 180ms ease, color 160ms ease;
  }

  .language-switcher[open] .language-switcher__chevron {
    transform: rotate(180deg);
    color: rgb(15 23 42);
  }

  .language-switcher__menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.7rem);
    z-index: 20;
    display: grid;
    min-width: 5rem;
    gap: 0.2rem;
    padding: 0.45rem;
    border: 1px solid rgba(216, 224, 232, 0.96);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
  }

  .language-switcher__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.35rem;
    padding: 0.45rem 0.7rem;
    border-radius: 0.75rem;
    color: rgb(71 85 105);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .language-switcher__item:hover,
  .language-switcher__item:focus-visible {
    background: rgba(241, 245, 249, 0.95);
    color: rgb(15 23 42);
  }

  .language-switcher__item.is-active {
    color: rgb(15 23 42);
    background: rgba(241, 245, 249, 0.95);
  }
</style>
