---
import { localeRootPaths } from '../content/site';
import type { Locale } from '../content/site';

interface Props {
  locale: Locale;
  languagePaths?: Partial<Record<Locale, string>>;
}

const { locale, languagePaths = {} } = Astro.props;
const paths: Record<Locale, string> = {
  ...localeRootPaths,
  ...languagePaths,
};
const languages: Array<{ code: string; locale: Locale; href: string }> = [
  { code: 'NL', locale: 'nl', href: paths.nl },
  { code: 'EN', locale: 'en', href: paths.en },
  { code: 'DE', locale: 'de', href: paths.de },
  { code: 'ES', locale: 'es', href: paths.es },
];
---

<div class="inline-flex items-center gap-2 text-sm font-medium text-slate-500">
  {languages.map((language, index) => (
    <span class="contents">
      <a
        href={language.href}
        class:list={[
          'relative px-0.5 py-1 transition-colors',
          locale === language.locale ? 'font-semibold text-slate-950' : 'text-slate-500 hover:text-slate-800',
        ]}
        aria-current={locale === language.locale ? 'page' : undefined}
      >
        {language.code}
        {locale === language.locale && <span class="absolute inset-x-0 -bottom-0.5 h-px bg-slate-900"></span>}
      </a>
      {index < languages.length - 1 && <span class="text-slate-300">|</span>}
    </span>
  ))}
</div>
