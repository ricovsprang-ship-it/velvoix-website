---
import { localeRootPaths } from '../content/site';
import type { Locale } from '../content/site';

interface Props {
  locale: Locale;
  languagePaths?: Partial<Record<Locale, string>>;
}

const { locale, languagePaths = {} } = Astro.props;
const paths: Record<Locale, string> = {
  ...localeRootPaths,
  ...languagePaths,
};
const orderedLocales: Locale[] = ['nl', 'en', 'de', 'es'];
const hasScopedLanguagePaths = Object.keys(languagePaths).length > 0;

const languageCodeByLocale: Record<Locale, string> = {
  nl: 'NL',
  en: 'EN',
  de: 'DE',
  es: 'ES',
};

const languages: Array<{ code: string; locale: Locale; href: string }> = orderedLocales
  .filter((candidate) => !hasScopedLanguagePaths || Boolean(languagePaths[candidate]))
  .map((candidate) => ({
    code: languageCodeByLocale[candidate],
    locale: candidate,
    href: paths[candidate],
  }));

const activeLanguage = languages.find((language) => language.locale === locale) ?? languages[0];
const otherLanguages = languages.filter((language) => language.locale !== locale);
const ariaLabelByLocale: Record<Locale, string> = {
  nl: 'Taalwisselaar',
  en: 'Language switcher',
  de: 'Sprachauswahl',
  es: 'Selector de idioma',
};
---

<details class="language-switcher" data-language-switcher>
  <summary class="language-switcher__summary">
    <span>{activeLanguage.code}</span>
    <svg
      class="language-switcher__chevron"
      viewBox="0 0 20 20"
      fill="none"
      aria-hidden="true"
      focusable="false"
    >
      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </summary>

  <div class="language-switcher__menu" role="listbox" aria-label={ariaLabelByLocale[locale]}>
    <a
      href={activeLanguage.href}
      class="language-switcher__item is-active"
      aria-current="page"
      data-language-link
      data-language-locale={activeLanguage.locale}
    >
      {activeLanguage.code}
    </a>
    {otherLanguages.map((language) => (
      <a
        href={language.href}
        class="language-switcher__item"
        data-language-link
        data-language-locale={language.locale}
      >
        {language.code}
      </a>
    ))}
  </div>
</details>

<style>
  .language-switcher {
    position: relative;
    isolation: isolate;
  }

  .language-switcher__summary {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0;
    color: rgb(15 23 42);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    list-style: none;
    cursor: pointer;
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }

  .language-switcher__summary::-webkit-details-marker {
    display: none;
  }

  .language-switcher__summary:hover,
  .language-switcher__summary:focus-visible {
    color: rgb(15 118 110);
  }

  .language-switcher__chevron {
    width: 0.8rem;
    height: 0.8rem;
    color: rgb(100 116 139);
    transition: transform 180ms ease, color 160ms ease;
  }

  .language-switcher[open] .language-switcher__chevron {
    transform: rotate(180deg);
    color: rgb(15 23 42);
  }

  .language-switcher__menu {
    position: absolute;
    right: 0;
    top: calc(100% + 0.7rem);
    z-index: 20;
    display: grid;
    min-width: 5.4rem;
    gap: 0.2rem;
    padding: 0.45rem;
    border: 1px solid rgba(216, 224, 232, 0.96);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.1);
    overflow: hidden;
  }

  .language-switcher[open] {
    z-index: 30;
  }

  .language-switcher__item {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 2.35rem;
    padding: 0.45rem 0.7rem;
    border-radius: 0.75rem;
    background: rgba(255, 255, 255, 0.98);
    color: rgb(71 85 105);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    white-space: nowrap;
    transition: background-color 160ms ease, color 160ms ease;
  }

  .language-switcher__item:hover,
  .language-switcher__item:focus-visible {
    background: rgba(241, 245, 249, 0.95);
    color: rgb(15 23 42);
  }

  .language-switcher__item.is-active {
    color: rgb(15 23 42);
    background: rgba(241, 245, 249, 0.95);
  }

  @media (max-width: 1023px) {
    .language-switcher {
      width: fit-content;
    }

    .language-switcher__menu {
      position: static;
      right: auto;
      top: auto;
      margin-top: 0.7rem;
      min-width: 7.2rem;
      background: rgb(255 255 255);
      box-shadow: 0 14px 28px rgba(15, 23, 42, 0.1);
    }
  }
</style>
