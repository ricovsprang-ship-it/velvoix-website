---
import type { PropositionBridgeContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: PropositionBridgeContent;
}

const { content } = Astro.props;
---

<section class="relative bg-[linear-gradient(180deg,rgba(246,249,252,0.92),rgba(246,249,252,0.68))] py-10 md:py-14">
  <div class="section-shell">
    <div class="mx-auto max-w-[44rem]">
      <SectionIntro
        eyebrow={content.eyebrow}
        title={content.title}
        description={content.description}
        align="center"
      />
    </div>

    <div class="mt-8 grid gap-4 md:mt-10 md:grid-cols-3">
      {content.stages.map((stage, index) => (
        <article class="h-full rounded-[1.6rem] border border-slate-200/80 bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(243,248,251,0.94))] p-5 shadow-[0_16px_34px_rgba(31,53,87,0.06)] md:p-6">
          <div class="flex items-center gap-3">
            <span class="inline-flex size-8 shrink-0 items-center justify-center rounded-full border border-[rgba(25,130,121,0.18)] bg-[rgba(25,130,121,0.07)] text-[0.72rem] font-bold tracking-[0.14em] text-[var(--vx-accent)]">
              {String(index + 1).padStart(2, '0')}
            </span>
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{stage.label}</p>
          </div>

          <h3 class="mt-5 text-[1.14rem] font-semibold tracking-tight text-slate-950">{stage.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{stage.description}</p>

          <div class="mt-5 flex flex-wrap gap-2">
            {stage.items.map((item) => (
              <span class="rounded-full border border-slate-200/80 bg-white/90 px-3 py-1.5 text-[0.8rem] font-semibold text-slate-700">
                {item}
              </span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
