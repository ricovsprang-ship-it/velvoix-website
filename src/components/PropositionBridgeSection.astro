---
import type { PropositionBridgeContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: PropositionBridgeContent;
}

const { content } = Astro.props;
---

<section class="relative bg-[linear-gradient(180deg,rgba(246,249,252,0.92),rgba(246,249,252,0.68))] py-10 md:py-14">
  <div class="section-shell">
    <div class="mx-auto max-w-[44rem]">
      <SectionIntro
        eyebrow={content.eyebrow}
        title={content.title}
        description={content.description}
        align="center"
      />
    </div>

    <div class="mt-8 grid gap-4 md:mt-10 md:grid-cols-3">
      {content.stages.map((stage, index) => (
        <article class="flex h-full flex-col rounded-[1.55rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.98),rgba(244,248,251,0.95))] px-5 py-5 shadow-[0_14px_28px_rgba(31,53,87,0.05)] md:min-h-[16.5rem] md:px-6 md:py-6">
          <div class="flex items-center gap-3">
            <span class="text-[0.76rem] font-bold tracking-[0.18em] text-[var(--vx-accent)]">
              {String(index + 1).padStart(2, '0')}
            </span>
            <span class="h-px flex-1 bg-[rgba(31,53,87,0.1)]"></span>
          </div>

          <p class="mt-4 text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{stage.label}</p>
          <h3 class="mt-3 max-w-[16ch] text-[1.14rem] font-semibold tracking-tight text-slate-950">{stage.title}</h3>
          <p class="mt-4 max-w-[31ch] text-sm leading-6 text-slate-600">
            {stage.description}
          </p>
        </article>
      ))}
    </div>
  </div>
</section>
