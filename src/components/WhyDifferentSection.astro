---
import type { Locale, WhyVelvoixContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: WhyVelvoixContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
      eyebrow: 'Why Velvoix is different',
      title: 'Why Velvoix works differently in operations',
      description:
        'Velvoix is not built to pass signals through, but to structure care situations into explainable, manageable and auditable workflow.',
      rows: [
        {
          index: '01',
          title: 'Not a notification layer',
          description:
            'Velvoix does not pass signals through as isolated alerts, but turns them into workable events with context, ownership and follow-up.',
          effect: 'Less interpretation burden, tighter follow-up.',
        },
        {
          index: '02',
          title: 'Explainable triage',
          description:
            'Velvoix shows not only urgency, but also why something needs attention and which follow-up makes sense in care language.',
          effect: 'Better prioritisation, more understandable action.',
        },
        {
          index: '03',
          title: 'Event truth for workflow and audit',
          description:
            'Status, ownership, escalation and reconstruction all build on one operational truth.',
          effect: 'Consistent workflow, traceable reconstruction.',
        },
      ],
    },
  nl: {
      eyebrow: 'Waarom Velvoix anders is',
      title: 'Waarom Velvoix operationeel anders werkt',
      description:
        'Velvoix is niet gebouwd om alleen signalen door te zetten, maar om zorgsituaties te structureren tot uitlegbare, bestuurbare en auditbare workflow.',
      rows: [
        {
          index: '01',
          title: 'Geen notificatielaag',
          description:
            'Velvoix zet signalen niet door als losse meldingen, maar maakt er werkbare events van met context, eigenaarschap en opvolging.',
          effect: 'Minder interpretatielast, strakkere opvolging.',
        },
        {
          index: '02',
          title: 'Uitlegbare triage',
          description:
            'Velvoix toont niet alleen urgentie, maar ook waarom iets aandacht vraagt en welke opvolging logisch is in zorgtaal.',
          effect: 'Betere prioritering, begrijpelijkere actie.',
        },
        {
          index: '03',
          title: 'Event truth voor workflow en audit',
          description:
            'Status, eigenaarschap, escalatie en reconstructie bouwen op een operationele waarheid.',
          effect: 'Consistente workflow, herleidbare reconstructie.',
        },
      ],
    },
  de: {
      eyebrow: 'Warum Velvoix anders ist',
      title: 'Warum Velvoix operativ anders arbeitet',
      description:
        'Velvoix ist nicht dafur gebaut, Signale nur weiterzugeben, sondern Pflegesituationen in einen erklarbaren, steuerbaren und auditierbaren Workflow zu uberfuhren.',
      rows: [
        {
          index: '01',
          title: 'Keine Benachrichtigungsschicht',
          description:
            'Velvoix reicht Signale nicht als isolierte Meldungen weiter, sondern macht daraus handhabbare Events mit Kontext, Verantwortung und Nachverfolgung.',
          effect: 'Weniger Interpretationslast, straffere Nachverfolgung.',
        },
        {
          index: '02',
          title: 'Erklarbare Triage',
          description:
            'Velvoix zeigt nicht nur Dringlichkeit, sondern auch, warum etwas Aufmerksamkeit braucht und welche Folgeaktion in Pflegesprache sinnvoll ist.',
          effect: 'Bessere Priorisierung, verstandlichere Aktion.',
        },
        {
          index: '03',
          title: 'Event-Wahrheit fur Workflow und Audit',
          description:
            'Status, Verantwortung, Eskalation und Rekonstruktion bauen auf einer gemeinsamen operativen Wahrheit auf.',
          effect: 'Konsistenter Workflow, nachvollziehbare Rekonstruktion.',
        },
      ],
    },
  es: {
      eyebrow: 'Por que Velvoix es diferente',
      title: 'Por que Velvoix funciona de otra manera en la operacion',
      description:
        'Velvoix no esta pensado para reenviar senales, sino para estructurar situaciones asistenciales en un workflow explicable, gobernable y auditable.',
      rows: [
        {
          index: '01',
          title: 'No es una capa de notificaciones',
          description:
            'Velvoix no reenvia senales como alertas aisladas, sino que las convierte en eventos operativos con contexto, titularidad y seguimiento.',
          effect: 'Menos carga interpretativa y un seguimiento mas estricto.',
        },
        {
          index: '02',
          title: 'Triaje explicable',
          description:
            'Velvoix no solo muestra urgencia, sino tambien por que algo requiere atencion y que seguimiento tiene sentido en lenguaje asistencial.',
          effect: 'Mejor priorizacion y accion mas comprensible.',
        },
        {
          index: '03',
          title: 'Verdad del evento para workflow y auditoria',
          description:
            'Estado, titularidad, escalada y reconstruccion se apoyan en una unica verdad operativa.',
          effect: 'Workflow coherente y reconstruccion trazable.',
        },
      ],
    },
} satisfies Record<Locale, {
  eyebrow: string;
  title: string;
  description: string;
  rows: Array<{
    index: string;
    title: string;
    description: string;
    effect: string;
  }>;
}>;

const sectionContent = sectionContentByLocale[locale];
---

<section class="section-block" id="why-velvoix">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
    <div class="max-w-[31rem]">
      <SectionIntro
        eyebrow={sectionContent.eyebrow}
        title={sectionContent.title}
        description={sectionContent.description}
      />
    </div>

    <div class="why-principles space-y-3.5">
      {sectionContent.rows.map((row) => (
        <article class="principle-row rounded-[1.35rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(243,247,250,0.92))] px-5 py-5 shadow-[0_12px_26px_rgba(31,53,87,0.05)] md:px-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="shrink-0 md:w-[4.25rem]">
              <p class="text-[0.74rem] font-bold uppercase tracking-[0.2em] text-slate-400">{row.index}</p>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-[1.15rem] font-semibold tracking-tight text-slate-950">{row.title}</h3>
              <p class="mt-2 max-w-[42rem] text-sm leading-6 text-slate-600">{row.description}</p>
              <p class="mt-3 inline-flex items-center gap-2 text-[0.88rem] font-medium text-slate-700">
                <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                <span>{row.effect}</span>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
