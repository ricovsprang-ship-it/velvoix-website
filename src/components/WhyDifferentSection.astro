---
import type { Locale, WhyVelvoixContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: WhyVelvoixContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
    eyebrow: 'Why Velvoix is different',
    title: 'Why Velvoix works differently in practice',
    description:
      'Velvoix does not stop at the alert, but helps teams move toward clear action and traceable follow-up.',
    rows: [
      {
        index: '01',
        title: 'Not just another alert',
        description: 'Velvoix goes beyond simply flagging that something happened.',
        effect: 'Less interpretation burden, calmer follow-up.',
      },
      {
        index: '02',
        title: 'Clearer priority',
        description: 'Teams see faster what needs attention and what should happen first.',
        effect: 'Better prioritisation, clearer action.',
      },
      {
        index: '03',
        title: 'Follow-up stays visible in one place',
        description: 'Status, responsibility and next steps stay visible together for the care team and for review.',
        effect: 'Clearer follow-up, better reconstruction.',
      },
    ],
  },
  nl: {
    eyebrow: 'Waarom Velvoix anders is',
    title: 'Waarom Velvoix in de praktijk anders werkt',
    description:
      'Velvoix stopt niet bij de melding, maar helpt teams door tot duidelijke actie en herleidbare opvolging.',
    rows: [
      {
        index: '01',
        title: 'Niet nog een losse melding',
        description: 'Velvoix helpt verder dan alleen doorgeven dat er iets is gebeurd.',
        effect: 'Minder interpretatieruis, rustigere opvolging.',
      },
      {
        index: '02',
        title: 'Duidelijke prioriteit',
        description: 'Teams zien sneller wat aandacht vraagt en wat eerst moet gebeuren.',
        effect: 'Betere prioritering, duidelijkere actie.',
      },
      {
        index: '03',
        title: 'Opvolging blijft in één lijn zichtbaar',
        description: 'Status, verantwoordelijkheid en vervolg blijven samen zichtbaar voor werkvloer en evaluatie.',
        effect: 'Duidelijkere opvolging, betere reconstructie.',
      },
    ],
  },
  de: {
    eyebrow: 'Warum Velvoix anders ist',
    title: 'Warum Velvoix in der Praxis anders funktioniert',
    description:
      'Velvoix bleibt nicht bei der Meldung stehen, sondern hilft Teams bis hin zu einer klaren Handlung und nachvollziehbaren Nachverfolgung.',
    rows: [
      {
        index: '01',
        title: 'Mehr als nur eine weitere Meldung',
        description: 'Velvoix geht über den bloßen Hinweis hinaus, dass etwas passiert ist.',
        effect: 'Weniger Interpretationslast, ruhigere Nachverfolgung.',
      },
      {
        index: '02',
        title: 'Klare Priorität',
        description: 'Teams sehen schneller, was Aufmerksamkeit braucht und was zuerst geschehen muss.',
        effect: 'Bessere Priorisierung, klarere Handlung.',
      },
      {
        index: '03',
        title: 'Nachverfolgung bleibt in einem klaren Ablauf sichtbar',
        description: 'Status, Verantwortung und nächster Schritt bleiben für Team und Auswertung zusammen sichtbar.',
        effect: 'Klarere Nachverfolgung, bessere Rekonstruktion.',
      },
    ],
  },
  es: {
    eyebrow: 'Por qué Velvoix es diferente',
    title: 'Por qué Velvoix funciona de forma distinta en la práctica',
    description:
      'Velvoix no se queda en la alerta, sino que ayuda a los equipos a llegar a una acción clara y a un seguimiento trazable.',
    rows: [
      {
        index: '01',
        title: 'No es solo otra alerta',
        description: 'Velvoix va más allá de limitarse a avisar de que algo ha ocurrido.',
        effect: 'Menos carga interpretativa y un seguimiento más sereno.',
      },
      {
        index: '02',
        title: 'Prioridad más clara',
        description: 'Los equipos ven antes qué requiere atención y qué debe hacerse primero.',
        effect: 'Mejor priorización y acción más clara.',
      },
      {
        index: '03',
        title: 'El seguimiento sigue visible en una misma línea',
        description: 'El estado, la responsabilidad y el siguiente paso permanecen visibles juntos para el equipo y para la revisión posterior.',
        effect: 'Seguimiento más claro y mejor reconstrucción.',
      },
    ],
  },
} satisfies Record<Locale, {
  eyebrow: string;
  title: string;
  description: string;
  rows: Array<{
    index: string;
    title: string;
    description: string;
    effect: string;
  }>;
}>;

const sectionContent = sectionContentByLocale[locale];
---

<section class="section-block" id="why-velvoix">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
    <div class="max-w-[31rem]">
      <SectionIntro
        eyebrow={sectionContent.eyebrow}
        title={sectionContent.title}
        description={sectionContent.description}
      />
    </div>

    <div class="why-principles space-y-3.5">
      {sectionContent.rows.map((row) => (
        <article class="principle-row rounded-[1.35rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(243,247,250,0.92))] px-5 py-5 shadow-[0_12px_26px_rgba(31,53,87,0.05)] md:px-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="shrink-0 md:w-[4.25rem]">
              <p class="text-[0.74rem] font-bold uppercase tracking-[0.2em] text-slate-400">{row.index}</p>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-[1.15rem] font-semibold tracking-tight text-slate-950">{row.title}</h3>
              <p class="mt-2 max-w-[42rem] text-sm leading-6 text-slate-600">{row.description}</p>
              <p class="mt-3 inline-flex items-center gap-2 text-[0.88rem] font-medium text-slate-700">
                <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                <span>{row.effect}</span>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
