---
import type { Locale, WhyVelvoixContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: WhyVelvoixContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
      eyebrow: 'Why Velvoix is different',
      title: 'Why Velvoix works differently in operations',
      description:
        'Velvoix is built to structure care situations into explainable, manageable and auditable workflow.',
      rows: [
        {
            index: '01',
            title: 'Not a notification layer',
            description:
              'Signals become workable events with context, ownership and follow-up.',
            effect: 'Less interpretation burden, tighter follow-up.',
        },
        {
            index: '02',
            title: 'Explainable triage',
            description:
              'Velvoix shows urgency, why attention is needed and which follow-up fits.',
            effect: 'Better prioritisation, clearer action.',
        },
        {
            index: '03',
            title: 'Event truth for workflow and audit',
            description:
              'Status, ownership, escalation and reconstruction build on one operational truth.',
            effect: 'Consistent workflow, traceable reconstruction.',
        },
      ],
    },
  nl: {
      eyebrow: 'Waarom Velvoix anders is',
      title: 'Waarom Velvoix in de praktijk anders werkt',
      description:
        'Velvoix stopt niet bij de melding, maar helpt teams door tot duidelijke actie en herleidbare opvolging.',
      rows: [
        {
            index: '01',
            title: 'Niet nog een losse melding',
            description:
              'Velvoix helpt verder dan alleen doorgeven dat er iets is gebeurd.',
            effect: 'Minder interpretatielast, rustigere opvolging.',
        },
        {
            index: '02',
            title: 'Duidelijke prioriteit',
            description:
              'Teams zien sneller wat aandacht vraagt en wat eerst moet gebeuren.',
            effect: 'Betere prioritering, duidelijkere actie.',
        },
        {
            index: '03',
            title: 'Opvolging blijft in één lijn zichtbaar',
            description:
              'Status, verantwoordelijkheid en vervolg blijven samen zichtbaar voor werkvloer en evaluatie.',
            effect: 'Duidelijkere opvolging, betere reconstructie.',
        },
      ],
    },
  de: {
      eyebrow: 'Warum Velvoix anders ist',
      title: 'Warum Velvoix operativ anders arbeitet',
      description:
        'Velvoix ist dafür gebaut, Pflegesituationen in einen erklärbaren, steuerbaren und auditierbaren Workflow zu überführen.',
      rows: [
        {
          index: '01',
          title: 'Keine Benachrichtigungsschicht',
          description:
            'Signale werden zu handhabbaren Events mit Kontext, Verantwortung und Nachverfolgung.',
          effect: 'Weniger Interpretationslast, straffere Nachverfolgung.',
        },
        {
          index: '02',
          title: 'Erklärbare Triage',
          description:
            'Velvoix zeigt Dringlichkeit, warum etwas Aufmerksamkeit braucht und welche Folgeaktion sinnvoll ist.',
          effect: 'Bessere Priorisierung, klarere Aktion.',
        },
        {
          index: '03',
          title: 'Event-Wahrheit für Workflow und Audit',
          description:
            'Status, Verantwortung, Eskalation und Rekonstruktion bauen auf einer operativen Wahrheit auf.',
          effect: 'Konsistenter Workflow, nachvollziehbare Rekonstruktion.',
        },
      ],
    },
  es: {
      eyebrow: 'Por qué Velvoix es diferente',
      title: 'Por qué Velvoix funciona de otra manera en la operación',
      description:
        'Velvoix está pensado para estructurar situaciones asistenciales en un workflow explicable, gobernable y auditable.',
      rows: [
        {
          index: '01',
          title: 'No es una capa de notificaciones',
          description:
            'Las señales se convierten en eventos operativos con contexto, titularidad y seguimiento.',
          effect: 'Menos carga interpretativa y un seguimiento más estricto.',
        },
        {
          index: '02',
          title: 'Triaje explicable',
          description:
            'Velvoix muestra urgencia, por qué algo requiere atención y qué seguimiento tiene sentido.',
          effect: 'Mejor priorización y acción más clara.',
        },
        {
          index: '03',
          title: 'Verdad del evento para workflow y auditoría',
          description:
            'Estado, titularidad, escalada y reconstrucción se apoyan en una verdad operativa.',
          effect: 'Workflow coherente y reconstrucción trazable.',
        },
      ],
    },
} satisfies Record<Locale, {
  eyebrow: string;
  title: string;
  description: string;
  rows: Array<{
    index: string;
    title: string;
    description: string;
    effect: string;
  }>;
}>;

const sectionContent = sectionContentByLocale[locale];
---

<section class="section-block" id="why-velvoix">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
    <div class="max-w-[31rem]">
      <SectionIntro
        eyebrow={sectionContent.eyebrow}
        title={sectionContent.title}
        description={sectionContent.description}
      />
    </div>

    <div class="why-principles space-y-3.5">
      {sectionContent.rows.map((row) => (
        <article class="principle-row rounded-[1.35rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(243,247,250,0.92))] px-5 py-5 shadow-[0_12px_26px_rgba(31,53,87,0.05)] md:px-6">
          <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
            <div class="shrink-0 md:w-[4.25rem]">
              <p class="text-[0.74rem] font-bold uppercase tracking-[0.2em] text-slate-400">{row.index}</p>
            </div>

            <div class="min-w-0 flex-1">
              <h3 class="text-[1.15rem] font-semibold tracking-tight text-slate-950">{row.title}</h3>
              <p class="mt-2 max-w-[42rem] text-sm leading-6 text-slate-600">{row.description}</p>
              <p class="mt-3 inline-flex items-center gap-2 text-[0.88rem] font-medium text-slate-700">
                <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                <span>{row.effect}</span>
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
