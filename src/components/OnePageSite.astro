---
import type { Locale, SiteContent } from '../content/site';
import ChallengeProofSection from './ChallengeProofSection.astro';
import CompareChainsSection from './CompareChainsSection.astro';
import ContactForm from './ContactForm.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import HeroSection from './HeroSection.astro';
import HowItWorksSection from './HowItWorksSection.astro';
import PilotSection from './PilotSection.astro';
import SnapshotSection from './SnapshotSection.astro';
import WhyDifferentSection from './WhyDifferentSection.astro';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
---

<div class="site-shell">
  <Header locale={locale} nav={content.nav} />

  <main>
    <HeroSection locale={locale} content={content.hero} />

    <ChallengeProofSection content={content.challenge} />

    <CompareChainsSection content={content.compareChains} />

    <HowItWorksSection content={content.howItWorks} />
    <WhyDifferentSection content={content.whyVelvoix} />

    <div class="surface-band">
      <SnapshotSection content={content.snapshots} />
    </div>
    <PilotSection content={content.pilot} />
    <ContactForm content={content.contact} />
  </main>

  <Footer content={content.footer} />
</div>
