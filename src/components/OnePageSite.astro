---
import type { Locale, SiteContent } from '../content/site';
import CompareChainsSection from './CompareChainsSection.astro';
import ContactForm from './ContactForm.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import HeroSection from './HeroSection.astro';
import HowItWorksSection from './HowItWorksSection.astro';
import PilotSection from './PilotSection.astro';
import SectionIntro from './SectionIntro.astro';
import SnapshotSection from './SnapshotSection.astro';
import WhyDifferentSection from './WhyDifferentSection.astro';

interface Props {
  locale: Locale;
  content: SiteContent;
}

const { locale, content } = Astro.props;
---

<div class="site-shell">
  <Header locale={locale} nav={content.nav} />

  <main>
    <HeroSection locale={locale} content={content.hero} />

    <section class="section-block">
      <div class="section-shell grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
        <div>
          <SectionIntro
            eyebrow={content.challenge.eyebrow}
            title={content.challenge.title}
            description={content.challenge.description}
          />
        </div>
        <div class="rounded-[2.4rem] bg-[linear-gradient(180deg,#f1eee5_0%,#edf3f6_100%)] p-4 md:p-5">
          <div class="relative overflow-hidden rounded-[2rem]">
          <div class="relative min-h-[21rem]">
            <img
              src="/media/care-resident.jpg"
              alt={locale === 'nl' ? 'Zorgmedewerker bij bewoner' : 'Care professional with resident'}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/58 via-slate-950/12 to-transparent"></div>
          </div>
          <div class="grid gap-3 p-5 md:p-6">
            {content.challenge.points.map((point) => (
              <div class="rounded-[1.35rem] border border-slate-200/80 bg-white/88 px-5 py-4 text-base font-semibold text-slate-700 shadow-sm">
                {point}
              </div>
            ))}
          </div>
          </div>
        </div>
      </div>
    </section>

    <CompareChainsSection content={content.compareChains} />

    <HowItWorksSection content={content.howItWorks} />
    <WhyDifferentSection content={content.whyVelvoix} />

    <SnapshotSection content={content.snapshots} />
    <PilotSection content={content.pilot} />
    <ContactForm content={content.contact} />
  </main>

  <Footer content={content.footer} />
</div>
