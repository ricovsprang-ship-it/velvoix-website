---
import type { ContactContent } from '../content/site';
import InquiryToggle from './InquiryToggle.astro';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: ContactContent;
}

const { content } = Astro.props;
const formTexts = {
  required: content.errors.required,
  email: content.errors.email,
  phone: content.errors.phone,
  generic: content.errors.generic,
  success: content.success,
};
const routeTexts = content.routeContent;
---

<section class="section-block" id="contact">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr]">
      <div class="rounded-[2rem] border border-slate-200/80 bg-[linear-gradient(180deg,rgba(237,245,243,0.88),rgba(245,249,252,0.92))] p-6 shadow-[0_18px_38px_rgba(31,53,87,0.06)] md:p-8">
        <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />

        <div class="mt-8 rounded-[1.3rem] border border-slate-200/75 bg-white/72 p-4 md:p-5">
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.reasonsLabel}</p>
          <div class="mt-4 space-y-3">
          {content.reasons.map((reason) => (
            <div class="flex items-start gap-3 rounded-[1rem] border border-slate-200/80 bg-white/78 px-4 py-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
              <span class="text-sm font-medium leading-6 text-slate-700">{reason}</span>
            </div>
          ))}
          </div>
        </div>

        <div class="mt-10 rounded-[1.3rem] border border-slate-200 bg-white/92 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{content.directEmailLabel}</p>
          <a class="mt-3 inline-block text-lg font-bold text-slate-950 transition-colors hover:text-[rgb(33_65_120)]" href={`mailto:${content.directEmailValue}`}>
            {content.directEmailValue}
          </a>
          <p class="mt-4 text-sm leading-6 text-slate-600">
            {content.directEmailNote}
          </p>
        </div>
      </div>

      <form
        class="rounded-[2rem] border border-slate-200/80 bg-white/96 p-6 shadow-[0_20px_42px_rgba(31,53,87,0.08)] md:p-8"
        action="/contact.php"
        method="post"
        data-contact-form
        aria-describedby="contact-form-status"
        novalidate
      >
        <InquiryToggle ariaLabel={content.inquiryGroupLabel} labels={content.inquiryTypes} />
        <input type="hidden" name="inquiryTypeValue" value="pilot" data-inquiry-type-input />
        <input type="hidden" name="companyWebsite" value="" />

        <div class="mb-6 rounded-[1.05rem] border border-slate-200/80 bg-slate-50/82 px-4 py-4">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500" data-route-label>{content.inquiryTypes.pilot}</p>
          <p class="mt-2 max-w-[44rem] text-sm leading-6 text-slate-600" data-route-helper>{routeTexts.pilot.helper}</p>
          <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
            <span class="font-semibold text-slate-500">{content.routeEmailLabel}</span>
            <a
              class="font-semibold text-[rgb(33_65_120)] transition-colors hover:text-[rgb(27_53_99)]"
              href={`mailto:${routeTexts.pilot.email}`}
              data-route-email
            >
              {routeTexts.pilot.email}
            </a>
          </div>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.name}</span>
            <input class="field-input" id="contact-name" name="name" type="text" placeholder={content.placeholders.name} autocomplete="name" inputmode="text" data-required="true" data-validate-field required />
            <span class="field-error" id="contact-name-error" data-error-for="name"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.organisation}</span>
            <input class="field-input" id="contact-organisation" name="organisation" type="text" placeholder={content.placeholders.organisation} autocomplete="organization" inputmode="text" data-required="true" data-validate-field required />
            <span class="field-error" id="contact-organisation-error" data-error-for="organisation"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.email}</span>
            <input class="field-input" id="contact-email" name="email" type="email" placeholder={content.placeholders.email} autocomplete="email" inputmode="email" spellcheck="false" autocapitalize="off" data-required="true" data-validate-field required />
            <span class="field-error" id="contact-email-error" data-error-for="email"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.phone}</span>
            <input class="field-input" id="contact-phone" name="phone" type="tel" placeholder={content.placeholders.phone} autocomplete="tel" inputmode="tel" data-validate-field />
            <span class="field-error" id="contact-phone-error" data-error-for="phone"></span>
          </label>
        </div>

        <label class="mt-5 block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.message}</span>
          <textarea class="field-input min-h-40 resize-y" id="contact-message" name="message" placeholder={routeTexts.pilot.messagePlaceholder} autocomplete="off" rows="6" data-message-field data-required="true" data-validate-field required></textarea>
          <span class="field-error" id="contact-message-error" data-error-for="message"></span>
        </label>

        <div class="mt-6 flex flex-col gap-4 border-t border-slate-200/80 pt-5 sm:flex-row sm:items-center sm:justify-between">
          <p class="status-copy text-slate-500" id="contact-form-status" data-form-status tabindex="-1" role="status" aria-live="polite" aria-atomic="true"></p>
          <button class="button-primary" type="submit" data-submit-button>{routeTexts.pilot.submit}</button>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline define:vars={{ formTexts, routeTexts }}>
  const forms = document.querySelectorAll('[data-contact-form]');
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const phoneRegex = /^[+()0-9\s-]{6,}$/;

  for (const form of forms) {
    const statusNode = form.querySelector('[data-form-status]');
    const submitButton = form.querySelector('[data-submit-button]');
    const inquiryInput = form.querySelector('[data-inquiry-type-input]');
    const routeLabel = form.querySelector('[data-route-label]');
    const routeHelper = form.querySelector('[data-route-helper]');
    const routeEmail = form.querySelector('[data-route-email]');
    const messageField = form.querySelector('[data-message-field]');
    const routeInputs = Array.from(form.querySelectorAll('input[name="inquiryType"]'));
    const fields = Array.from(form.querySelectorAll('[data-validate-field]'));

    const getErrorNode = (field) => form.querySelector(`[data-error-for="${field.name}"]`);

    const clearFieldError = (field) => {
      const errorNode = getErrorNode(field);
      if (errorNode) errorNode.textContent = '';
      field.removeAttribute('aria-invalid');
      field.removeAttribute('aria-describedby');
    };

    const setFieldError = (field, message) => {
      const errorNode = getErrorNode(field);
      if (errorNode) {
        errorNode.textContent = message;
        if (errorNode.id) {
          field.setAttribute('aria-describedby', errorNode.id);
        }
      }
      field.setAttribute('aria-invalid', 'true');
    };

    const setStatus = (message, state) => {
      if (!statusNode) return;
      statusNode.textContent = message;
      statusNode.dataset.state = state;
      statusNode.setAttribute('aria-live', state === 'error' ? 'assertive' : 'polite');
      statusNode.setAttribute('role', state === 'error' ? 'alert' : 'status');
    };

    for (const field of fields) {
      if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) continue;
      field.addEventListener('input', () => {
        clearFieldError(field);
        if (statusNode?.dataset.state === 'error') {
          setStatus('', '');
        }
      });
    }

    const applyRoute = (route) => {
      const selected = routeTexts[route] ?? routeTexts.pilot;
      const selectedLabel = routeInputs.find((input) => input.value === route)?.parentElement?.textContent?.trim() ?? '';
      if (inquiryInput instanceof HTMLInputElement) inquiryInput.value = route;
      if (routeLabel) routeLabel.textContent = selectedLabel;
      if (routeHelper) routeHelper.textContent = selected.helper;
      if (routeEmail instanceof HTMLAnchorElement) {
        routeEmail.textContent = selected.email;
        routeEmail.href = `mailto:${selected.email}`;
      }
      if (messageField instanceof HTMLTextAreaElement) messageField.placeholder = selected.messagePlaceholder;
      if (submitButton) submitButton.textContent = selected.submit;
    };

    for (const input of routeInputs) {
      input.addEventListener('change', () => {
        if (input instanceof HTMLInputElement && input.checked) {
          applyRoute(input.value);
        }
      });
    }

    applyRoute('pilot');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      let hasErrors = false;
      let firstInvalidField = null;

      for (const field of fields) {
        if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement)) continue;
        clearFieldError(field);

        const value = field.value.trim();
        if (field.dataset.required === 'true' && !value) {
          hasErrors = true;
          setFieldError(field, formTexts.required);
          firstInvalidField ??= field;
          continue;
        }

        if (field.name === 'email' && value && !emailRegex.test(value)) {
          hasErrors = true;
          setFieldError(field, formTexts.email);
          firstInvalidField ??= field;
        }

        if (field.name === 'phone' && value && !phoneRegex.test(value)) {
          hasErrors = true;
          setFieldError(field, formTexts.phone);
          firstInvalidField ??= field;
        }
      }

      setStatus('', '');

      if (hasErrors) {
        setStatus(formTexts.generic, 'error');
        firstInvalidField?.focus();
        return;
      }

      submitButton?.setAttribute('disabled', 'true');
      submitButton?.setAttribute('aria-busy', 'true');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.getAttribute('action') ?? '/contact.php', {
          method: 'POST',
          headers: {
            Accept: 'application/json',
          },
          body: formData,
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok || payload.ok !== true) {
          throw new Error(payload.error || formTexts.generic);
        }

        form.reset();
        applyRoute('pilot');
        for (const field of fields) {
          if (field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement) {
            clearFieldError(field);
          }
        }
        setStatus(formTexts.success, 'success');
        statusNode?.focus();
      } catch (error) {
        setStatus(error instanceof Error && error.message ? error.message : formTexts.generic, 'error');
        statusNode?.focus();
      } finally {
        submitButton?.removeAttribute('disabled');
        submitButton?.removeAttribute('aria-busy');
      }
    });
  }
</script>
