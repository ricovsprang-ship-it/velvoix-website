---
import type { ContactContent } from '../content/site';
import InquiryToggle from './InquiryToggle.astro';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: ContactContent;
}

const { content } = Astro.props;
const formTexts = {
  required: content.errors.required,
  email: content.errors.email,
  phone: content.errors.phone,
  generic: content.errors.generic,
  success: content.success,
};
const routeTexts = content.routeContent;
---

<section class="section-block" id="contact">
  <div class="section-shell">
    <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr]">
      <div class="rounded-[2rem] border border-slate-200/80 bg-[linear-gradient(180deg,rgba(237,245,243,0.88),rgba(245,249,252,0.92))] p-6 shadow-[0_18px_38px_rgba(31,53,87,0.06)] md:p-8">
        <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />

        <div class="mt-8 space-y-3">
          {content.reasons.map((reason) => (
            <div class="flex items-start gap-3 rounded-[1rem] border border-slate-200/80 bg-white/78 px-4 py-3">
              <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
              <span class="text-sm font-medium leading-6 text-slate-700">{reason}</span>
            </div>
          ))}
        </div>

        <div class="mt-10 rounded-[1.3rem] border border-slate-200 bg-white/92 p-5">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{content.directEmailLabel}</p>
          <a class="mt-3 inline-block text-lg font-bold text-slate-950 hover:text-teal-700" href={`mailto:${content.directEmailValue}`}>
            {content.directEmailValue}
          </a>
          <p class="mt-4 text-sm leading-6 text-slate-600">
            {content.directEmailNote}
          </p>
        </div>
      </div>

      <form
        class="rounded-[2rem] border border-slate-200/80 bg-white/96 p-6 shadow-[0_20px_42px_rgba(31,53,87,0.08)] md:p-8"
        action="/contact.php"
        method="post"
        data-contact-form
        novalidate
      >
        <InquiryToggle labels={content.inquiryTypes} />
        <input type="hidden" name="inquiryTypeValue" value="pilot" data-inquiry-type-input />
        <input class="sr-only" type="text" name="companyWebsite" tabindex="-1" autocomplete="off" />

        <div class="mb-6 rounded-[1rem] border border-slate-200/80 bg-slate-50/80 px-4 py-3">
          <p class="text-xs font-bold uppercase tracking-[0.16em] text-slate-500" data-route-label>{content.inquiryTypes.pilot}</p>
          <p class="mt-2 text-sm leading-6 text-slate-600" data-route-helper>{routeTexts.pilot.helper}</p>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.name}</span>
            <input class="field-input" name="name" type="text" placeholder={content.placeholders.name} data-required="true" />
            <span class="field-error" data-error-for="name"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.organisation}</span>
            <input class="field-input" name="organisation" type="text" placeholder={content.placeholders.organisation} data-required="true" />
            <span class="field-error" data-error-for="organisation"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.email}</span>
            <input class="field-input" name="email" type="email" placeholder={content.placeholders.email} data-required="true" />
            <span class="field-error" data-error-for="email"></span>
          </label>
          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.phone}</span>
            <input class="field-input" name="phone" type="tel" placeholder={content.placeholders.phone} />
            <span class="field-error" data-error-for="phone"></span>
          </label>
        </div>

        <label class="mt-5 block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">{content.labels.message}</span>
          <textarea class="field-input min-h-40 resize-y" name="message" placeholder={routeTexts.pilot.messagePlaceholder} data-message-field data-required="true"></textarea>
          <span class="field-error" data-error-for="message"></span>
        </label>

        <div class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
          <p class="status-copy text-slate-500" data-form-status></p>
          <button class="button-primary" type="submit" data-submit-button>{routeTexts.pilot.submit}</button>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline define:vars={{ formTexts, routeTexts }}>
  const forms = document.querySelectorAll('[data-contact-form]');
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const phoneRegex = /^[+()0-9\s-]{6,}$/;

  for (const form of forms) {
    const statusNode = form.querySelector('[data-form-status]');
    const submitButton = form.querySelector('[data-submit-button]');
    const inquiryInput = form.querySelector('[data-inquiry-type-input]');
    const routeLabel = form.querySelector('[data-route-label]');
    const routeHelper = form.querySelector('[data-route-helper]');
    const messageField = form.querySelector('[data-message-field]');
    const routeInputs = Array.from(form.querySelectorAll('input[name="inquiryType"]'));

    const applyRoute = (route) => {
      const selected = routeTexts[route] ?? routeTexts.pilot;
      const selectedLabel = routeInputs.find((input) => input.value === route)?.parentElement?.textContent?.trim() ?? '';
      if (inquiryInput instanceof HTMLInputElement) inquiryInput.value = route;
      if (routeLabel) routeLabel.textContent = selectedLabel;
      if (routeHelper) routeHelper.textContent = selected.helper;
      if (messageField instanceof HTMLTextAreaElement) messageField.placeholder = selected.messagePlaceholder;
      if (submitButton) submitButton.textContent = selected.submit;
    };

    for (const input of routeInputs) {
      input.addEventListener('change', () => {
        if (input instanceof HTMLInputElement && input.checked) {
          applyRoute(input.value);
        }
      });
    }

    applyRoute('pilot');

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      let hasErrors = false;

      const fields = Array.from(form.querySelectorAll('input, textarea'));
      for (const field of fields) {
        const errorNode = form.querySelector(`[data-error-for="${field.name}"]`);
        if (errorNode) {
          errorNode.textContent = '';
        }

        const value = field.value.trim();
        if (field.dataset.required === 'true' && !value) {
          hasErrors = true;
          if (errorNode) errorNode.textContent = formTexts.required;
          continue;
        }

        if (field.name === 'email' && value && !emailRegex.test(value)) {
          hasErrors = true;
          if (errorNode) errorNode.textContent = formTexts.email;
        }

        if (field.name === 'phone' && value && !phoneRegex.test(value)) {
          hasErrors = true;
          if (errorNode) errorNode.textContent = formTexts.phone;
        }
      }

      if (statusNode) {
        statusNode.textContent = '';
        statusNode.dataset.state = '';
      }

      if (hasErrors) {
        if (statusNode) {
          statusNode.textContent = formTexts.generic;
          statusNode.dataset.state = 'error';
        }
        return;
      }

      submitButton?.setAttribute('disabled', 'true');
      submitButton?.setAttribute('aria-busy', 'true');

      try {
        const formData = new FormData(form);
        const response = await fetch(form.getAttribute('action') ?? '/contact.php', {
          method: 'POST',
          headers: {
            Accept: 'application/json',
          },
          body: formData,
        });

        const payload = await response.json().catch(() => ({}));

        if (!response.ok || payload.ok !== true) {
          throw new Error(payload.error || formTexts.generic);
        }

        form.reset();
        applyRoute('pilot');
        if (statusNode) {
          statusNode.textContent = formTexts.success;
          statusNode.dataset.state = 'success';
        }
      } catch (error) {
        if (statusNode) {
          statusNode.textContent = error instanceof Error && error.message ? error.message : formTexts.generic;
          statusNode.dataset.state = 'error';
        }
      } finally {
        submitButton?.removeAttribute('disabled');
        submitButton?.removeAttribute('aria-busy');
      }
    });
  }
</script>
