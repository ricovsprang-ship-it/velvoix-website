---
interface Card {
  title: string;
  description: string;
}

interface Props {
  cards: Card[];
  variant?: 'steps' | 'features';
}

const { cards, variant = 'features' } = Astro.props;
---

<div class:list={['mt-10 grid gap-5', variant === 'steps' ? 'md:grid-cols-2 xl:grid-cols-4' : 'lg:grid-cols-3']}>
  {cards.map((card, index) => (
    <article class="panel rounded-[2rem] p-6">
      <div class="flex items-start justify-between gap-4">
        <h3 class="text-xl font-bold tracking-tight text-slate-950">{card.title}</h3>
        <div class="rounded-full bg-slate-950 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-white">
          {index + 1}
        </div>
      </div>
      <p class="mt-4 text-base leading-7 text-slate-600">{card.description}</p>
    </article>
  ))}
</div>
