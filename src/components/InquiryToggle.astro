---
interface Props {
  labels: {
    pilot: string;
    general: string;
  };
}

const { labels } = Astro.props;
---

<div class="mb-6 rounded-[1.5rem] border border-slate-200 bg-white/86 p-2">
  <div class="grid gap-2 sm:grid-cols-2">
    <label class="cursor-pointer rounded-[1rem] border border-slate-950 bg-slate-950 px-4 py-3 text-sm font-semibold text-white">
      <input class="sr-only" type="radio" name="inquiryType" value="pilot" checked />
      {labels.pilot}
    </label>
    <label class="cursor-pointer rounded-[1rem] border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 hover:border-slate-300 hover:bg-slate-50">
      <input class="sr-only" type="radio" name="inquiryType" value="general" />
      {labels.general}
    </label>
  </div>
</div>
