---
import { legalLocaleFallback, localeRootPaths } from '../content/site';
import type { FooterContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: FooterContent;
}

const { locale, content } = Astro.props;
const basePath = localeRootPaths[locale];
const legalBasePath = legalLocaleFallback[locale] === 'nl' ? '' : '/en';
const languageLabels: Record<Locale, string> = {
  nl: 'Nederlands',
  en: 'English',
  de: 'Deutsch',
  es: 'Español',
};
const copyrightByLocale: Record<Locale, string> = {
  nl: '© 2026 Velvoix® · Alle rechten voorbehouden.',
  en: '© 2026 Velvoix® · All rights reserved.',
  de: '© 2026 Velvoix® · Alle Rechte vorbehalten.',
  es: '© 2026 Velvoix® · Todos los derechos reservados.',
};
---

<footer class="border-t border-white/60 py-8">
  <div class="section-shell flex flex-col gap-4 text-sm text-slate-600 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-1.5">
      <div class="vx-wordmark text-[1.5rem] text-slate-950">{content.brand}</div>
      <p class="text-xs text-slate-500">
        {copyrightByLocale[locale]}
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-5">
      <a href={localeRootPaths.nl}>{languageLabels.nl}</a>
      <a href={localeRootPaths.en}>{languageLabels.en}</a>
      <a href={localeRootPaths.de}>{languageLabels.de}</a>
      <a href={localeRootPaths.es}>{languageLabels.es}</a>
      <a href={`${basePath}#contact`}>{content.contact}</a>
      <a href={`${legalBasePath}/privacy-policy`}>{content.privacy}</a>
      <a href={`${legalBasePath}/cookie-policy`}>{content.cookies}</a>
      <a href={`${legalBasePath}/terms-and-conditions`}>{content.terms}</a>
    </div>
  </div>
</footer>
