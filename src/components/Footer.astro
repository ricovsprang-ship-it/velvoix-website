---
import { localeRootPaths } from '../content/site';
import type { FooterContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: FooterContent;
}

const { locale, content } = Astro.props;
const basePath = localeRootPaths[locale];
const legalBasePath = locale === 'nl' ? '' : localeRootPaths[locale].replace(/\/$/, '');

const languageLinks = [
  { href: localeRootPaths.nl, locale: 'nl', label: content.languageNl },
  { href: localeRootPaths.en, locale: 'en', label: content.languageEn },
  { href: localeRootPaths.de, locale: 'de', label: content.languageDe },
  { href: localeRootPaths.es, locale: 'es', label: content.languageEs },
] as const;

const legalLinks = [
  { href: `${basePath}#contact`, label: content.contact },
  { href: `${legalBasePath}/privacy-policy`, label: content.privacy },
  { href: `${legalBasePath}/cookie-policy`, label: content.cookies },
  { href: `${legalBasePath}/terms-and-conditions`, label: content.terms },
] as const;

const ariaLabels: Record<Locale, { footer: string; languages: string }> = {
  nl: {
    footer: 'Footerlinks',
    languages: 'Talen',
  },
  en: {
    footer: 'Footer links',
    languages: 'Languages',
  },
  de: {
    footer: 'Links im Footer',
    languages: 'Sprachen',
  },
  es: {
    footer: 'Enlaces del pie',
    languages: 'Idiomas',
  },
};
---

<footer class="border-t border-white/60 py-8 md:py-10">
  <div class="section-shell">
    <div class="footer-shell">
      <div class="footer-brand-block">
        <div class="vx-wordmark text-[1.5rem] text-slate-950">{content.brand}</div>
        <p class="footer-meta">{content.copyright}</p>
      </div>

      <div class="footer-utility">
        <nav class="footer-links" aria-label={ariaLabels[locale].footer}>
          {legalLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="footer-languages" aria-label={ariaLabels[locale].languages}>
          {languageLinks.map((link) => (
            <a href={link.href} data-language-link data-language-locale={link.locale}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    display: grid;
    gap: 1.25rem;
    padding-top: 0.25rem;
  }

  .footer-brand-block {
    display: grid;
    gap: 0.45rem;
  }

  .footer-meta {
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgb(100 116 139);
  }

  .footer-links,
  .footer-languages {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem 1rem;
  }

  .footer-links {
    font-size: 0.9rem;
    color: rgb(71 85 105);
  }

  .footer-utility {
    display: grid;
    gap: 0.8rem;
  }

  .footer-links a,
  .footer-languages a {
    transition: color 160ms ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible,
  .footer-languages a:hover,
  .footer-languages a:focus-visible {
    color: rgb(15 23 42);
  }

  .footer-languages {
    font-size: 0.82rem;
    color: rgb(100 116 139);
  }

  .footer-languages a {
    position: relative;
  }

  .footer-languages a + a {
    padding-left: 0.8rem;
  }

  .footer-languages a + a::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1px;
    height: 0.72rem;
    background: rgba(203, 213, 225, 0.96);
    transform: translateY(-50%);
  }

  @media (min-width: 768px) {
    .footer-shell {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }

    .footer-utility {
      justify-items: end;
    }

    .footer-links,
    .footer-languages {
      justify-content: flex-end;
    }
  }
</style>
