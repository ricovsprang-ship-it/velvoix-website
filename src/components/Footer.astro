---
import type { FooterContent } from '../content/site';

interface Props {
  locale: 'nl' | 'en';
  content: FooterContent;
}

const { locale, content } = Astro.props;
const basePath = locale === 'nl' ? '' : '/en';
---

<footer class="border-t border-white/60 py-8">
  <div class="section-shell flex flex-col gap-4 text-sm text-slate-600 md:flex-row md:items-center md:justify-between">
    <div class="flex flex-col gap-1.5">
      <div class="vx-wordmark text-[1.5rem] text-slate-950">{content.brand}</div>
      <p class="text-xs text-slate-500">
        &copy; 2026 Velvoix&reg; &middot; {locale === 'nl' ? 'Alle rechten voorbehouden.' : 'All rights reserved.'}
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-5">
      <a href="/">{content.languageNl}</a>
      <a href="/en/">{content.languageEn}</a>
      <a href={`${basePath}/#contact`}>{content.contact}</a>
      <a href={`${basePath}/privacy-policy`}>{content.privacy}</a>
      <a href={`${basePath}/cookie-policy`}>{content.cookies}</a>
      <a href={`${basePath}/terms-and-conditions`}>{content.terms}</a>
    </div>
  </div>
</footer>
