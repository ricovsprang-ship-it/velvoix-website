---
import { localeRootPaths } from '../content/site';
import type { FooterContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: FooterContent;
}

const { locale, content } = Astro.props;
const basePath = localeRootPaths[locale];
const legalBasePath = locale === 'nl' ? '' : localeRootPaths[locale].replace(/\/$/, '');

const languageLinks = [
  { href: localeRootPaths.nl, locale: 'nl', label: content.languageNl },
  { href: localeRootPaths.en, locale: 'en', label: content.languageEn },
  { href: localeRootPaths.de, locale: 'de', label: content.languageDe },
  { href: localeRootPaths.es, locale: 'es', label: content.languageEs },
] as const;

const legalLinks = [
  { href: `${basePath}#contact`, label: content.contact },
  { href: `${legalBasePath}/privacy-policy`, label: content.privacy },
  { href: `${legalBasePath}/cookie-policy`, label: content.cookies },
  { href: `${legalBasePath}/terms-and-conditions`, label: content.terms },
] as const;

const ariaLabels: Record<
  Locale,
  { footer: string; languages: string; socialNote: string; linkedin: string; youtube: string }
> = {
  nl: {
    footer: 'Footerlinks',
    languages: 'Talen',
    socialNote: 'LinkedIn- en YouTube-links volgen later.',
    linkedin: 'LinkedIn',
    youtube: 'YouTube',
  },
  en: {
    footer: 'Footer links',
    languages: 'Languages',
    socialNote: 'LinkedIn and YouTube links are coming later.',
    linkedin: 'LinkedIn',
    youtube: 'YouTube',
  },
  de: {
    footer: 'Links im Footer',
    languages: 'Sprachen',
    socialNote: 'LinkedIn- und YouTube-Links folgen später.',
    linkedin: 'LinkedIn',
    youtube: 'YouTube',
  },
  es: {
    footer: 'Enlaces del pie',
    languages: 'Idiomas',
    socialNote: 'Los enlaces de LinkedIn y YouTube llegarán más adelante.',
    linkedin: 'LinkedIn',
    youtube: 'YouTube',
  },
};
---

<footer class="border-t border-white/60 py-8 md:py-10">
  <div class="section-shell">
    <div class="footer-shell">
      <div class="footer-brand-block">
        <div class="vx-wordmark text-[1.5rem] text-slate-950">{content.brand}</div>
        <p class="footer-meta">{content.copyright}</p>
      </div>

      <div class="footer-utility">
        <div class="footer-social-group">
          <div class="footer-socials" aria-hidden="true">
            <span class="footer-social-link" title={ariaLabels[locale].linkedin}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M6.94 8.5V18H3.8V8.5h3.14Zm.2-2.94c0 1-.75 1.8-1.78 1.8h-.02c-1 0-1.74-.8-1.74-1.8 0-1.03.76-1.81 1.77-1.81s1.75.78 1.77 1.8ZM20.2 12.13V18h-3.13v-5.5c0-1.38-.5-2.33-1.73-2.33-.95 0-1.5.64-1.75 1.26-.1.22-.12.54-.12.86V18H10.3s.04-9.02 0-9.5h3.13v1.35c.42-.65 1.16-1.58 2.84-1.58 2.07 0 3.63 1.35 3.63 4.25Z" />
              </svg>
            </span>
            <span class="footer-social-link" title={ariaLabels[locale].youtube}>
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21.1 7.2a2.9 2.9 0 0 0-2.03-2.04C17.28 4.67 12 4.67 12 4.67s-5.28 0-7.07.5A2.9 2.9 0 0 0 2.9 7.2c-.5 1.8-.5 4.8-.5 4.8s0 3 .5 4.8a2.9 2.9 0 0 0 2.03 2.03c1.79.5 7.07.5 7.07.5s5.28 0 7.07-.5a2.9 2.9 0 0 0 2.03-2.03c.5-1.8.5-4.8.5-4.8s0-3-.5-4.8ZM10.3 15.03V8.97L15.57 12l-5.27 3.03Z" />
              </svg>
            </span>
          </div>
          <p class="footer-social-note">{ariaLabels[locale].socialNote}</p>
        </div>

        <nav class="footer-links" aria-label={ariaLabels[locale].footer}>
          {legalLinks.map((link) => (
            <a href={link.href}>{link.label}</a>
          ))}
        </nav>

        <nav class="footer-languages" aria-label={ariaLabels[locale].languages}>
          {languageLinks.map((link) => (
            <a href={link.href} data-language-link data-language-locale={link.locale}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    display: grid;
    gap: 1.25rem;
    padding-top: 0.25rem;
  }

  .footer-brand-block {
    display: grid;
    gap: 0.45rem;
  }

  .footer-meta {
    font-size: 0.78rem;
    line-height: 1.6;
    color: rgb(100 116 139);
  }

  .footer-socials,
  .footer-links,
  .footer-languages {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.8rem 1rem;
  }

  .footer-links,
  .footer-languages {
    font-size: 0.9rem;
    color: rgb(71 85 105);
  }

  .footer-social-group {
    display: grid;
    gap: 0.45rem;
    justify-items: start;
  }

  .footer-utility {
    display: grid;
    gap: 0.8rem;
  }

  .footer-links a,
  .footer-languages a {
    transition: color 160ms ease;
  }

  .footer-links a:hover,
  .footer-links a:focus-visible,
  .footer-languages a:hover,
  .footer-languages a:focus-visible {
    color: rgb(15 23 42);
  }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid rgba(203, 213, 225, 0.92);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    color: rgb(2 6 23);
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.04);
    opacity: 0.82;
  }

  .footer-social-link svg {
    width: 1.02rem;
    height: 1.02rem;
    fill: currentColor;
  }

  .footer-social-note {
    font-size: 0.76rem;
    line-height: 1.5;
    color: rgb(100 116 139);
  }

  .footer-languages {
    font-size: 0.82rem;
    color: rgb(100 116 139);
  }

  .footer-languages a {
    position: relative;
  }

  .footer-languages a + a {
    padding-left: 0.8rem;
  }

  .footer-languages a + a::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 1px;
    height: 0.72rem;
    background: rgba(203, 213, 225, 0.96);
    transform: translateY(-50%);
  }

  @media (min-width: 768px) {
    .footer-shell {
      grid-template-columns: minmax(0, 1fr) auto;
      align-items: start;
    }

    .footer-utility {
      justify-items: end;
    }

    .footer-social-group {
      justify-items: end;
    }

    .footer-socials,
    .footer-links,
    .footer-languages {
      justify-content: flex-end;
    }
  }
</style>
