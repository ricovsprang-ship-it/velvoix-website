---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, description, align = 'left' } = Astro.props;
const centered = align === 'center';
---

<div class:list={['max-w-3xl', centered && 'mx-auto text-center']}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="mt-4 text-3xl font-extrabold tracking-tight text-slate-950 [text-wrap:balance] md:text-4xl">{title}</h2>
  <p class="mt-5 max-w-[44rem] text-base leading-7 text-slate-600 [text-wrap:pretty] md:text-lg md:leading-8">{description}</p>
</div>
