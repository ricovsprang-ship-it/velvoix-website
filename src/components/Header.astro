---
import type { Locale, NavItem } from '../content/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  nav: NavItem[];
}

const { locale, nav } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-white/60 bg-white/72 backdrop-blur-xl">
  <div class="section-shell flex items-center justify-between gap-6 py-4">
    <a href={locale === 'nl' ? '/' : '/en/'} class="flex items-center gap-3 text-slate-950">
      <span class="flex size-11 items-center justify-center rounded-2xl bg-slate-950 text-lg font-extrabold text-white">
        V
      </span>
      <span class="text-lg font-extrabold tracking-tight">Velvoix</span>
    </a>

    <nav class="hidden items-center gap-7 text-sm font-semibold lg:flex">
      {nav.map((item) => (
        <a class="nav-link" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="hidden lg:block">
      <LanguageSwitcher locale={locale} />
    </div>

    <details class="relative lg:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-800 shadow-sm">
        Menu
      </summary>
      <div class="panel absolute right-0 top-14 w-[18rem] rounded-3xl p-4">
        <div class="mb-4">
          <LanguageSwitcher locale={locale} />
        </div>
        <div class="flex flex-col gap-1">
          {nav.map((item) => (
            <a class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100" href={item.href}>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>
