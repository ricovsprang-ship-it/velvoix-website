---
import { localeRootPaths } from '../content/site';
import type { Locale, NavItem } from '../content/site';
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  locale: Locale;
  nav: NavItem[];
  languagePaths?: Partial<Record<Locale, string>>;
}

const { locale, nav, languagePaths } = Astro.props;
const orderedLocales: Locale[] = ['nl', 'en', 'de', 'es'];
const hasScopedLanguagePaths = Boolean(languagePaths && Object.keys(languagePaths).length > 0);
const languageCodeByLocale: Record<Locale, string> = {
  nl: 'NL',
  en: 'EN',
  de: 'DE',
  es: 'ES',
};
const mobileLanguages = orderedLocales
  .filter((candidate) => !hasScopedLanguagePaths || Boolean(languagePaths?.[candidate]))
  .map((candidate) => ({
    locale: candidate,
    code: languageCodeByLocale[candidate],
    href: languagePaths?.[candidate] ?? localeRootPaths[candidate],
    isActive: candidate === locale,
  }));
const menuLabelByLocale: Record<Locale, string> = {
  nl: 'Menu',
  en: 'Menu',
  de: 'Menu',
  es: 'Menu',
};
const languageLabelByLocale: Record<Locale, string> = {
  nl: 'Talen',
  en: 'Languages',
  de: 'Sprachen',
  es: 'Idiomas',
};
---

<header class="sticky top-0 z-50 border-b border-slate-200/70 bg-[rgba(249,251,253,0.92)] backdrop-blur-xl">
  <div class="mx-auto flex h-[5.25rem] w-full max-w-[1280px] items-center justify-between px-5 md:px-10">
    <div class="flex min-w-0 items-center">
      <a href={localeRootPaths[locale]} class="shrink-0 text-slate-950">
        <span class="vx-wordmark text-[1.72rem] md:text-[2.05rem]">Velvoix</span>
      </a>

      <nav class="ml-14 hidden items-center gap-7 text-sm font-semibold xl:ml-[4.2rem] lg:flex">
        {nav.map((item) => (
          <a class="nav-link whitespace-nowrap" href={item.href}>{item.label}</a>
        ))}
      </nav>
    </div>

    <div class="hidden lg:flex lg:items-center">
      <LanguageSwitcher locale={locale} languagePaths={languagePaths} />
    </div>

    <details class="relative lg:hidden">
      <summary class="flex cursor-pointer list-none items-center gap-2 rounded-full border border-slate-200 bg-white/92 px-4 py-2 text-sm font-semibold text-slate-800">
        {menuLabelByLocale[locale]}
      </summary>
      <div class="panel absolute right-0 top-14 w-[18rem] rounded-3xl p-4">
        <div class="mb-4">
          <p class="mb-3 text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{languageLabelByLocale[locale]}</p>
          <div class="grid grid-cols-4 gap-2" aria-label={languageLabelByLocale[locale]}>
            {mobileLanguages.map((language) => (
              <a
                href={language.href}
                class:list={[
                  'inline-flex min-h-11 items-center justify-center rounded-[0.95rem] border text-sm font-bold tracking-[0.08em]',
                  language.isActive
                    ? 'border-slate-200 bg-slate-100 text-slate-950'
                    : 'border-slate-200 bg-white text-slate-600 hover:bg-slate-50 hover:text-slate-950',
                ]}
                aria-current={language.isActive ? 'page' : undefined}
                data-language-link
                data-language-locale={language.locale}
              >
                {language.code}
              </a>
            ))}
          </div>
        </div>
        <div class="flex flex-col gap-1">
          {nav.map((item) => (
            <a class="rounded-2xl px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-100" href={item.href}>
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </details>
  </div>
</header>
