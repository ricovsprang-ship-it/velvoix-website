---
import type { Locale } from '../content/site';
import { hasResourcePages, getResourcePath, resourceArticlesByLocale, resourceUiByLocale } from '../content/resources';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = resourceUiByLocale[locale];
const articles = hasResourcePages(locale) ? resourceArticlesByLocale[locale] : [];

const validationOverrides = {
  nl: {
    title: 'Wat een eerste pilot in de praktijk moet bewijzen',
    description:
      'Een pilot maakt zichtbaar of Velvoix in uw setting echt helpt om sneller te prioriteren, duidelijker op te volgen en beter te reconstrueren.',
  },
  en: {
    title: 'What a first pilot can validate in practice',
    description:
      'A pilot shows whether Velvoix really helps your setting prioritise faster, follow up more clearly and reconstruct events more effectively.',
    cards: [
      {
        title: 'Seeing faster what needs attention',
        description: 'Which signals lead to clearer follow-up sooner, and where additional context genuinely changes decisions.',
      },
      {
        title: 'Clearer follow-up and responsibility',
        description: 'How status, responsibility and escalation reduce interpretation noise in day-to-day work.',
      },
      {
        title: 'Better reconstruction for review',
        description: 'Which audit and evaluation questions become easier to answer with clearer status progression and reconstruction.',
      },
    ],
  },
  de: {
    eyebrow: 'Pilotvalidierung',
    title: 'Was ein erster Pilot in der Praxis belegen sollte',
    description:
      'Ein Pilot macht sichtbar, ob Velvoix in Ihrer Umgebung wirklich hilft, schneller zu priorisieren, klarer nachzuverfolgen und besser zu rekonstruieren.',
    note:
      'Praktische Ergebnisse hängen von Teams, Prozessen, Geräten und bestehenden Systemen ab. Gerade deshalb ist ein gezielter Pilot wertvoller als eine allgemeine Demo.',
    cards: [
      {
        title: 'Schneller sehen, was Aufmerksamkeit braucht',
        description: 'Welche Signale schneller zu klarer Nachverfolgung führen und wo zusätzlicher Kontext Entscheidungen wirklich verbessert.',
      },
      {
        title: 'Klarere Nachverfolgung und Verantwortung',
        description: 'Wie Status, Verantwortung und Eskalation die tägliche Interpretationslast im Alltag senken.',
      },
      {
        title: 'Bessere Rekonstruktion für Auswertung',
        description: 'Welche Audit- und Evaluationsfragen sich mit klarem Statusverlauf und Rekonstruktion besser beantworten lassen.',
      },
    ],
  },
  es: {
    eyebrow: 'Validación piloto',
    title: 'Qué debe demostrar un primer piloto en la práctica',
    description:
      'Un piloto hace visible si Velvoix realmente ayuda en su entorno a priorizar antes, hacer un seguimiento más claro y reconstruir mejor lo ocurrido.',
    note:
      'Los resultados prácticos dependen de equipos, procesos, dispositivos y sistemas existentes. Por eso un piloto enfocado aporta más que una demo genérica.',
    cards: [
      {
        title: 'Ver antes qué requiere atención',
        description: 'Qué señales conducen antes a un seguimiento claro y dónde el contexto adicional cambia realmente las decisiones.',
      },
      {
        title: 'Seguimiento y responsabilidad más claros',
        description: 'Cómo el estado, la responsabilidad y la escalada reducen el ruido interpretativo en la operación diaria.',
      },
      {
        title: 'Mejor reconstrucción para la revisión',
        description: 'Qué preguntas de auditoría y evaluación se responden mejor con una evolución del estado y una reconstrucción más claras.',
      },
    ],
  },
} as const;

const hubOverrides = {
  nl: {
    description:
      'Drie verdiepende pagina’s over hoe Velvoix zorgsignalen helpt vertalen naar duidelijke opvolging, betere prioritering en herleidbare reconstructie.',
  },
  de: {
    title: 'Mehr Kontext für Entscheidungsträger und Teams',
    description:
      'Drei vertiefende Seiten zu Triage, Workflow und Pilotansatz für Pflegesignale.',
    linkLabel: 'Seite lesen',
  },
  es: {
    title: 'Más contexto para responsables y equipos',
    description:
      'Tres páginas de profundidad sobre triaje, flujo de trabajo y enfoque piloto para señales asistenciales.',
    linkLabel: 'Leer página',
  },
} as const;

const validationContent = {
  ...content.validation,
  ...(validationOverrides[locale] ?? {}),
};

const hubContent = {
  ...content.hub,
  ...(hubOverrides[locale as 'nl' | 'de' | 'es'] ?? {}),
};
---

<section class="section-block surface-band-alt" id="insights">
  <div class="section-shell space-y-10">
    <div class="rounded-[2rem] border border-slate-200/85 bg-white/96 p-6 shadow-[0_20px_40px_rgba(31,53,87,0.06)] md:p-8">
      <SectionIntro
        eyebrow={validationContent.eyebrow}
        title={validationContent.title}
        description={validationContent.description}
      />

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {validationContent.cards.map((card) => (
          <article class="rounded-[1.45rem] border border-slate-200/80 bg-slate-50/75 p-5">
            <h3 class="text-[1.05rem] font-bold tracking-tight text-slate-950">{card.title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-600">{card.description}</p>
          </article>
        ))}
      </div>

      <p class="mt-6 max-w-[58rem] text-sm leading-6 text-slate-500">{validationContent.note}</p>
    </div>

    {articles.length > 0 && (
      <div class="rounded-[2rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(244,248,251,0.94))] p-6 shadow-[0_20px_40px_rgba(31,53,87,0.06)] md:p-8">
        <SectionIntro
          eyebrow={hubContent.eyebrow}
          title={hubContent.title}
          description={hubContent.description}
        />

        <div class="mt-8 grid gap-4 lg:grid-cols-3">
          {articles.map((article) => (
            <article class="flex h-full flex-col rounded-[1.55rem] border border-slate-200/85 bg-white/92 p-5 shadow-[0_16px_28px_rgba(31,53,87,0.04)]">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{article.eyebrow}</p>
              <h3 class="mt-3 text-[1.16rem] font-bold tracking-tight text-slate-950">{article.title}</h3>
              <p class="mt-4 flex-1 text-sm leading-6 text-slate-600">{article.cardDescription}</p>
              <a
                class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-[rgb(33_65_120)] transition-colors hover:text-[rgb(27_53_99)]"
                href={getResourcePath(locale, article)}
              >
                {hubContent.linkLabel}
                <span aria-hidden="true">→</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
