---
import type { Locale, PilotContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: PilotContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
    eyebrow: 'Pilot and partnership',
    title: 'Explore whether Velvoix fits your care practice',
    description:
      'An initial exploration shows whether Velvoix supports clearer follow-up, less interpretation work and a better fit with your processes.',
    audience:
      'Relevant for healthcare organisations, care teams and partners exploring a pilot, rollout or integration.',
    primaryCta: 'Plan an exploration',
    secondaryCta: 'Get in touch',
    moduleTitle: 'A first exploration looks at',
    rows: [
      {
        title: 'Seeing faster what needs attention',
        description: 'Test whether teams can prioritise faster and which situations require immediate action.',
      },
      {
        title: 'Clearer follow-up',
        description: 'Assess whether responsibility, status and the next step can be organised more clearly.',
      },
      {
        title: 'Better reconstruction',
        description: 'Make visible whether status progression and reconstruction are useful for evaluation and quality improvement.',
      },
      {
        title: 'Fit with practice',
        description: 'Explore how Velvoix fits teams, processes, equipment and the existing environment.',
      },
    ],
    organisationTitle: 'For healthcare organisations',
    organisationBody: 'Focus on clearer follow-up, workload and practical fit in day-to-day care.',
    partnerTitle: 'For partners',
    partnerBody: 'Focus on rollout, integration and operational value.',
  },
  nl: {
    eyebrow: 'Pilot en samenwerking',
    title: 'Verken of Velvoix past bij uw zorgpraktijk',
    description:
      'Een eerste verkenning laat zien of Velvoix helpt bij duidelijkere opvolging, minder interpretatieruis en een goede aansluiting op uw processen.',
    audience:
      'Relevant voor zorgorganisaties, teams en partners die een pilot, uitrol of integratie willen verkennen.',
    primaryCta: 'Plan een eerste verkenning',
    secondaryCta: 'Neem contact op',
    moduleTitle: 'Een eerste verkenning kijkt naar',
    rows: [
      {
        title: 'Sneller zien wat aandacht vraagt',
        description: 'Toets of teams sneller kunnen prioriteren en welke situaties direct actie vragen.',
      },
      {
        title: 'Duidelijkere opvolging',
        description: 'Beoordeel of verantwoordelijkheid, status en vervolgstappen duidelijker georganiseerd kunnen worden.',
      },
      {
        title: 'Betere reconstructie',
        description: 'Maak zichtbaar of statusverloop en reconstructie bruikbaar zijn voor evaluatie en kwaliteitsverbetering.',
      },
      {
        title: 'Aansluiting op de praktijk',
        description: 'Verken hoe Velvoix past bij teams, processen, apparaten en de bestaande omgeving.',
      },
    ],
    organisationTitle: 'Voor zorgorganisaties',
    organisationBody: 'Focus op duidelijkere opvolging, werkdruk en een goede aansluiting op de zorgpraktijk.',
    partnerTitle: 'Voor partners',
    partnerBody: 'Focus op uitrol, integratie en operationele meerwaarde.',
  },
  de: {
    eyebrow: 'Pilot und Zusammenarbeit',
    title: 'Prüfen, ob Velvoix zu Ihrer Pflegepraxis passt',
    description:
      'Eine erste Erkundung zeigt, ob Velvoix zu klarerer Nachverfolgung, weniger Interpretationsaufwand und einer besseren Einbindung in Ihre Abläufe beiträgt.',
    audience:
      'Relevant für Pflegeorganisationen, Pflegeteams und Partner, die Pilot, Rollout oder Integration prüfen möchten.',
    primaryCta: 'Erstgespräch planen',
    secondaryCta: 'Kontakt aufnehmen',
    moduleTitle: 'Eine erste Erkundung betrachtet',
    rows: [
      {
        title: 'Schneller sehen, was Aufmerksamkeit braucht',
        description: 'Prüfen Sie, ob Teams schneller priorisieren können und welche Situationen sofortiges Handeln verlangen.',
      },
      {
        title: 'Klarere Nachverfolgung',
        description: 'Beurteilen Sie, ob Verantwortung, Status und der nächste Schritt klarer organisiert werden können.',
      },
      {
        title: 'Bessere Rekonstruktion',
        description: 'Machen Sie sichtbar, ob Statusverlauf und Rekonstruktion für Auswertung und Qualitätsverbesserung nutzbar sind.',
      },
      {
        title: 'Passung zur Praxis',
        description: 'Erkunden Sie, wie Velvoix zu Teams, Prozessen, Geräten und der bestehenden Umgebung passt.',
      },
    ],
    organisationTitle: 'Für Pflegeorganisationen',
    organisationBody: 'Fokus auf klarere Nachverfolgung, Arbeitsdruck und eine gute Passung im Pflegealltag.',
    partnerTitle: 'Für Partner',
    partnerBody: 'Fokus auf Rollout, Integration und operativen Mehrwert.',
  },
  es: {
    eyebrow: 'Piloto y colaboración',
    title: 'Explore si Velvoix encaja en su práctica asistencial',
    description:
      'Una primera exploración muestra si Velvoix aporta un seguimiento más claro, menos carga interpretativa y una mejor integración en sus procesos.',
    audience:
      'Relevante para organizaciones asistenciales, equipos y socios que quieran explorar un piloto, despliegue o integración.',
    primaryCta: 'Planificar una exploración',
    secondaryCta: 'Ponerse en contacto',
    moduleTitle: 'Una primera exploración analiza',
    rows: [
      {
        title: 'Ver antes qué requiere atención',
        description: 'Compruebe si los equipos pueden priorizar más rápido y qué situaciones exigen una acción inmediata.',
      },
      {
        title: 'Seguimiento más claro',
        description: 'Evalúe si la responsabilidad, el estado y la siguiente acción pueden organizarse con más calma.',
      },
      {
        title: 'Mejor reconstrucción',
        description: 'Haga visible si la evolución del estado y la reconstrucción resultan útiles para la evaluación y la mejora de la calidad.',
      },
      {
        title: 'Encaje con la práctica',
        description: 'Explore cómo encaja Velvoix con los equipos, los procesos, los dispositivos y el entorno existente.',
      },
    ],
    organisationTitle: 'Para organizaciones asistenciales',
    organisationBody: 'Enfoque en un seguimiento más claro, la presión asistencial y el encaje práctico en la atención diaria.',
    partnerTitle: 'Para socios',
    partnerBody: 'Enfoque en el alcance del despliegue, la integración y el valor operativo.',
  },
} satisfies Record<Locale, {
  eyebrow: string;
  title: string;
  description: string;
  audience: string;
  primaryCta: string;
  secondaryCta: string;
  moduleTitle: string;
  rows: Array<{ title: string; description: string }>;
  organisationTitle: string;
  organisationBody: string;
  partnerTitle: string;
  partnerBody: string;
}>;

const sectionContent = sectionContentByLocale[locale];
---

<section class="section-block surface-band-alt" id="pilot">
  <div class="section-shell">
    <div class="pilot-proposition grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="pilot-proposition__intro">
        <SectionIntro
          eyebrow={sectionContent.eyebrow}
          title={sectionContent.title}
          description={sectionContent.description}
        />

        <p class="pilot-proposition__audience">{sectionContent.audience}</p>

        <div class="pilot-proposition__actions">
          <a class="button-primary" href="#contact">{sectionContent.primaryCta}</a>
          <a class="button-secondary" href="#contact">{sectionContent.secondaryCta}</a>
        </div>
      </div>

      <aside class="pilot-evidence">
        <div class="pilot-evidence__head">
          <div class="pilot-evidence__eyebrow">{sectionContent.eyebrow}</div>
          <h3 class="pilot-evidence__title">{sectionContent.moduleTitle}</h3>
        </div>

        <div class="pilot-evidence__rows">
          {sectionContent.rows.map((row, index) => (
            <article class="pilot-evidence__row">
              <div class="pilot-evidence__index">{String(index + 1).padStart(2, '0')}</div>
              <div class="pilot-evidence__body">
                <h4>{row.title}</h4>
                <p>{row.description}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="pilot-evidence__split">
          <div class="pilot-evidence__splitrow">
            <div class="pilot-evidence__splitlabel">{sectionContent.organisationTitle}</div>
            <div class="pilot-evidence__splittext">{sectionContent.organisationBody}</div>
          </div>
          <div class="pilot-evidence__splitrow">
            <div class="pilot-evidence__splitlabel">{sectionContent.partnerTitle}</div>
            <div class="pilot-evidence__splittext">{sectionContent.partnerBody}</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  #pilot .pilot-proposition {
    padding: 2rem;
    border-radius: 2rem;
    border: 1px solid rgba(226, 232, 240, 0.86);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(245, 249, 252, 0.96));
    box-shadow: 0 18px 38px rgba(31, 53, 87, 0.07);
  }

  #pilot .pilot-proposition__intro {
    max-width: 34rem;
  }

  #pilot .pilot-proposition__audience {
    margin-top: 1.35rem;
    max-width: 32rem;
    font-size: 0.95rem;
    line-height: 1.72;
    color: rgb(71 85 105);
  }

  #pilot .pilot-proposition__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.7rem;
  }

  #pilot .pilot-evidence {
    border-radius: 1.5rem;
    border: 1px solid rgba(226, 232, 240, 0.88);
    background: rgba(255, 255, 255, 0.96);
    padding: 1.35rem;
    box-shadow: 0 14px 28px rgba(31, 53, 87, 0.05);
  }

  #pilot .pilot-evidence__head {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.82);
  }

  #pilot .pilot-evidence__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  #pilot .pilot-evidence__title {
    margin-top: 0.55rem;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
  }

  #pilot .pilot-evidence__rows {
    display: grid;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  #pilot .pilot-evidence__row {
    display: grid;
    grid-template-columns: 3.1rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
    padding: 0.95rem 0;
    border-top: 1px solid rgba(231, 236, 241, 0.9);
  }

  #pilot .pilot-evidence__row:first-child {
    border-top: 0;
    padding-top: 0.2rem;
  }

  #pilot .pilot-evidence__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border-radius: 0.8rem;
    border: 1px solid rgba(214, 223, 233, 0.96);
    background: rgba(248, 250, 252, 0.96);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: rgb(71 85 105);
  }

  #pilot .pilot-evidence__body h4 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgb(15 23 42);
  }

  #pilot .pilot-evidence__body p {
    margin-top: 0.34rem;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgb(71 85 105);
  }

  #pilot .pilot-evidence__split {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(226, 232, 240, 0.86);
  }

  #pilot .pilot-evidence__splitrow {
    display: grid;
    gap: 0.2rem;
  }

  #pilot .pilot-evidence__splitlabel {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  #pilot .pilot-evidence__splittext {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(71 85 105);
  }

  @media (max-width: 767px) {
    #pilot .pilot-proposition {
      padding: 1.2rem;
      border-radius: 1.5rem;
    }

    #pilot .pilot-evidence {
      padding: 1rem;
    }

    #pilot .pilot-evidence__row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    #pilot .pilot-evidence__index {
      width: fit-content;
      min-width: 2.6rem;
    }
  }
</style>
