---
import type { PilotContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: PilotContent;
}

const { content } = Astro.props;
---

<section class="section-block surface-band-alt" id="pilot">
  <div class="section-shell">
    <div class="rounded-[2.4rem] border border-slate-200/80 bg-white/82 p-6 shadow-[0_20px_42px_rgba(31,53,87,0.08)] md:p-10">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
          <div class="mt-7 space-y-3">
            {content.points.map((point) => (
              <div class="flex items-start gap-3 rounded-[1.3rem] border border-slate-200/80 bg-slate-50/80 px-4 py-4">
                <span class="mt-1.5 size-2 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                <span class="text-base font-semibold text-slate-700">{point}</span>
              </div>
            ))}
          </div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a class="button-primary" href="#contact">{content.primaryCta}</a>
            <a class="button-secondary" href="#contact">{content.secondaryCta}</a>
          </div>
        </div>

        <div class="relative overflow-hidden rounded-[2rem] border border-slate-200/70">
          <img
            src="/media/care-resident.jpg"
            alt="Care setting"
            class="absolute inset-0 h-full w-full object-cover"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-slate-950/72 via-slate-950/26 to-slate-900/68"></div>
          <div class="relative p-6 text-white md:p-8">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-sky-200">Pilot focus</p>
            <p class="mt-4 max-w-md text-lg font-semibold leading-8 text-white">
              {content.title}
            </p>
            <p class="mt-4 max-w-md text-sm leading-7 text-slate-200">
              {content.description}
            </p>
            <div class="mt-6 rounded-[1.4rem] border border-white/14 bg-white/8 px-5 py-4 backdrop-blur-sm">
              <p class="text-sm font-semibold text-white">
                {content.primaryCta}
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-200">
                {content.secondaryCta}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
