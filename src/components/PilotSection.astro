---
import type { Locale, PilotContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: PilotContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
      eyebrow: 'Pilot and partnership',
      title: 'Assess whether a pilot or partnership route fits',
      description:
        'Use this route to assess whether Velvoix fits a pilot, rollout or partnership discussion.',
      audience:
        'Relevant for healthcare organisations, care teams and partners exploring rollout or integration.',
      primaryCta: 'Start pilot assessment',
      secondaryCta: 'Discuss partnership route',
      moduleTitle: 'A pilot assessment looks at',
      rows: [
        {
          title: 'Operational clarity',
          description: 'See faster what needs attention, why that is the case and which follow-up fits.',
        },
        {
          title: 'Workable follow-up',
          description: 'Organise ownership, status and next action more clearly.',
        },
        {
          title: 'Reconstruction and evaluation',
          description: 'Use status flow and reconstruction for quality improvement.',
        },
        {
          title: 'Integration and rollout',
          description: 'Explore fit with teams, processes, devices and the existing environment.',
        },
      ],
      organisationTitle: 'For healthcare organisations',
      organisationBody: 'Focus on operational relevance, work pressure and follow-up in care practice.',
      partnerTitle: 'For partners',
      partnerBody: 'Focus on rollout scope, integration approach and operational value.',
    },
  nl: {
      eyebrow: 'Pilot en samenwerking',
      title: 'Toets of een pilot- of samenwerkingsroute past',
      description:
        'Gebruik deze route om te toetsen of Velvoix past bij een pilot, uitrolverkenning of samenwerkingsgesprek.',
      audience:
        'Relevant voor zorgorganisaties, zorgteams en partners die uitrol of integratie willen verkennen.',
      primaryCta: 'Start pilotverkenning',
      secondaryCta: 'Bespreek samenwerkingsroute',
      moduleTitle: 'Een pilotverkenning kijkt naar',
      rows: [
        {
          title: 'Operationele duidelijkheid',
          description: 'Sneller zien wat aandacht vraagt, waarom dat zo is en welke opvolging past.',
        },
        {
          title: 'Werkbare opvolging',
          description: 'Eigenaarschap, status en vervolgactie beter organiseren.',
        },
        {
          title: 'Reconstructie en evaluatie',
          description: 'Statusverloop en reconstructie bruikbaar maken voor kwaliteitsverbetering.',
        },
        {
          title: 'Inpasbaarheid',
          description: 'Verkennen hoe Velvoix past bij teams, processen, devices en bestaande omgeving.',
        },
      ],
      organisationTitle: 'Voor zorgorganisaties',
      organisationBody: 'Focus op operationele relevantie, werkdruk en opvolging in de zorgpraktijk.',
      partnerTitle: 'Voor partners',
      partnerBody: 'Focus op uitrolscope, integratieaanpak en operationele meerwaarde.',
    },
  de: {
      eyebrow: 'Pilot und Zusammenarbeit',
      title: 'Prüfen, ob ein Pilot- oder Kooperationsweg passt',
      description:
        'Nutzen Sie diesen Weg, um zu prüfen, ob Velvoix zu einem Pilot, Rollout oder Kooperationsgespräch passt.',
      audience:
        'Relevant für Pflegeorganisationen, Pflegeteams und Partner, die Rollout oder Integration prüfen wollen.',
      primaryCta: 'Pilotprüfung starten',
      secondaryCta: 'Kooperationsweg besprechen',
      moduleTitle: 'Eine Pilotprüfung betrachtet',
      rows: [
        {
          title: 'Operative Klarheit',
          description: 'Schneller sehen, was Aufmerksamkeit braucht, warum das so ist und welche Folgeaktion passt.',
        },
        {
          title: 'Handhabbare Nachverfolgung',
          description: 'Verantwortung, Status und nächste Maßnahme klarer organisieren.',
        },
        {
          title: 'Rekonstruktion und Auswertung',
          description: 'Statusverlauf und Rekonstruktion für Qualitätsverbesserung nutzbar machen.',
        },
        {
          title: 'Integration und Rollout',
          description: 'Prüfen, wie Velvoix zu Teams, Prozessen, Geräten und der bestehenden Umgebung passt.',
        },
      ],
      organisationTitle: 'Für Pflegeorganisationen',
      organisationBody: 'Fokus auf operative Relevanz, Arbeitsdruck und Nachverfolgung in der Pflegepraxis.',
      partnerTitle: 'Für Partner',
      partnerBody: 'Fokus auf Rollout-Umfang, Integrationsansatz und operativen Mehrwert.',
    },
  es: {
      eyebrow: 'Piloto y colaboración',
      title: 'Evalúe si una ruta de piloto o colaboración encaja',
      description:
        'Utilice esta vía para comprobar si Velvoix encaja en un piloto, despliegue o conversación de colaboración.',
      audience:
        'Relevante para organizaciones asistenciales, equipos y socios que quieran explorar despliegue o integración.',
      primaryCta: 'Iniciar exploración piloto',
      secondaryCta: 'Tratar ruta de colaboración',
      moduleTitle: 'Una exploración piloto mira',
      rows: [
        {
          title: 'Claridad operativa',
          description: 'Ver antes qué requiere atención, por qué ocurre y qué seguimiento encaja.',
        },
        {
          title: 'Seguimiento claro',
          description: 'Organizar mejor la titularidad, el estado y la siguiente acción.',
        },
        {
          title: 'Reconstrucción y evaluación',
          description: 'Hacer utilizables la evolución del estado y la reconstrucción para mejorar calidad.',
        },
        {
          title: 'Integración y despliegue',
          description: 'Explorar cómo Velvoix encaja con equipos, procesos, dispositivos y el entorno existente.',
        },
      ],
      organisationTitle: 'Para organizaciones asistenciales',
      organisationBody: 'Foco en relevancia operativa, carga de trabajo y seguimiento en la práctica asistencial.',
      partnerTitle: 'Para socios',
      partnerBody: 'Foco en alcance de despliegue, integración y valor operativo.',
    },
} satisfies Record<Locale, {
  eyebrow: string;
  title: string;
  description: string;
  audience: string;
  primaryCta: string;
  secondaryCta: string;
  moduleTitle: string;
  rows: Array<{ title: string; description: string }>;
  organisationTitle: string;
  organisationBody: string;
  partnerTitle: string;
  partnerBody: string;
}>;

const sectionContent = sectionContentByLocale[locale];
---

<section class="section-block surface-band-alt" id="pilot">
  <div class="section-shell">
    <div class="pilot-proposition grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="pilot-proposition__intro">
        <SectionIntro
          eyebrow={sectionContent.eyebrow}
          title={sectionContent.title}
          description={sectionContent.description}
        />

        <p class="pilot-proposition__audience">{sectionContent.audience}</p>

        <div class="pilot-proposition__actions">
          <a class="button-primary" href="#contact">{sectionContent.primaryCta}</a>
          <a class="button-secondary" href="#contact">{sectionContent.secondaryCta}</a>
        </div>
      </div>

      <aside class="pilot-evidence">
        <div class="pilot-evidence__head">
          <div class="pilot-evidence__eyebrow">{sectionContent.eyebrow}</div>
          <h3 class="pilot-evidence__title">{sectionContent.moduleTitle}</h3>
        </div>

        <div class="pilot-evidence__rows">
          {sectionContent.rows.map((row, index) => (
            <article class="pilot-evidence__row">
              <div class="pilot-evidence__index">{String(index + 1).padStart(2, '0')}</div>
              <div class="pilot-evidence__body">
                <h4>{row.title}</h4>
                <p>{row.description}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="pilot-evidence__split">
          <div class="pilot-evidence__splitrow">
            <div class="pilot-evidence__splitlabel">{sectionContent.organisationTitle}</div>
            <div class="pilot-evidence__splittext">{sectionContent.organisationBody}</div>
          </div>
          <div class="pilot-evidence__splitrow">
            <div class="pilot-evidence__splitlabel">{sectionContent.partnerTitle}</div>
            <div class="pilot-evidence__splittext">{sectionContent.partnerBody}</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  #pilot .pilot-proposition {
    padding: 2rem;
    border-radius: 2rem;
    border: 1px solid rgba(226, 232, 240, 0.86);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(245, 249, 252, 0.96));
    box-shadow: 0 18px 38px rgba(31, 53, 87, 0.07);
  }

  #pilot .pilot-proposition__intro {
    max-width: 34rem;
  }

  #pilot .pilot-proposition__audience {
    margin-top: 1.35rem;
    max-width: 32rem;
    font-size: 0.95rem;
    line-height: 1.72;
    color: rgb(71 85 105);
  }

  #pilot .pilot-proposition__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.7rem;
  }

  #pilot .pilot-evidence {
    border-radius: 1.5rem;
    border: 1px solid rgba(226, 232, 240, 0.88);
    background: rgba(255, 255, 255, 0.96);
    padding: 1.35rem;
    box-shadow: 0 14px 28px rgba(31, 53, 87, 0.05);
  }

  #pilot .pilot-evidence__head {
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.82);
  }

  #pilot .pilot-evidence__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  #pilot .pilot-evidence__title {
    margin-top: 0.55rem;
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
  }

  #pilot .pilot-evidence__rows {
    display: grid;
    gap: 0.9rem;
    margin-top: 1rem;
  }

  #pilot .pilot-evidence__row {
    display: grid;
    grid-template-columns: 3.1rem minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
    padding: 0.95rem 0;
    border-top: 1px solid rgba(231, 236, 241, 0.9);
  }

  #pilot .pilot-evidence__row:first-child {
    border-top: 0;
    padding-top: 0.2rem;
  }

  #pilot .pilot-evidence__index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border-radius: 0.8rem;
    border: 1px solid rgba(214, 223, 233, 0.96);
    background: rgba(248, 250, 252, 0.96);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: rgb(71 85 105);
  }

  #pilot .pilot-evidence__body h4 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgb(15 23 42);
  }

  #pilot .pilot-evidence__body p {
    margin-top: 0.34rem;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgb(71 85 105);
  }

  #pilot .pilot-evidence__split {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.2rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(226, 232, 240, 0.86);
  }

  #pilot .pilot-evidence__splitrow {
    display: grid;
    gap: 0.2rem;
  }

  #pilot .pilot-evidence__splitlabel {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  #pilot .pilot-evidence__splittext {
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(71 85 105);
  }

  @media (max-width: 767px) {
    #pilot .pilot-proposition {
      padding: 1.2rem;
      border-radius: 1.5rem;
    }

    #pilot .pilot-evidence {
      padding: 1rem;
    }

    #pilot .pilot-evidence__row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
    }

    #pilot .pilot-evidence__index {
      width: fit-content;
      min-width: 2.6rem;
    }
  }
</style>


