---
import type { HowItWorksContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: HowItWorksContent;
}

const { content } = Astro.props;
---

<section class="section-block">
  <div class="section-shell">
    <div class="rounded-[2.6rem] bg-[linear-gradient(180deg,rgba(240,246,249,0.94),rgba(233,241,246,0.94))] p-6 md:p-10">
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />

      <div class="mt-10 grid gap-5 lg:grid-cols-[0.88fr_1.12fr]">
        <div class="rounded-[2rem] bg-[linear-gradient(180deg,#183053_0%,#13263f_100%)] p-6 text-white md:p-8">
          <p class="text-xs font-bold uppercase tracking-[0.24em] text-sky-200">{content.panelLabel}</p>
          <p class="mt-4 text-3xl font-extrabold tracking-tight">
            {content.steps[0]?.title} -> {content.steps[1]?.title} -> {content.steps[2]?.title} -> {content.steps[3]?.title}
          </p>
          <p class="mt-5 max-w-md text-base leading-7 text-slate-200">{content.panelSupporting}</p>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          {content.steps.map((step, index) => (
            <article class="panel rounded-[1.8rem] p-6">
              <p class="eyebrow">0{index + 1}</p>
              <h3 class="mt-4 text-xl font-extrabold tracking-tight text-slate-950">{step.title}</h3>
              <p class="mt-4 text-base leading-7 text-slate-600">{step.description}</p>
              <div class="mt-5 rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700">
                {content.stepNotes[index]}
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
