---
import type { HowItWorksContent, Locale } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: HowItWorksContent;
}

const { locale, content } = Astro.props;

const sectionContentByLocale = {
  en: {
    eyebrow: 'How it works',
    title: 'From signal to a clear next action',
