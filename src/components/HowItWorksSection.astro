---
import type { HowItWorksContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: HowItWorksContent;
}

const { content } = Astro.props;
---

<section class="section-block">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-start">
    <div class="max-w-[32rem]">
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />

      <div class="mt-7 space-y-3">
        {content.steps.map((step, index) => (
          <div class="flex items-center gap-3 text-sm font-semibold text-slate-700">
            <span class="flex size-6 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-[0.72rem] font-bold text-slate-500">
              {index + 1}
            </span>
            <span>{step.title}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="rounded-[2.2rem] border border-slate-200/80 bg-[linear-gradient(180deg,rgba(248,250,252,0.98),rgba(240,246,249,0.92))] p-6 shadow-[0_18px_36px_rgba(31,53,87,0.06)] md:p-8">
      <div class="space-y-5">
        {content.steps.map((step, index) => (
          <div class="relative pl-9">
            {index < content.steps.length - 1 && (
              <span class="absolute left-[0.68rem] top-7 h-[calc(100%+0.8rem)] w-px bg-[linear-gradient(180deg,rgba(25,130,121,0.28),rgba(31,53,87,0.08))]"></span>
            )}
            <span class="absolute left-0 top-1.5 size-3 rounded-full bg-[var(--vx-accent)] ring-4 ring-[rgba(25,130,121,0.08)]"></span>
            <div class="rounded-[1.35rem] border border-slate-200/75 bg-white/92 px-5 py-4 shadow-[0_10px_22px_rgba(31,53,87,0.04)]">
              <div class="flex items-baseline gap-3">
                <p class="text-base font-bold tracking-tight text-slate-950">{step.title}</p>
                <p class="text-[0.7rem] font-bold uppercase tracking-[0.16em] text-slate-400">0{index + 1}</p>
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-600">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
