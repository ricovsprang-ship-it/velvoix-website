---
import type { CompareChainsContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: CompareChainsContent;
}

const { content } = Astro.props;
---

<section class="section-block surface-band" id="how-it-works" data-chain-block>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
    <div class="max-w-[32rem] chain-intro" data-chain-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div class="chain-compare rounded-[1.85rem] border border-slate-200/80 bg-white/92 p-6 shadow-[0_18px_36px_rgba(31,53,87,0.06)] md:p-7" data-chain-compare>
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.compareLabel}</p>

      <div class="mt-5 space-y-4">
        <div class="chain-row chain-row-traditional rounded-[1.15rem] border border-slate-200/90 bg-slate-50/80 px-4 py-4" data-chain-row="traditional">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="shrink-0 lg:w-[10rem]">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.traditionalTitle}</p>
            </div>

            <div class="chain-track chain-track-traditional flex min-w-0 flex-1 flex-wrap items-center gap-2.5">
              {content.traditionalSteps.map((step, index) => (
                <>
                  <div class="chain-module chain-module-traditional">
                    {step}
                  </div>
                  {index < content.traditionalSteps.length - 1 && (
                    <span class="chain-arrow chain-arrow-traditional" aria-hidden="true">→</span>
                  )}
                </>
              ))}
            </div>
          </div>
        </div>

        <div class="chain-row chain-row-velvoix rounded-[1.35rem] border border-[rgba(31,53,87,0.13)] bg-[linear-gradient(180deg,rgba(236,242,246,0.98),rgba(246,249,252,0.99))] px-4 py-4 shadow-[0_16px_32px_rgba(31,53,87,0.055)] md:px-5 md:py-5" data-chain-row="velvoix">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="shrink-0 lg:w-[10rem]">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.velvoixTitle}</p>
            </div>

            <div class="min-w-0 flex-1 space-y-4">
              <div class="chain-flow relative grid gap-3.5" data-chain-flow>
                <span class="chain-flow-line hidden md:block" aria-hidden="true" data-chain-flow-line></span>

                <div class="chain-rail chain-rail-primary">
                  {content.velvoixSteps.slice(0, 4).map((step, index) => (
                    <>
                    <button
                      type="button"
                      class="chain-node chain-module chain-module-velvoix"
                      data-chain-node
                      data-chain-node-index={index}
                      data-chain-step-title={content.stepDetails[index]?.title}
                      data-chain-step-description={content.stepDetails[index]?.description}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                      aria-controls="chain-step-detail"
                    >
                        <span class="chain-node-label">{step}</span>
                      </button>
                      {index < 3 && (
                        <span class="chain-arrow chain-arrow-velvoix" data-chain-arrow aria-hidden="true">
                          <span class="chain-arrow-line"></span>
                        </span>
                      )}
                    </>
                  ))}
                </div>

                <div class="chain-rail chain-rail-secondary">
                  {content.velvoixSteps.slice(4).map((step, railIndex) => {
                    const index = railIndex + 4;
                    return (
                      <>
                        <button
                          type="button"
                          class="chain-node chain-module chain-module-velvoix"
                          data-chain-node
                          data-chain-node-index={index}
                          data-chain-step-title={content.stepDetails[index]?.title}
                          data-chain-step-description={content.stepDetails[index]?.description}
                          aria-pressed="false"
                          aria-controls="chain-step-detail"
                        >
                          <span class="chain-node-label">{step}</span>
                        </button>
                        {railIndex < 2 && (
                          <span class="chain-arrow chain-arrow-velvoix" data-chain-arrow aria-hidden="true">
                            <span class="chain-arrow-line"></span>
                          </span>
                        )}
                      </>
                    );
                  })}
                </div>

                <span class="chain-highlight hidden md:block" aria-hidden="true" data-chain-highlight></span>
              </div>

              <p class="max-w-[42rem] text-sm leading-6 text-slate-600">{content.velvoixSupporting}</p>

              <div
                id="chain-step-detail"
                class="chain-detail border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.9),rgba(248,250,252,0.95))] px-4 py-3.5"
                data-chain-detail
                aria-live="polite"
              >
                <div class="flex items-start gap-3">
                  <span class="mt-1.5 size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                  <div class="min-w-0">
                    <p class="chain-detail-title text-[0.84rem] font-semibold uppercase tracking-[0.12em] text-slate-700" data-chain-detail-title-target>
                      {content.stepDetails[0]?.title}
                    </p>
                    <p class="chain-detail-description mt-2 text-sm leading-6 text-slate-600" data-chain-detail-description-target>
                      {content.stepDetails[0]?.description}
                    </p>
                  </div>
                </div>
              </div>

              <div class="chain-results grid gap-2.5 md:grid-cols-3" data-chain-results>
                {content.outcomes.map((outcome) => (
                  <div class="chain-result-item flex items-center gap-2.5 border-t border-slate-200/90 pt-2 text-[0.84rem] font-medium text-slate-700" data-chain-result>
                    <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                    <span>{outcome}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  [data-chain-block] .chain-compare {
    position: relative;
  }

  [data-chain-block] .chain-module {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    border: 1px solid rgba(31, 53, 87, 0.1);
    background: rgba(255, 255, 255, 0.94);
    padding: 0.7rem 0.95rem;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.25;
    color: rgb(30 41 59);
    box-shadow: 0 6px 16px rgba(31, 53, 87, 0.045);
  }

  [data-chain-block] .chain-module-traditional {
    min-height: 2.55rem;
    border-radius: 0.8rem;
    border-color: rgba(203, 213, 225, 0.95);
    background: rgba(255, 255, 255, 0.88);
    padding-inline: 0.9rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: rgb(71 85 105);
    box-shadow: none;
  }

  [data-chain-block] .chain-module-velvoix {
    width: 100%;
    justify-content: flex-start;
    border-radius: 0.95rem;
    border-color: rgba(31, 53, 87, 0.12);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 250, 252, 0.98));
    padding: 0.82rem 0.95rem;
    text-align: left;
  }

  [data-chain-block] .chain-rail {
    display: grid;
    align-items: center;
    gap: 0.7rem;
  }

  [data-chain-block] .chain-rail-primary {
    grid-template-columns: minmax(0, 1fr) 1.2rem minmax(0, 1fr) 1.2rem minmax(0, 1fr) 1.2rem minmax(0, 1fr);
  }

  [data-chain-block] .chain-rail-secondary {
    grid-template-columns: minmax(0, 1fr) 1.2rem minmax(0, 1fr) 1.2rem minmax(0, 1fr);
  }

  [data-chain-block] .chain-flow {
    isolation: isolate;
  }

  [data-chain-block] .chain-row-traditional {
    opacity: 0.82;
  }

  [data-chain-block] .chain-flow-line {
    position: absolute;
    left: 0.8rem;
    right: 0.8rem;
    top: 2.45rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(25, 130, 121, 0.1), rgba(31, 53, 87, 0.14), rgba(31, 53, 87, 0.08));
    z-index: -2;
  }

  [data-chain-block] .chain-highlight {
    position: absolute;
    left: 0.8rem;
    top: 2.45rem;
    width: 6rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(25, 130, 121, 0), rgba(25, 130, 121, 0.34), rgba(25, 130, 121, 0));
    z-index: -1;
    pointer-events: none;
  }

  [data-chain-block] .chain-node {
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease,
      transform 180ms ease;
    cursor: pointer;
  }

  [data-chain-block] .chain-node[aria-pressed='true'] {
    border-color: rgba(25, 130, 121, 0.34);
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 10px 22px rgba(31, 53, 87, 0.08);
  }

  [data-chain-block] .chain-node:is(:hover, :focus-visible) {
    background: rgba(255, 255, 255, 1);
    border-color: rgba(25, 130, 121, 0.26);
    box-shadow: 0 9px 20px rgba(31, 53, 87, 0.075);
    color: rgb(15 23 42);
    transform: translateY(-1px);
  }

  [data-chain-block] .chain-node:focus-visible {
    outline: 2px solid rgba(25, 130, 121, 0.22);
    outline-offset: 2px;
  }

  [data-chain-block] .chain-node-label {
    display: block;
  }

  [data-chain-block] .chain-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  [data-chain-block] .chain-arrow-traditional {
    font-size: 0.9rem;
    font-weight: 500;
    color: rgb(148 163 184);
  }

  [data-chain-block] .chain-arrow-velvoix {
    width: 100%;
  }

  [data-chain-block] .chain-arrow-line {
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.55), rgba(148, 163, 184, 0.18));
  }

  [data-chain-block] .chain-detail {
    min-height: 5.8rem;
    border-radius: 0.95rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  [data-chain-block] .chain-results {
    align-items: start;
  }

  [data-chain-block] .chain-result-item {
    min-height: 2.2rem;
  }

  @media (max-width: 1023px) {
    [data-chain-block] .chain-rail-primary,
    [data-chain-block] .chain-rail-secondary {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }

    [data-chain-block] .chain-arrow-velvoix {
      display: none;
    }

    [data-chain-block] .chain-flow-line,
    [data-chain-block] .chain-highlight {
      display: none;
    }
  }

  @media (max-width: 767px) {
    [data-chain-block] .chain-track-traditional {
      gap: 0.55rem;
    }

    [data-chain-block] .chain-module-traditional {
      width: 100%;
      justify-content: flex-start;
    }

    [data-chain-block] .chain-arrow-traditional {
      display: none;
    }

    [data-chain-block] .chain-results {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chainBlocks = document.querySelectorAll('[data-chain-block]');

  for (const block of chainBlocks) {
    if (block instanceof HTMLElement === false) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector('[data-chain-intro]');
    const compare = block.querySelector('[data-chain-compare]');
    const traditionalRow = block.querySelector('[data-chain-row="traditional"]');
    const velvoixRow = block.querySelector('[data-chain-row="velvoix"]');
    const flowLine = block.querySelector('[data-chain-flow-line]');
    const highlight = block.querySelector('[data-chain-highlight]');
    const detail = block.querySelector<HTMLElement>('[data-chain-detail]');
    const detailTitle = block.querySelector<HTMLElement>('[data-chain-detail-title-target]');
    const detailDescription = block.querySelector<HTMLElement>('[data-chain-detail-description-target]');
    const nodes = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-node]'));
    const arrows = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-arrow]'));
    const results = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-result]'));

    if (prefersReducedMotion) {
      gsap.set([intro, compare, traditionalRow, velvoixRow, flowLine, highlight, nodes, arrows, results, detail], {
        clearProps: 'all',
      });
    }

    const updateActiveStep = (index: number) => {
      const activeNode = nodes[index];
      if (!activeNode || !detailTitle || !detailDescription || !detail) return;

      for (const [nodeIndex, node] of nodes.entries()) {
        node.setAttribute('aria-pressed', nodeIndex === index ? 'true' : 'false');
      }

      const nextTitle = activeNode.dataset.chainStepTitle ?? activeNode.textContent?.trim() ?? '';
      const nextDescription = activeNode.dataset.chainStepDescription ?? '';

      if (prefersReducedMotion) {
        detailTitle.textContent = nextTitle;
        detailDescription.textContent = nextDescription;
        return;
      }

      gsap.killTweensOf([detailTitle, detailDescription, detail]);
      gsap
        .timeline({ defaults: { ease: 'power2.out' } })
        .to([detailTitle, detailDescription], { autoAlpha: 0, y: 4, duration: 0.14 })
        .add(() => {
          detailTitle.textContent = nextTitle;
          detailDescription.textContent = nextDescription;
        })
        .to(detail, { borderColor: 'rgba(25, 130, 121, 0.18)', duration: 0.18 }, '<')
        .to([detailTitle, detailDescription], { autoAlpha: 1, y: 0, duration: 0.18 })
        .to(detail, { borderColor: 'rgba(226, 232, 240, 0.8)', duration: 0.22 }, '-=0.02');
    };

    for (const [index, node] of nodes.entries()) {
      node.addEventListener('mouseenter', () => updateActiveStep(index));
      node.addEventListener('focus', () => updateActiveStep(index));
      node.addEventListener('click', () => updateActiveStep(index));
    }

    if (!prefersReducedMotion) {
      gsap.set([intro, compare], { autoAlpha: 0, y: 18 });
      gsap.set(traditionalRow, { autoAlpha: 0, y: 12 });
      gsap.set(velvoixRow, { autoAlpha: 1 });
      gsap.set(nodes, { autoAlpha: 0, y: 8, scale: 0.985 });
      gsap.set(arrows, { autoAlpha: 0, y: 4 });
      gsap.set(flowLine, { autoAlpha: 0, scaleX: 0.36, transformOrigin: 'left center' });
      gsap.set(highlight, { autoAlpha: 0, x: -16 });
      gsap.set(results, { autoAlpha: 0, y: 10 });

      const timeline = gsap.timeline({
        defaults: { ease: 'power2.out' },
        scrollTrigger: {
          trigger: block,
          start: 'top 72%',
          once: true,
        },
      });

      timeline
        .to(intro, { autoAlpha: 1, y: 0, duration: 0.52 })
        .to(compare, { autoAlpha: 1, y: 0, duration: 0.56 }, '-=0.32')
        .to(traditionalRow, { autoAlpha: 0.84, y: 0, duration: 0.46 }, '-=0.18')
        .to(
          nodes,
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            duration: 0.34,
            stagger: 0.1,
          },
          '-=0.02'
        )
        .to(
          arrows,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.22,
            stagger: 0.1,
          },
          '<0.08'
        )
        .to(flowLine, { autoAlpha: 1, scaleX: 1, duration: 0.5 }, '-=0.38')
        .to(highlight, { autoAlpha: 0.95, x: 452, duration: 0.78, ease: 'power1.inOut' })
        .to(highlight, { autoAlpha: 0, duration: 0.12 }, '-=0.08')
        .to(
          results,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.28,
            stagger: 0.08,
          },
          '-=0.02'
        );
    }

    updateActiveStep(0);
  }
</script>
