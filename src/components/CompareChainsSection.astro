---
import type { CompareChainsContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: CompareChainsContent;
}

const { content } = Astro.props;
const highlightedDetail = content.stepDetails[1] ?? content.stepDetails[0];
const firstRail = content.velvoixSteps.slice(0, 4);
const secondRail = content.velvoixSteps.slice(4, 6);
const finalStep = content.velvoixSteps[6];
---

<section class="section-block surface-band" id="how-it-works" data-chain-block>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
    <div class="max-w-[32rem]" data-chain-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div
      class="chain-compare rounded-[1.85rem] border border-slate-200/76 bg-white/94 p-6 shadow-[0_18px_36px_rgba(31,53,87,0.055)] md:p-7"
      data-chain-compare
    >
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.compareLabel}</p>

      <div class="mt-5 space-y-4">
        <article
          class="chain-panel chain-panel-traditional rounded-[1.25rem] border border-slate-200/84 bg-slate-50/84 p-4 md:p-5"
          data-chain-panel
        >
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.traditionalTitle}</p>

          <div class="chain-grid chain-grid-traditional mt-4" data-chain-grid-traditional>
            {content.traditionalSteps.map((step, index) => (
              <>
                <article class="chain-step chain-step-traditional" data-chain-step>
                  <h3 class="chain-step-label">{step}</h3>
                </article>
                {index < content.traditionalSteps.length - 1 && (
                  <span class="chain-connector chain-connector-traditional" aria-hidden="true"></span>
                )}
              </>
            ))}
          </div>
        </article>

        <article
          class="chain-panel chain-panel-velvoix rounded-[1.4rem] border border-[rgba(31,53,87,0.11)] bg-[linear-gradient(180deg,rgba(236,242,246,0.98),rgba(246,249,252,0.99))] p-5 shadow-[0_16px_30px_rgba(31,53,87,0.045)] md:p-6"
          data-chain-panel
        >
          <div class="space-y-2.5">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.velvoixTitle}</p>
            <p class="max-w-[45rem] text-sm leading-6 text-slate-600">{content.velvoixSupporting}</p>
          </div>

          <div class="chain-system mt-5" data-chain-system>
            <div class="chain-rail chain-rail-primary" data-chain-rail>
              {firstRail.map((step, index) => (
                <>
                  <article
                    class:list={['chain-step chain-step-velvoix', index === 1 && 'is-highlighted']}
                    data-chain-step
                  >
                    <h3 class="chain-step-label">{step}</h3>
                  </article>
                  {index < firstRail.length - 1 && <span class="chain-connector" aria-hidden="true"></span>}
                </>
              ))}
            </div>

            <div class="chain-rail chain-rail-secondary" data-chain-rail>
              {secondRail.map((step, index) => (
                <>
                  <article class="chain-step chain-step-velvoix" data-chain-step>
                    <h3 class="chain-step-label">{step}</h3>
                  </article>
                  {index < secondRail.length - 1 && <span class="chain-connector" aria-hidden="true"></span>}
                </>
              ))}
            </div>

            <div class="chain-rail chain-rail-final" data-chain-rail>
              <article class="chain-step chain-step-velvoix chain-step-final" data-chain-step>
                <h3 class="chain-step-label">{finalStep}</h3>
              </article>
            </div>
          </div>

          <div
            class="chain-context-note mt-5 border-l border-[rgba(25,130,121,0.2)] pl-4"
            data-chain-context
          >
            <p class="chain-context-note__eyebrow">{highlightedDetail.title}</p>
            <p class="chain-context-note__text">{highlightedDetail.description}</p>
          </div>

          <div class="chain-results mt-5" data-chain-results>
            {content.outcomes.map((outcome) => (
              <div class="chain-result-item" data-chain-result>
                <span class="chain-result-dot" aria-hidden="true"></span>
                <span>{outcome}</span>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  [data-chain-block] .chain-panel {
    position: relative;
  }

  [data-chain-block] .chain-grid,
  [data-chain-block] .chain-rail {
    display: grid;
    gap: 0.8rem;
    align-items: stretch;
  }

  [data-chain-block] .chain-grid-traditional {
    grid-template-columns: minmax(0, 1fr) 0.9rem minmax(0, 1fr) 0.9rem minmax(0, 1fr);
  }

  [data-chain-block] .chain-system {
    display: grid;
    gap: 0.8rem;
  }

  [data-chain-block] .chain-rail-primary {
    grid-template-columns: minmax(0, 1fr) 0.9rem minmax(0, 1fr) 0.9rem minmax(0, 1fr) 0.9rem minmax(0, 1fr);
  }

  [data-chain-block] .chain-rail-secondary {
    grid-template-columns: 1.1fr 0.9rem 1.1fr 1fr;
  }

  [data-chain-block] .chain-rail-final {
    grid-template-columns: 1fr minmax(0, 1.1fr);
  }

  [data-chain-block] .chain-step {
    display: grid;
    align-items: center;
    min-height: 4.6rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(214, 223, 233, 0.9);
    padding: 0.95rem 1rem;
  }

  [data-chain-block] .chain-step-traditional {
    background: rgba(255, 255, 255, 0.88);
  }

  [data-chain-block] .chain-step-velvoix {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 250, 252, 0.96));
  }

  [data-chain-block] .chain-step-velvoix.is-highlighted {
    border-color: rgba(25, 130, 121, 0.18);
    background: linear-gradient(180deg, rgba(242, 249, 247, 0.96), rgba(255, 255, 255, 0.96));
  }

  [data-chain-block] .chain-step-final {
    grid-column: 2;
  }

  [data-chain-block] .chain-step-label {
    font-size: 0.94rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgb(15 23 42);
    text-wrap: balance;
  }

  [data-chain-block] .chain-connector {
    position: relative;
    display: block;
    align-self: center;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.46), rgba(148, 163, 184, 0.14));
  }

  [data-chain-block] .chain-connector::after {
    content: '';
    position: absolute;
    right: -0.02rem;
    top: 50%;
    width: 0.4rem;
    height: 0.4rem;
    border-top: 1px solid rgba(148, 163, 184, 0.46);
    border-right: 1px solid rgba(148, 163, 184, 0.46);
    transform: translateY(-50%) rotate(45deg);
  }

  [data-chain-block] .chain-context-note {
    display: grid;
    gap: 0.35rem;
  }

  [data-chain-block] .chain-context-note__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  [data-chain-block] .chain-context-note__text {
    max-width: 40rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(71 85 105);
    text-wrap: pretty;
  }

  [data-chain-block] .chain-results {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem 1.2rem;
    border-top: 1px solid rgba(226, 232, 240, 0.82);
    padding-top: 1rem;
  }

  [data-chain-block] .chain-result-item {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 1.6rem;
    font-size: 0.86rem;
    font-weight: 600;
    color: rgb(71 85 105);
  }

  [data-chain-block] .chain-result-dot {
    width: 0.38rem;
    height: 0.38rem;
    border-radius: 999px;
    background: var(--vx-accent);
    box-shadow: 0 0 0 4px rgba(25, 130, 121, 0.1);
  }

  @media (max-width: 1180px) {
    [data-chain-block] .chain-rail-primary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-chain-block] .chain-rail-secondary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-chain-block] .chain-rail-final {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-chain-block] .chain-step-final {
      grid-column: auto;
    }

    [data-chain-block] .chain-connector {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    [data-chain-block] .chain-grid-traditional {
      grid-template-columns: 1fr;
    }

    [data-chain-block] .chain-results {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.7rem;
    }
  }

  @media (max-width: 767px) {
    [data-chain-block] .chain-rail-primary,
    [data-chain-block] .chain-rail-secondary,
    [data-chain-block] .chain-rail-final {
      grid-template-columns: 1fr;
    }

    [data-chain-block] .chain-step {
      min-height: auto;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chainBlocks = document.querySelectorAll('[data-chain-block]');

  for (const block of chainBlocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector<HTMLElement>('[data-chain-intro]');
    const compare = block.querySelector<HTMLElement>('[data-chain-compare]');
    const panels = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-panel]'));
    const rails = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-rail]'));
    const steps = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-step]'));
    const context = block.querySelector<HTMLElement>('[data-chain-context]');
    const results = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-result]'));

    if (prefersReducedMotion) {
      gsap.set([intro, compare, ...panels, ...rails, ...steps, context, ...results], { clearProps: 'all' });
      continue;
    }

    gsap.set([intro, compare], { autoAlpha: 0, y: 18 });
    gsap.set(panels, { autoAlpha: 0, y: 14 });
    gsap.set(rails, { autoAlpha: 0, y: 10 });
    gsap.set(steps, { autoAlpha: 0, y: 10 });
    gsap.set(context, { autoAlpha: 0, y: 10 });
    gsap.set(results, { autoAlpha: 0, y: 10 });

    gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: {
        trigger: block,
        start: 'top 72%',
        once: true,
      },
      onComplete: () => {
        gsap.set([intro, compare, ...panels, ...rails, ...steps, context, ...results], {
          clearProps: 'opacity,visibility,transform',
        });
      },
    })
      .to(intro, { autoAlpha: 1, y: 0, duration: 0.48 })
      .to(compare, { autoAlpha: 1, y: 0, duration: 0.5 }, '-=0.28')
      .to(panels, { autoAlpha: 1, y: 0, duration: 0.32, stagger: 0.1 }, '-=0.16')
      .to(rails, { autoAlpha: 1, y: 0, duration: 0.26, stagger: 0.08 }, '-=0.12')
      .to(steps, { autoAlpha: 1, y: 0, duration: 0.24, stagger: 0.04 }, '-=0.16')
      .to(context, { autoAlpha: 1, y: 0, duration: 0.22 }, '-=0.1')
      .to(results, { autoAlpha: 1, y: 0, duration: 0.22, stagger: 0.06 }, '-=0.08');
  }
</script>
