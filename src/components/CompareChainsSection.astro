---
import type { CompareChainsContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: CompareChainsContent;
}

const { content } = Astro.props;
const highlightedDetail = content.stepDetails[1] ?? content.stepDetails[0];
const primaryFlow = content.velvoixSteps.slice(0, 4);
const secondaryFlow = content.velvoixSteps.slice(4);
---

<section class="section-block surface-band" id="how-it-works" data-chain-block>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
    <div class="max-w-[31rem]" data-chain-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div
      class="chain-compare rounded-[1.95rem] border border-slate-200/75 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(244,248,251,0.94))] p-6 shadow-[0_22px_42px_rgba(31,53,87,0.065)] md:p-7"
      data-chain-compare
    >
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.compareLabel}</p>

      <div class="mt-5 space-y-4">
        <article class="chain-reference rounded-[1.2rem] border border-slate-200/82 bg-white/72 p-4" data-chain-panel>
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.traditionalTitle}</p>

            <div class="chain-reference__flow" data-chain-reference-flow>
              {content.traditionalSteps.map((step, index) => (
                <>
                  <article class="chain-reference__step" data-chain-step>
                    <span>{step}</span>
                  </article>
                  {index < content.traditionalSteps.length - 1 && (
                    <span class="chain-reference__connector" aria-hidden="true"></span>
                  )}
                </>
              ))}
            </div>
          </div>
        </article>

        <article class="chain-system rounded-[1.5rem] border border-[rgba(31,53,87,0.11)] bg-[linear-gradient(180deg,rgba(235,242,246,0.98),rgba(247,250,252,0.98))] p-5 md:p-6" data-chain-panel>
          <div class="space-y-2.5">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.velvoixTitle}</p>
            <p class="max-w-[43rem] text-sm leading-6 text-slate-600">{content.velvoixSupporting}</p>
          </div>

          <div class="chain-system__flow mt-5" data-chain-flow>
            <div class="chain-primary-row" data-chain-primary-row>
              <span class="chain-flow-line" aria-hidden="true"></span>
              {primaryFlow.map((step, index) => (
                <article
                  class:list={['chain-primary-step', index === 1 && 'is-highlighted']}
                  data-chain-step
                >
                  <span>{step}</span>
                </article>
              ))}
            </div>

            <div class="chain-context-note" data-chain-context>
              <p class="chain-context-note__eyebrow">{highlightedDetail.title}</p>
              <p class="chain-context-note__text">{highlightedDetail.description}</p>
            </div>

            <div class="chain-secondary-row" data-chain-secondary-row>
              {secondaryFlow.map((step) => (
                <article class="chain-secondary-step" data-chain-step>
                  <span>{step}</span>
                </article>
              ))}
            </div>
          </div>

          <div class="chain-summary mt-6" data-chain-results>
            {content.outcomes.map((outcome) => (
              <div class="chain-summary__item" data-chain-result>
                <span class="chain-summary__dot" aria-hidden="true"></span>
                <span>{outcome}</span>
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  [data-chain-block] .chain-reference__flow {
    display: grid;
    align-items: center;
    gap: 0.7rem;
    grid-template-columns: minmax(0, 1fr) 0.9rem minmax(0, 1fr) 0.9rem minmax(0, 1fr);
    min-width: min(100%, 31rem);
  }

  [data-chain-block] .chain-reference__step,
  [data-chain-block] .chain-primary-step,
  [data-chain-block] .chain-secondary-step {
    display: grid;
    align-items: center;
    justify-items: center;
    text-align: center;
    text-wrap: balance;
  }

  [data-chain-block] .chain-reference__step {
    min-height: 3.35rem;
    border-radius: 0.95rem;
    border: 1px solid rgba(220, 228, 236, 0.86);
    background: rgba(255, 255, 255, 0.8);
    padding: 0.7rem 0.8rem;
    font-size: 0.84rem;
    font-weight: 600;
    color: rgb(100 116 139);
  }

  [data-chain-block] .chain-reference__connector {
    position: relative;
    display: block;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.42), rgba(148, 163, 184, 0.14));
  }

  [data-chain-block] .chain-reference__connector::after {
    content: '';
    position: absolute;
    right: -0.02rem;
    top: 50%;
    width: 0.38rem;
    height: 0.38rem;
    border-top: 1px solid rgba(148, 163, 184, 0.42);
    border-right: 1px solid rgba(148, 163, 184, 0.42);
    transform: translateY(-50%) rotate(45deg);
  }

  [data-chain-block] .chain-system__flow {
    display: grid;
    gap: 1rem;
  }

  [data-chain-block] .chain-primary-row {
    position: relative;
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    padding-top: 0.15rem;
  }

  [data-chain-block] .chain-flow-line {
    position: absolute;
    left: 8%;
    right: 8%;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.18), rgba(25, 130, 121, 0.28), rgba(148, 163, 184, 0.18));
    transform: translateY(-50%);
  }

  [data-chain-block] .chain-primary-step {
    position: relative;
    z-index: 1;
    min-height: 5.1rem;
    border-radius: 1rem;
    border: 1px solid rgba(214, 223, 233, 0.84);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(247, 250, 252, 0.97));
    padding: 0.95rem 0.9rem;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgb(15 23 42);
    box-shadow: 0 12px 24px rgba(31, 53, 87, 0.05);
  }

  [data-chain-block] .chain-primary-step.is-highlighted {
    border-color: rgba(25, 130, 121, 0.2);
    background: linear-gradient(180deg, rgba(242, 249, 247, 0.97), rgba(255, 255, 255, 0.96));
    box-shadow: 0 14px 28px rgba(31, 53, 87, 0.055);
  }

  [data-chain-block] .chain-context-note {
    max-width: 19rem;
    margin-left: calc(25% + 0.45rem);
    border-left: 1px solid rgba(25, 130, 121, 0.2);
    padding-left: 1rem;
  }

  [data-chain-block] .chain-context-note__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  [data-chain-block] .chain-context-note__text {
    margin-top: 0.35rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(71 85 105);
    text-wrap: pretty;
  }

  [data-chain-block] .chain-secondary-row {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  [data-chain-block] .chain-secondary-step {
    min-height: 4.45rem;
    border-radius: 0.95rem;
    border-top: 1px solid rgba(203, 213, 225, 0.92);
    padding: 1rem 0.85rem 0.15rem;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
    color: rgb(51 65 85);
  }

  [data-chain-block] .chain-summary {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid rgba(226, 232, 240, 0.84);
    padding-top: 1.1rem;
  }

  [data-chain-block] .chain-summary__item {
    display: inline-flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.5;
    color: rgb(51 65 85);
    text-wrap: balance;
  }

  [data-chain-block] .chain-summary__dot {
    width: 0.42rem;
    height: 0.42rem;
    margin-top: 0.38rem;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--vx-accent);
    box-shadow: 0 0 0 4px rgba(25, 130, 121, 0.1);
  }

  @media (max-width: 1180px) {
    [data-chain-block] .chain-primary-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-chain-block] .chain-flow-line {
      display: none;
    }

    [data-chain-block] .chain-context-note {
      max-width: none;
      margin-left: 0;
    }
  }

  @media (max-width: 1023px) {
    [data-chain-block] .chain-reference__flow {
      min-width: 0;
      width: 100%;
    }

    [data-chain-block] .chain-secondary-row,
    [data-chain-block] .chain-summary {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    [data-chain-block] .chain-reference__flow,
    [data-chain-block] .chain-primary-row {
      grid-template-columns: 1fr;
    }

    [data-chain-block] .chain-reference__connector {
      display: none;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chainBlocks = document.querySelectorAll('[data-chain-block]');

  for (const block of chainBlocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector<HTMLElement>('[data-chain-intro]');
    const compare = block.querySelector<HTMLElement>('[data-chain-compare]');
    const panels = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-panel]'));
    const referenceFlow = block.querySelector<HTMLElement>('[data-chain-reference-flow]');
    const primaryRow = block.querySelector<HTMLElement>('[data-chain-primary-row]');
    const context = block.querySelector<HTMLElement>('[data-chain-context]');
    const secondaryRow = block.querySelector<HTMLElement>('[data-chain-secondary-row]');
    const steps = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-step]'));
    const summary = block.querySelector<HTMLElement>('[data-chain-results]');
    const summaryItems = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-result]'));

    if (prefersReducedMotion) {
      gsap.set([intro, compare, ...panels, referenceFlow, primaryRow, context, secondaryRow, ...steps, summary, ...summaryItems], {
        clearProps: 'all',
      });
      continue;
    }

    gsap.set([intro, compare], { autoAlpha: 0, y: 18 });
    gsap.set(panels, { autoAlpha: 0, y: 14 });
    gsap.set(referenceFlow, { autoAlpha: 0, y: 8 });
    gsap.set(primaryRow, { autoAlpha: 0, y: 10 });
    gsap.set(steps, { autoAlpha: 0, y: 10 });
    gsap.set(context, { autoAlpha: 0, y: 10 });
    gsap.set(secondaryRow, { autoAlpha: 0, y: 10 });
    gsap.set(summary, { autoAlpha: 0, y: 10 });
    gsap.set(summaryItems, { autoAlpha: 0, y: 8 });

    gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: {
        trigger: block,
        start: 'top 72%',
        once: true,
      },
      onComplete: () => {
        gsap.set([intro, compare, ...panels, referenceFlow, primaryRow, context, secondaryRow, ...steps, summary, ...summaryItems], {
          clearProps: 'opacity,visibility,transform',
        });
      },
    })
      .to(intro, { autoAlpha: 1, y: 0, duration: 0.48 })
      .to(compare, { autoAlpha: 1, y: 0, duration: 0.52 }, '-=0.28')
      .to(panels, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.1 }, '-=0.16')
      .to(referenceFlow, { autoAlpha: 1, y: 0, duration: 0.26 }, '-=0.12')
      .to(primaryRow, { autoAlpha: 1, y: 0, duration: 0.3 }, '-=0.08')
      .to(steps, { autoAlpha: 1, y: 0, duration: 0.24, stagger: 0.04 }, '-=0.14')
      .to(context, { autoAlpha: 1, y: 0, duration: 0.22 }, '-=0.1')
      .to(secondaryRow, { autoAlpha: 1, y: 0, duration: 0.22 }, '-=0.1')
      .to(summary, { autoAlpha: 1, y: 0, duration: 0.2 }, '-=0.06')
      .to(summaryItems, { autoAlpha: 1, y: 0, duration: 0.18, stagger: 0.05 }, '-=0.08');
  }
</script>
