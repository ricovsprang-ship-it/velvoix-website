---
import type { CompareChainsContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: CompareChainsContent;
}

const { content } = Astro.props;
const highlightedDetail = content.stepDetails[1] ?? content.stepDetails[0];
---

<section class="section-block surface-band" id="how-it-works" data-chain-block>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
    <div class="max-w-[32rem]" data-chain-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div
      class="chain-compare rounded-[1.85rem] border border-slate-200/80 bg-white/94 p-6 shadow-[0_18px_36px_rgba(31,53,87,0.06)] md:p-7"
      data-chain-compare
    >
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.compareLabel}</p>

      <div class="mt-5 space-y-4">
        <article
          class="chain-panel chain-panel-traditional rounded-[1.3rem] border border-slate-200/88 bg-slate-50/86 p-4 md:p-5"
          data-chain-panel
        >
          <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.traditionalTitle}</p>

          <div class="chain-grid chain-grid-traditional mt-4" data-chain-grid-traditional>
            {content.traditionalSteps.map((step, index) => (
              <>
                <article class="chain-step chain-step-traditional" data-chain-step>
                  <span class="chain-step-index">{String(index + 1).padStart(2, '0')}</span>
                  <h3 class="chain-step-label">{step}</h3>
                </article>
                {index < content.traditionalSteps.length - 1 && (
                  <span class="chain-connector chain-connector-traditional" aria-hidden="true"></span>
                )}
              </>
            ))}
          </div>
        </article>

        <article
          class="chain-panel chain-panel-velvoix rounded-[1.45rem] border border-[rgba(31,53,87,0.13)] bg-[linear-gradient(180deg,rgba(236,242,246,0.98),rgba(246,249,252,0.99))] p-5 shadow-[0_16px_32px_rgba(31,53,87,0.055)] md:p-6"
          data-chain-panel
        >
          <div class="space-y-3">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.velvoixTitle}</p>
            <p class="max-w-[46rem] text-sm leading-6 text-slate-600">{content.velvoixSupporting}</p>
          </div>

          <div class="chain-grid chain-grid-velvoix mt-5" data-chain-grid-velvoix>
            {content.velvoixSteps.map((step, index) => (
              <article
                class:list={['chain-step chain-step-velvoix', index === 1 && 'is-highlighted']}
                data-chain-step
              >
                <span class="chain-step-index">{String(index + 1).padStart(2, '0')}</span>
                <h3 class="chain-step-label">{step}</h3>
              </article>
            ))}
          </div>

          <div
            class="chain-context-note mt-5 rounded-[1.1rem] border border-slate-200/86 bg-white/86 px-4 py-4"
            data-chain-context
          >
            <p class="chain-context-note__eyebrow">{highlightedDetail.title}</p>
            <p class="chain-context-note__text">{highlightedDetail.description}</p>
          </div>

          <div class="chain-results mt-5 grid gap-3 md:grid-cols-3" data-chain-results>
            {content.outcomes.map((outcome, index) => (
              <article class="chain-result-card" data-chain-result>
                <span class="chain-result-index">{String(index + 1).padStart(2, '0')}</span>
                <p>{outcome}</p>
              </article>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  [data-chain-block] .chain-panel {
    position: relative;
  }

  [data-chain-block] .chain-grid {
    display: grid;
    gap: 0.85rem;
    align-items: stretch;
  }

  [data-chain-block] .chain-grid-traditional {
    grid-template-columns: minmax(0, 1fr) 1rem minmax(0, 1fr) 1rem minmax(0, 1fr);
  }

  [data-chain-block] .chain-grid-velvoix {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  [data-chain-block] .chain-step {
    display: grid;
    align-content: start;
    gap: 0.55rem;
    min-height: 6.2rem;
    border-radius: 1rem;
    border: 1px solid rgba(203, 213, 225, 0.95);
    padding: 1rem 1rem 0.95rem;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  [data-chain-block] .chain-step-traditional {
    background: rgba(255, 255, 255, 0.92);
  }

  [data-chain-block] .chain-step-velvoix {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(247, 250, 252, 0.98));
  }

  [data-chain-block] .chain-step-velvoix.is-highlighted {
    border-color: rgba(25, 130, 121, 0.22);
    background: linear-gradient(180deg, rgba(242, 249, 247, 0.98), rgba(255, 255, 255, 0.98));
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.76),
      0 10px 22px rgba(31, 53, 87, 0.06);
  }

  [data-chain-block] .chain-step-index,
  [data-chain-block] .chain-result-index {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  [data-chain-block] .chain-step-label {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.35;
    color: rgb(15 23 42);
    text-wrap: balance;
  }

  [data-chain-block] .chain-connector {
    position: relative;
    display: block;
    align-self: center;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.55), rgba(148, 163, 184, 0.16));
  }

  [data-chain-block] .chain-connector::after {
    content: '';
    position: absolute;
    right: -0.02rem;
    top: 50%;
    width: 0.42rem;
    height: 0.42rem;
    border-top: 1px solid rgba(148, 163, 184, 0.55);
    border-right: 1px solid rgba(148, 163, 184, 0.55);
    transform: translateY(-50%) rotate(45deg);
  }

  [data-chain-block] .chain-context-note {
    display: grid;
    gap: 0.45rem;
  }

  [data-chain-block] .chain-context-note__eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  [data-chain-block] .chain-context-note__text {
    max-width: 42rem;
    font-size: 0.92rem;
    line-height: 1.65;
    color: rgb(71 85 105);
    text-wrap: pretty;
  }

  [data-chain-block] .chain-results {
    align-items: stretch;
  }

  [data-chain-block] .chain-result-card {
    display: grid;
    gap: 0.5rem;
    min-height: 4.7rem;
    border-top: 0;
    border-radius: 1rem;
    border: 1px solid rgba(216, 224, 232, 0.92);
    background: rgba(255, 255, 255, 0.84);
    padding: 0.95rem 1rem;
  }

  [data-chain-block] .chain-result-card p {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.5;
    color: rgb(51 65 85);
    text-wrap: balance;
  }

  @media (max-width: 1180px) {
    [data-chain-block] .chain-grid-velvoix {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1023px) {
    [data-chain-block] .chain-grid-traditional {
      grid-template-columns: 1fr;
    }

    [data-chain-block] .chain-grid-velvoix {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-chain-block] .chain-connector {
      width: 1px;
      min-height: 0.9rem;
      justify-self: center;
      background: linear-gradient(180deg, rgba(148, 163, 184, 0.55), rgba(148, 163, 184, 0.16));
    }

    [data-chain-block] .chain-connector::after {
      right: auto;
      left: 50%;
      top: auto;
      bottom: -0.02rem;
      transform: translateX(-50%) rotate(135deg);
    }
  }

  @media (max-width: 767px) {
    [data-chain-block] .chain-grid-velvoix,
    [data-chain-block] .chain-results {
      grid-template-columns: 1fr;
    }

    [data-chain-block] .chain-step,
    [data-chain-block] .chain-result-card {
      min-height: auto;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chainBlocks = document.querySelectorAll('[data-chain-block]');

  for (const block of chainBlocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector<HTMLElement>('[data-chain-intro]');
    const compare = block.querySelector<HTMLElement>('[data-chain-compare]');
    const panels = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-panel]'));
    const steps = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-step]'));
    const context = block.querySelector<HTMLElement>('[data-chain-context]');
    const results = Array.from(block.querySelectorAll<HTMLElement>('[data-chain-result]'));

    if (prefersReducedMotion) {
      gsap.set([intro, compare, ...panels, ...steps, context, ...results], { clearProps: 'all' });
      continue;
    }

    gsap.set([intro, compare], { autoAlpha: 0, y: 18 });
    gsap.set(panels, { autoAlpha: 0, y: 14 });
    gsap.set(steps, { autoAlpha: 0, y: 10 });
    gsap.set(context, { autoAlpha: 0, y: 10 });
    gsap.set(results, { autoAlpha: 0, y: 10 });

    gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: {
        trigger: block,
        start: 'top 72%',
        once: true,
      },
      onComplete: () => {
        gsap.set([intro, compare, ...panels, ...steps, context, ...results], {
          clearProps: 'opacity,visibility,transform',
        });
      },
    })
      .to(intro, { autoAlpha: 1, y: 0, duration: 0.48 })
      .to(compare, { autoAlpha: 1, y: 0, duration: 0.5 }, '-=0.28')
      .to(panels, { autoAlpha: 1, y: 0, duration: 0.34, stagger: 0.1 }, '-=0.14')
      .to(steps, { autoAlpha: 1, y: 0, duration: 0.28, stagger: 0.05 }, '-=0.18')
      .to(context, { autoAlpha: 1, y: 0, duration: 0.24 }, '-=0.12')
      .to(results, { autoAlpha: 1, y: 0, duration: 0.24, stagger: 0.08 }, '-=0.08');
  }
</script>
