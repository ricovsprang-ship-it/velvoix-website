---
import type { CompareChainsContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: CompareChainsContent;
}

const { content } = Astro.props;
---

<section class="section-block surface-band" id="how-it-works" data-chain-block>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
    <div class="max-w-[32rem] chain-intro" data-chain-intro>
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div class="chain-compare rounded-[2.2rem] border border-slate-200/80 bg-white/90 p-6 shadow-[0_20px_40px_rgba(31,53,87,0.06)] md:p-8" data-chain-compare>
      <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-500">{content.compareLabel}</p>

      <div class="mt-6 space-y-4">
        <div class="chain-row chain-row-traditional rounded-[1.55rem] border border-slate-200/85 bg-slate-50/88 p-5" data-chain-row="traditional">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="shrink-0 lg:w-[11rem]">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.traditionalTitle}</p>
            </div>

            <div class="flex min-w-0 flex-1 flex-wrap items-center gap-2.5">
              {content.traditionalSteps.map((step, index) => (
                <>
                  <div class="inline-flex min-h-10 items-center rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm">
                    {step}
                  </div>
                  {index < content.traditionalSteps.length - 1 && (
                    <span class="text-sm font-semibold text-slate-300">-></span>
                  )}
                </>
              ))}
            </div>
          </div>
        </div>

        <div class="chain-row chain-row-velvoix rounded-[1.85rem] border border-[rgba(31,53,87,0.12)] bg-[linear-gradient(180deg,rgba(234,241,246,0.96),rgba(245,249,252,0.98))] p-5 shadow-[0_18px_34px_rgba(31,53,87,0.06)]" data-chain-row="velvoix">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="shrink-0 lg:w-[11rem]">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{content.velvoixTitle}</p>
            </div>

            <div class="min-w-0 flex-1">
              <div class="chain-flow relative flex min-w-0 flex-wrap items-center gap-2.5" data-chain-flow>
                <span class="chain-flow-line hidden origin-left md:block" aria-hidden="true" data-chain-flow-line></span>
                {content.velvoixSteps.map((step, index) => (
                  <>
                    <button
                      type="button"
                      class="chain-node inline-flex min-h-11 items-center rounded-full border border-[rgba(31,53,87,0.12)] bg-white/96 px-4 py-2 text-sm font-semibold text-slate-800 shadow-[0_8px_18px_rgba(31,53,87,0.05)]"
                      data-chain-node
                      data-chain-node-index={index}
                      data-chain-detail-title={content.stepDetails[index]?.title}
                      data-chain-detail-description={content.stepDetails[index]?.description}
                      aria-pressed={index === 0 ? 'true' : 'false'}
                      aria-controls="chain-step-detail"
                    >
                      {step}
                    </button>
                    {index < content.velvoixSteps.length - 1 && (
                      <span class="chain-arrow text-sm font-semibold text-slate-400" data-chain-arrow>
                        ->
                      </span>
                    )}
                  </>
                ))}
                <span class="chain-highlight hidden md:block" aria-hidden="true" data-chain-highlight></span>
              </div>

              <p class="mt-5 max-w-[42rem] text-sm leading-6 text-slate-600">{content.velvoixSupporting}</p>

              <div
                id="chain-step-detail"
                class="chain-detail mt-5 rounded-[1.3rem] border border-slate-200/80 bg-white/84 px-4 py-3.5 shadow-[0_10px_22px_rgba(31,53,87,0.045)]"
                data-chain-detail
                aria-live="polite"
              >
                <div class="flex items-start gap-3">
                  <span class="mt-1 size-2 rounded-full bg-[var(--vx-accent)]"></span>
                  <div class="min-w-0">
                    <p class="chain-detail-title text-sm font-semibold text-slate-900" data-chain-detail-title>
                      {content.stepDetails[0]?.title}
                    </p>
                    <p class="chain-detail-description mt-1 text-sm leading-6 text-slate-600" data-chain-detail-description>
                      {content.stepDetails[0]?.description}
                    </p>
                  </div>
                </div>
              </div>

              <div class="chain-results mt-5 flex flex-wrap gap-2.5" data-chain-results>
                {content.outcomes.map((outcome) => (
                  <div class="inline-flex items-center gap-2 rounded-full border border-slate-200/80 bg-white/88 px-3 py-1.5 text-[0.82rem] font-semibold text-slate-700" data-chain-result>
                    <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                    <span>{outcome}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  [data-chain-block] .chain-flow {
    isolation: isolate;
  }

  [data-chain-block] .chain-row-traditional {
    opacity: 0.84;
  }

  [data-chain-block] .chain-flow-line {
    position: absolute;
    left: 1rem;
    right: 1rem;
    top: 50%;
    height: 1px;
    background: linear-gradient(90deg, rgba(25, 130, 121, 0.18), rgba(31, 53, 87, 0.18));
    transform: translateY(-50%);
    z-index: -2;
  }

  [data-chain-block] .chain-highlight {
    position: absolute;
    left: 1rem;
    top: 50%;
    width: 5.5rem;
    height: 2px;
    background: linear-gradient(90deg, rgba(25, 130, 121, 0), rgba(25, 130, 121, 0.42), rgba(25, 130, 121, 0));
    transform: translateY(-50%);
    z-index: -1;
    pointer-events: none;
  }

  [data-chain-block] .chain-node {
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      color 180ms ease;
    cursor: pointer;
  }

  [data-chain-block] .chain-node[aria-pressed='true'] {
    border-color: rgba(25, 130, 121, 0.34);
    background: rgba(255, 255, 255, 1);
    box-shadow: 0 12px 24px rgba(31, 53, 87, 0.08);
  }

  [data-chain-block] .chain-node:is(:hover, :focus-visible) {
    background: rgba(255, 255, 255, 1);
    border-color: rgba(25, 130, 121, 0.26);
    box-shadow: 0 10px 22px rgba(31, 53, 87, 0.08);
    color: rgb(15 23 42);
  }

  [data-chain-block] .chain-node:focus-visible {
    outline: 2px solid rgba(25, 130, 121, 0.22);
    outline-offset: 2px;
  }

  [data-chain-block] .chain-detail {
    min-height: 6.35rem;
  }

  @media (max-width: 767px) {
    [data-chain-block] .chain-results {
      gap: 0.5rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const chainBlocks = document.querySelectorAll('[data-chain-block]');

  for (const block of chainBlocks) {
    if (block instanceof HTMLElement === false) continue;
    if (block.dataset.gsapBound === 'true') continue;
    block.dataset.gsapBound = 'true';

    const intro = block.querySelector('[data-chain-intro]');
    const compare = block.querySelector('[data-chain-compare]');
    const traditionalRow = block.querySelector('[data-chain-row="traditional"]');
    const velvoixRow = block.querySelector('[data-chain-row="velvoix"]');
    const flowLine = block.querySelector('[data-chain-flow-line]');
    const highlight = block.querySelector('[data-chain-highlight]');
    const detail = block.querySelector<HTMLElement>('[data-chain-detail]');
    const detailTitle = block.querySelector<HTMLElement>('[data-chain-detail-title]');
    const detailDescription = block.querySelector<HTMLElement>('[data-chain-detail-description]');
    const nodes = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-node]'));
    const arrows = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-arrow]'));
    const results = gsap.utils.toArray<HTMLElement>(block.querySelectorAll('[data-chain-result]'));

    if (prefersReducedMotion) {
      gsap.set([intro, compare, traditionalRow, velvoixRow, flowLine, highlight, nodes, arrows, results, detail], {
        clearProps: 'all',
      });
    }

    const updateActiveStep = (index: number) => {
      const activeNode = nodes[index];
      if (!activeNode || !detailTitle || !detailDescription || !detail) return;

      for (const [nodeIndex, node] of nodes.entries()) {
        node.setAttribute('aria-pressed', nodeIndex === index ? 'true' : 'false');
      }

      const nextTitle = activeNode.dataset.chainDetailTitle ?? activeNode.textContent?.trim() ?? '';
      const nextDescription = activeNode.dataset.chainDetailDescription ?? '';

      if (prefersReducedMotion) {
        detailTitle.textContent = nextTitle;
        detailDescription.textContent = nextDescription;
        return;
      }

      gsap.killTweensOf([detailTitle, detailDescription, detail]);
      gsap
        .timeline({ defaults: { ease: 'power2.out' } })
        .to([detailTitle, detailDescription], { autoAlpha: 0, y: 4, duration: 0.14 })
        .add(() => {
          detailTitle.textContent = nextTitle;
          detailDescription.textContent = nextDescription;
        })
        .to(detail, { borderColor: 'rgba(25, 130, 121, 0.18)', duration: 0.18 }, '<')
        .to([detailTitle, detailDescription], { autoAlpha: 1, y: 0, duration: 0.18 })
        .to(detail, { borderColor: 'rgba(226, 232, 240, 0.8)', duration: 0.22 }, '-=0.02');
    };

    for (const [index, node] of nodes.entries()) {
      node.addEventListener('mouseenter', () => updateActiveStep(index));
      node.addEventListener('focus', () => updateActiveStep(index));
      node.addEventListener('click', () => updateActiveStep(index));
    }

    if (!prefersReducedMotion) {
      gsap.set([intro, compare], { autoAlpha: 0, y: 18 });
      gsap.set(traditionalRow, { autoAlpha: 0, y: 12 });
      gsap.set(velvoixRow, { autoAlpha: 1 });
      gsap.set(nodes, { autoAlpha: 0, y: 8, scale: 0.985 });
      gsap.set(arrows, { autoAlpha: 0, y: 4 });
      gsap.set(flowLine, { autoAlpha: 0, scaleX: 0.36, transformOrigin: 'left center' });
      gsap.set(highlight, { autoAlpha: 0, x: -16 });
      gsap.set(results, { autoAlpha: 0, y: 10 });

      const timeline = gsap.timeline({
        defaults: { ease: 'power2.out' },
        scrollTrigger: {
          trigger: block,
          start: 'top 72%',
          once: true,
        },
      });

      timeline
        .to(intro, { autoAlpha: 1, y: 0, duration: 0.52 })
        .to(compare, { autoAlpha: 1, y: 0, duration: 0.56 }, '-=0.32')
        .to(traditionalRow, { autoAlpha: 0.84, y: 0, duration: 0.46 }, '-=0.18')
        .to(
          nodes,
          {
            autoAlpha: 1,
            y: 0,
            scale: 1,
            duration: 0.34,
            stagger: 0.1,
          },
          '-=0.02'
        )
        .to(
          arrows,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.22,
            stagger: 0.1,
          },
          '<0.08'
        )
        .to(flowLine, { autoAlpha: 1, scaleX: 1, duration: 0.5 }, '-=0.38')
        .to(highlight, { autoAlpha: 0.95, x: 452, duration: 0.78, ease: 'power1.inOut' })
        .to(highlight, { autoAlpha: 0, duration: 0.12 }, '-=0.08')
        .to(
          results,
          {
            autoAlpha: 1,
            y: 0,
            duration: 0.28,
            stagger: 0.08,
          },
          '-=0.02'
        );
    }

    updateActiveStep(0);
  }
</script>
