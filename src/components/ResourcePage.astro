---
import type { FooterContent, Locale, NavItem } from '../content/site';
import type { ResourceArticleContent, ResourceLocale, ResourceUiContent } from '../content/resources';
import { getResourcePath, resourceArticlesByLocale } from '../content/resources';
import Footer from './Footer.astro';
import Header from './Header.astro';

interface Props {
  locale: ResourceLocale;
  article: ResourceArticleContent;
  ui: ResourceUiContent;
  footer: FooterContent;
  nav: NavItem[];
  languagePaths: Partial<Record<Locale, string>>;
}

const { locale, article, ui, footer, nav, languagePaths } = Astro.props;
const homePath = locale === 'nl' ? '/' : `/${locale}/`;
const relatedArticles = resourceArticlesByLocale[locale].filter((candidate) => candidate.id !== article.id);
const backLabel = locale === 'nl' ? 'Terug naar homepage' : 'Back to homepage';
const summaryLabel = locale === 'nl' ? 'Kern in het kort' : 'Core in brief';
const pointsLabel = locale === 'nl' ? 'Wat deze pagina behandelt' : 'What this page covers';
const relatedLabel = locale === 'nl' ? 'Verder lezen' : 'Related reading';
---

<div class="site-shell">
  <Header locale={locale} nav={nav} languagePaths={languagePaths} />

  <main>
    <section class="border-b border-slate-200/80 bg-[linear-gradient(180deg,rgba(246,249,252,0.98),rgba(241,246,250,0.94))]">
      <div class="section-shell py-14 md:py-18">
        <div class="max-w-[54rem]">
          <a class="text-sm font-semibold text-[rgb(33_65_120)] transition-colors hover:text-[rgb(27_53_99)]" href={homePath}>
            {backLabel}
          </a>
          <p class="eyebrow mt-6">{article.eyebrow}</p>
          <h1 class="mt-4 max-w-[20ch] text-4xl font-extrabold tracking-tight text-slate-950 [text-wrap:balance] md:text-5xl">
            {article.title}
          </h1>
          <p class="mt-6 max-w-[48rem] text-lg leading-8 text-slate-600 [text-wrap:pretty]">{article.intro}</p>
        </div>
      </div>
    </section>

    <section class="section-block">
      <div class="section-shell grid gap-10 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-start">
        <aside class="lg:sticky lg:top-28">
          <div class="rounded-[1.4rem] border border-slate-200/85 bg-white/92 p-5 shadow-[0_18px_32px_rgba(31,53,87,0.05)]">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{summaryLabel}</p>
            <p class="mt-4 text-sm leading-6 text-slate-600">{article.summary}</p>

            <div class="mt-6 border-t border-slate-200/80 pt-5">
              <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-500">{pointsLabel}</p>
              <ul class="mt-4 space-y-3">
                {article.points.map((point) => (
                  <li class="flex items-start gap-3 text-sm leading-6 text-slate-700">
                    <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                    <span>{point}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </aside>

        <div class="space-y-8">
          <div class="rounded-[1.8rem] border border-slate-200/85 bg-white/96 p-6 shadow-[0_24px_42px_rgba(31,53,87,0.06)] md:p-8 lg:p-10">
            <div class="space-y-10">
              {article.sections.map((section) => (
                <section class="border-t border-slate-200/75 pt-10 first:border-t-0 first:pt-0">
                  <h2 class="max-w-[26ch] text-2xl font-bold tracking-tight text-slate-950 [text-wrap:balance] md:text-[1.9rem]">
                    {section.title}
                  </h2>
                  <div class="mt-5 space-y-4">
                    {section.paragraphs.map((paragraph) => (
                      <p class="text-[1rem] leading-8 text-slate-600">{paragraph}</p>
                    ))}
                  </div>
                  {section.bullets && (
                    <ul class="mt-5 space-y-3 rounded-[1.2rem] border border-slate-200/80 bg-slate-50/78 px-5 py-5">
                      {section.bullets.map((bullet) => (
                        <li class="flex items-start gap-3 text-[0.98rem] leading-7 text-slate-700">
                          <span class="mt-2 size-1.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                          <span>{bullet}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                </section>
              ))}
            </div>
          </div>

          <div class="rounded-[1.8rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(236,243,247,0.9),rgba(255,255,255,0.96))] p-6 shadow-[0_20px_36px_rgba(31,53,87,0.05)] md:p-8">
            <p class="eyebrow">{article.eyebrow}</p>
            <h2 class="mt-4 text-2xl font-bold tracking-tight text-slate-950 [text-wrap:balance] md:text-[1.85rem]">
              {article.ctaTitle}
            </h2>
            <p class="mt-4 max-w-[44rem] text-base leading-7 text-slate-600">{article.ctaBody}</p>
            <a class="button-primary mt-6" href={`${homePath}#contact`}>{article.ctaLabel}</a>
          </div>

          <div class="rounded-[1.8rem] border border-slate-200/85 bg-white/96 p-6 shadow-[0_20px_36px_rgba(31,53,87,0.05)] md:p-8">
            <p class="eyebrow">{relatedLabel}</p>
            <div class="mt-6 grid gap-4 md:grid-cols-2">
              {relatedArticles.map((related) => (
                <article class="rounded-[1.35rem] border border-slate-200/80 bg-slate-50/72 p-5">
                  <h3 class="text-[1.05rem] font-bold tracking-tight text-slate-950">{related.title}</h3>
                  <p class="mt-3 text-sm leading-6 text-slate-600">{related.cardDescription}</p>
                  <a
                    class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-[rgb(33_65_120)] transition-colors hover:text-[rgb(27_53_99)]"
                    href={getResourcePath(locale, related)}
                  >
                    {ui.hub.linkLabel}
                    <span aria-hidden="true">→</span>
                  </a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer locale={locale} content={footer} />
</div>
