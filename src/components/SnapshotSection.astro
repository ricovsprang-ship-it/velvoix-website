---
import { platformTourContent } from '../content/platform-tour';
import type { Locale, SnapshotSectionContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  locale: Locale;
  content: SnapshotSectionContent;
}

const { locale, content } = Astro.props;
const sectionContent = platformTourContent[locale];
const previewSlide = sectionContent.slides.find((slide) => slide.id === 'event-detail') ?? sectionContent.slides[0];
---

<section class="section-block" data-platform-tour data-tour-slides={JSON.stringify(sectionContent.slides)}>
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.42fr_0.58fr] lg:items-center">
      <div class="max-w-[33rem]" data-platform-tour-intro>
        <SectionIntro eyebrow={sectionContent.eyebrow} title={sectionContent.title} description={sectionContent.description} />
        <p class="mt-5 max-w-[31rem] text-sm leading-6 text-slate-500">{sectionContent.supporting}</p>
        <div class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-3">
          <button type="button" class="platform-tour-button" data-tour-open>
            {sectionContent.cta}
          </button>
          <span class="platform-tour-footnote">
            {sectionContent.slides.length} {sectionContent.curatedViewsLabel}
          </span>
        </div>
      </div>

      <div class="platform-tour-teaser" data-platform-tour-teaser>
        <div class="platform-tour-teaser__frame">
          <img
            src={previewSlide.image}
            alt={previewSlide.alt}
            class="platform-tour-teaser__image"
            loading="lazy"
            decoding="async"
          />
          <div class="platform-tour-teaser__copy">
            <p class="platform-tour-teaser__label">{sectionContent.previewLabel}</p>
            <h3>{sectionContent.previewTitle}</h3>
            <p>{sectionContent.previewBody}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="platform-tour-overlay" data-tour-overlay hidden aria-hidden="true">
    <div class="platform-tour-overlay__backdrop" data-tour-close></div>
    <div
      class="platform-tour-overlay__panel"
      data-tour-panel
      role="dialog"
      aria-modal="true"
      aria-labelledby="platform-tour-title"
      tabindex="-1"
    >
      <header class="platform-tour-overlay__header">
        <div class="platform-tour-overlay__meta">
          <p class="platform-tour-overlay__eyebrow">{sectionContent.overlayLabel}</p>
          <div class="platform-tour-overlay__counter">
            <span data-tour-counter-current>1</span>
            <span>/</span>
            <span>{sectionContent.slides.length}</span>
          </div>
        </div>
        <div class="platform-tour-overlay__actions">
          <div class="platform-tour-navgroup">
            <button type="button" class="platform-tour-nav is-ghost" data-tour-prev>{sectionContent.previousLabel}</button>
            <button type="button" class="platform-tour-nav is-ghost" data-tour-next>{sectionContent.nextLabel}</button>
          </div>
          <button type="button" class="platform-tour-close" data-tour-close>{sectionContent.closeLabel}</button>
        </div>
      </header>

      <div class="platform-tour-overlay__body">
        <div class="platform-tour-stage" data-tour-stage>
          {sectionContent.slides.map((slide, index) => (
            <article class="platform-tour-slide" data-tour-slide data-slide-id={slide.id} hidden={index !== 0}>
              <figure class="platform-tour-slide__figure" data-tour-figure>
                <img
                  alt={slide.alt}
                  data-tour-src={slide.image}
                  draggable="false"
                  data-tour-image
                />
              </figure>
            </article>
          ))}
        </div>

        <aside class="platform-tour-copy">
          <div class="platform-tour-copy__main">
            <p class="platform-tour-copy__label" data-tour-label>{sectionContent.slides[0].label}</p>
            <h3 id="platform-tour-title" data-tour-title>{sectionContent.slides[0].title}</h3>
            <p data-tour-text>{sectionContent.slides[0].text}</p>
            <p class="platform-tour-copy__hint">{sectionContent.interactionHint}</p>
          </div>

          <nav class="platform-tour-rail" aria-label={sectionContent.railLabel}>
            {sectionContent.slides.map((slide, index) => (
              <button
                type="button"
                class:list={['platform-tour-rail__item', index === 0 && 'is-active']}
                data-tour-jump={index}
                aria-current={index === 0 ? 'true' : 'false'}
              >
                <span class="platform-tour-rail__index">{String(index + 1).padStart(2, '0')}</span>
                <span class="platform-tour-rail__copy">
                  <strong>{slide.label}</strong>
                  <span>{slide.title}</span>
                </span>
              </button>
            ))}
          </nav>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  [data-platform-tour] .platform-tour-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.2rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(22, 36, 64, 0.14);
    background: rgb(33 65 120);
    color: rgba(248, 250, 252, 0.98);
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.25;
    text-align: center;
    letter-spacing: -0.01em;
    transition: background-color 160ms ease, transform 160ms ease;
  }

  [data-platform-tour] .platform-tour-button:hover,
  [data-platform-tour] .platform-tour-button:focus-visible {
    background: rgb(27 53 99);
    transform: translateY(-1px);
  }

  [data-platform-tour] .platform-tour-footnote {
    font-size: 0.8rem;
    font-weight: 600;
    color: rgb(100 116 139);
  }

  [data-platform-tour] .platform-tour-teaser {
    position: relative;
  }

  [data-platform-tour] .platform-tour-teaser__frame {
    position: relative;
    overflow: hidden;
    border-radius: 1.7rem;
    border: 1px solid rgba(218, 226, 236, 0.96);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 250, 252, 0.98));
    box-shadow: 0 28px 64px rgba(15, 23, 42, 0.08);
  }

  [data-platform-tour] .platform-tour-teaser__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9.65;
    object-fit: cover;
    object-position: top center;
  }

  [data-platform-tour] .platform-tour-teaser__copy {
    position: absolute;
    left: 1.35rem;
    bottom: 1.35rem;
    max-width: min(25rem, calc(100% - 2.7rem));
    padding: 1rem 1.05rem 1.05rem;
    border: 1px solid rgba(214, 223, 233, 0.96);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(12px);
    box-shadow: 0 18px 34px rgba(15, 23, 42, 0.09);
  }

  [data-platform-tour] .platform-tour-teaser__label,
  [data-platform-tour] .platform-tour-overlay__eyebrow,
  [data-platform-tour] .platform-tour-copy__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-teaser__copy h3 {
    margin-top: 0.45rem;
    font-size: clamp(1.28rem, 2vw, 1.56rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
    text-wrap: balance;
  }

  [data-platform-tour] .platform-tour-teaser__copy p:last-child {
    margin-top: 0.45rem;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-overlay[hidden] {
    display: none;
  }

  [data-platform-tour] .platform-tour-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: grid;
    place-items: center;
    padding: 1.25rem;
  }

  [data-platform-tour] .platform-tour-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.54);
    backdrop-filter: blur(7px);
  }

  [data-platform-tour] .platform-tour-overlay__panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    width: min(1320px, calc(100vw - 2.5rem));
    max-height: calc(100vh - 2.5rem);
    overflow: hidden;
    border: 1px solid rgba(214, 223, 233, 0.96);
    border-radius: 1.5rem;
    background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(243, 248, 251, 0.98));
    box-shadow: 0 30px 72px rgba(15, 23, 42, 0.24);
  }

  [data-platform-tour] .platform-tour-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
    padding: 0.95rem 1.1rem;
    border-bottom: 1px solid rgba(224, 231, 239, 0.92);
  }

  [data-platform-tour] .platform-tour-overlay__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  [data-platform-tour] .platform-tour-overlay__counter {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 1.9rem;
    padding: 0.25rem 0.65rem;
    border: 1px solid rgba(222, 229, 236, 0.96);
    border-radius: 999px;
    background: rgba(248, 250, 252, 0.92);
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-overlay__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    justify-content: flex-end;
  }

  [data-platform-tour] .platform-tour-navgroup {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  [data-platform-tour] .platform-tour-nav,
  [data-platform-tour] .platform-tour-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.25rem;
    padding: 0.42rem 0.82rem;
    border: 1px solid rgba(219, 227, 235, 0.96);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.92);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.2;
    color: rgb(51 65 85);
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }

  [data-platform-tour] .platform-tour-nav:hover,
  [data-platform-tour] .platform-tour-nav:focus-visible,
  [data-platform-tour] .platform-tour-close:hover,
  [data-platform-tour] .platform-tour-close:focus-visible {
    border-color: rgba(148, 163, 184, 0.34);
    color: rgb(15 23 42);
    background: rgba(248, 250, 252, 0.98);
  }

  [data-platform-tour] .platform-tour-overlay__body {
    display: grid;
    grid-template-columns: minmax(0, 1.74fr) minmax(20.5rem, 0.56fr);
    gap: 1.1rem;
    min-height: 0;
    padding: 1.1rem;
  }

  [data-platform-tour] .platform-tour-stage {
    min-width: 0;
    min-height: 0;
    cursor: default;
  }

  [data-platform-tour] .platform-tour-slide,
  [data-platform-tour] .platform-tour-slide__figure {
    height: 100%;
  }

  [data-platform-tour] .platform-tour-slide__figure {
    overflow: hidden;
    display: grid;
    place-items: center;
    padding: clamp(0.55rem, 0.82vw, 0.82rem);
    border: 1px solid rgba(216, 224, 232, 0.96);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.72),
      0 14px 28px rgba(15, 23, 42, 0.04);
    user-select: none;
    -webkit-user-select: none;
    -webkit-user-drag: none;
    touch-action: none;
    overscroll-behavior: contain;
  }

  [data-platform-tour] .platform-tour-slide__figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    background: linear-gradient(180deg, rgba(246, 249, 252, 1), rgba(241, 246, 250, 1));
    border-radius: 0.95rem;
    transform-origin: center center;
    transition: transform 160ms ease;
    user-select: none;
    -webkit-user-drag: none;
    pointer-events: none;
  }

  [data-platform-tour] .platform-tour-copy {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 0.95rem;
    min-height: 0;
  }

  [data-platform-tour] .platform-tour-copy__main,
  [data-platform-tour] .platform-tour-rail {
    border: 1px solid rgba(216, 224, 232, 0.94);
    border-radius: 1.15rem;
    background: rgba(255, 255, 255, 0.95);
  }

  [data-platform-tour] .platform-tour-copy__main {
    padding: 1.15rem 1.1rem;
  }

  [data-platform-tour] .platform-tour-copy__main h3 {
    margin-top: 0.55rem;
    font-size: clamp(1.34rem, 1.9vw, 1.72rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
    text-wrap: balance;
  }

  [data-platform-tour] .platform-tour-copy__main [data-tour-text] {
    margin-top: 0.55rem;
    font-size: 0.93rem;
    line-height: 1.66;
    text-wrap: pretty;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-copy__hint {
    margin-top: 0.85rem;
    font-size: 0.78rem;
    line-height: 1.5;
    color: rgb(100 116 139);
  }

  [data-platform-tour] .platform-tour-slide__figure.is-zoomable {
    cursor: zoom-in;
  }

  [data-platform-tour] .platform-tour-slide__figure.is-pannable {
    cursor: grab;
  }

  [data-platform-tour] .platform-tour-slide__figure.is-dragging {
    cursor: grabbing;
  }

  body.platform-tour-is-dragging,
  body.platform-tour-is-dragging * {
    cursor: grabbing !important;
  }

  [data-platform-tour] .platform-tour-rail {
    overflow: auto;
    padding: 0.45rem;
  }

  [data-platform-tour] .platform-tour-rail__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.8rem;
    width: 100%;
    padding: 0.82rem 0.86rem;
    border: 1px solid transparent;
    border-radius: 0.9rem;
    background: transparent;
    text-align: left;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  [data-platform-tour] .platform-tour-rail__item + .platform-tour-rail__item {
    margin-top: 0.28rem;
  }

  [data-platform-tour] .platform-tour-rail__item:hover,
  [data-platform-tour] .platform-tour-rail__item:focus-visible {
    border-color: rgba(203, 213, 225, 0.94);
    background: rgba(248, 250, 252, 0.9);
  }

  [data-platform-tour] .platform-tour-rail__item.is-active {
    border-color: rgba(191, 219, 254, 0.7);
    background: rgba(246, 249, 252, 0.98);
  }

  [data-platform-tour] .platform-tour-rail__index {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  [data-platform-tour] .platform-tour-rail__copy strong {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: rgb(15 23 42);
  }

  [data-platform-tour] .platform-tour-rail__copy span {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.81rem;
    line-height: 1.45;
    color: rgb(71 85 105);
  }

  @media (max-width: 1023px) {
    [data-platform-tour] .platform-tour-overlay {
      padding: 0.9rem;
    }

    [data-platform-tour] .platform-tour-overlay__panel {
      width: calc(100vw - 1.8rem);
      max-height: calc(100vh - 1.8rem);
    }

    [data-platform-tour] .platform-tour-overlay__body {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      overflow: auto;
    }

    [data-platform-tour] .platform-tour-stage {
      min-height: clamp(20rem, 58svh, 34rem);
    }

    [data-platform-tour] .platform-tour-slide__figure img {
      max-height: 60svh;
    }
  }

  @media (max-width: 767px) {
    [data-platform-tour] .platform-tour-teaser__copy {
      position: static;
      max-width: none;
      border-left: 0;
      border-right: 0;
      border-bottom: 0;
      border-radius: 0;
      background: rgba(255, 255, 255, 0.97);
      box-shadow: none;
      backdrop-filter: none;
    }

    [data-platform-tour] .platform-tour-overlay__header {
      flex-direction: column;
      align-items: flex-start;
    }

    [data-platform-tour] .platform-tour-overlay__actions {
      width: 100%;
      justify-content: flex-start;
      flex-wrap: wrap;
    }

    [data-platform-tour] .platform-tour-nav,
    [data-platform-tour] .platform-tour-close {
      flex: 1 1 9rem;
    }

    [data-platform-tour] .platform-tour-navgroup {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    [data-platform-tour] .platform-tour-copy {
      grid-template-rows: auto auto;
    }

    [data-platform-tour] .platform-tour-stage {
      min-height: clamp(21rem, 62svh, 32rem);
    }

    [data-platform-tour] .platform-tour-slide__figure {
      padding: 0.55rem;
    }

    [data-platform-tour] .platform-tour-slide__figure img {
      max-height: 64svh;
    }

    [data-platform-tour] .platform-tour-rail {
      max-height: 15rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const supportsCoarsePointer = window.matchMedia('(pointer: coarse)').matches;
  const blocks = document.querySelectorAll('[data-platform-tour]');

  for (const block of blocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.bound === 'true') continue;
    block.dataset.bound = 'true';

    const intro = block.querySelector('[data-platform-tour-intro]');
    const teaser = block.querySelector('[data-platform-tour-teaser]');
    const openButton = block.querySelector('[data-tour-open]');
    const overlay = block.querySelector('[data-tour-overlay]');
    const panel = block.querySelector('[data-tour-panel]');
    const prevButton = block.querySelector('[data-tour-prev]');
    const nextButton = block.querySelector('[data-tour-next]');
    const closeButtons = block.querySelectorAll('[data-tour-close]');
    const counterCurrent = block.querySelector('[data-tour-counter-current]');
    const labelTarget = block.querySelector('[data-tour-label]');
    const titleTarget = block.querySelector('[data-tour-title]');
    const textTarget = block.querySelector('[data-tour-text]');
    const slides = Array.from(block.querySelectorAll('[data-tour-slide]'));
    const figures = Array.from(block.querySelectorAll('[data-tour-figure]'));
    const jumpButtons = Array.from(block.querySelectorAll('[data-tour-jump]'));
    const slideData = JSON.parse(block.dataset.tourSlides ?? '[]');
    const stage = block.querySelector('[data-tour-stage]');

    let activeIndex = 0;
    let lastFocused = null;
    const preloaded = new Set();
    const viewState = {
      zoom: 1,
      panX: 0,
      panY: 0,
      dragging: false,
      pointerId: null,
      dragStartX: 0,
      dragStartY: 0,
      dragPanX: 0,
      dragPanY: 0,
      touchMode: 'idle',
      touchStartDistance: 0,
      touchStartZoom: 1,
      touchStartPanX: 0,
      touchStartPanY: 0,
      touchLastCenterX: 0,
      touchLastCenterY: 0,
      touchMoved: false,
      lastTapAt: 0,
      lastTapX: 0,
      lastTapY: 0,
    };

    const focusableSelector =
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

    const getSlideMeta = (index) => slideData[index] ?? {};

    const getSlideImage = (index) => {
      const slide = slides[index];
      if (!(slide instanceof HTMLElement)) return null;
      const image = slide.querySelector('[data-tour-image]');
      return image instanceof HTMLImageElement ? image : null;
    };

    const getActiveImage = () => getSlideImage(activeIndex);

    const getSlideFigure = (index) => {
      const figure = figures[index];
      return figure instanceof HTMLElement ? figure : null;
    };

    const getActiveFigure = () => getSlideFigure(activeIndex);

    const getTouchDistance = (touchA, touchB) => Math.hypot(touchB.clientX - touchA.clientX, touchB.clientY - touchA.clientY);

    const getTouchCenter = (touchA, touchB) => ({
      x: (touchA.clientX + touchB.clientX) / 2,
      y: (touchA.clientY + touchB.clientY) / 2,
    });

    const ensureSlideImage = (index, priority = 'auto') => {
      const slide = slideData[index];
      const image = getSlideImage(index);
      if (!slide || !(image instanceof HTMLImageElement)) return;

      if (!image.getAttribute('src')) {
        image.src = slide.image;
        image.decoding = 'async';
        image.loading = priority === 'high' ? 'eager' : 'lazy';
      }

      image.fetchPriority = priority;
      image.alt = slide.alt;
    };

    const getFitMetrics = () => {
      const figure = getActiveFigure();
      const image = getActiveImage();
      if (!(figure instanceof HTMLElement) || !(image instanceof HTMLImageElement)) return null;

      const rect = figure.getBoundingClientRect();
      if (!rect.width || !rect.height) return null;

      const naturalWidth = image.naturalWidth || rect.width;
      const naturalHeight = image.naturalHeight || rect.height;
      const fitRatio = Math.min(rect.width / naturalWidth, rect.height / naturalHeight);

      return {
        rect,
        fittedWidth: naturalWidth * fitRatio,
        fittedHeight: naturalHeight * fitRatio,
      };
    };

    const clampPan = (panX, panY, zoom = viewState.zoom) => {
      const metrics = getFitMetrics();
      if (!metrics) return { panX, panY };

      const maxX = Math.max(0, (metrics.fittedWidth * zoom - metrics.rect.width) / 2);
      const maxY = Math.max(0, (metrics.fittedHeight * zoom - metrics.rect.height) / 2);

      return {
        panX: Math.min(maxX, Math.max(-maxX, panX)),
        panY: Math.min(maxY, Math.max(-maxY, panY)),
      };
    };

    const updateFigureCursor = () => {
      document.body.classList.toggle('platform-tour-is-dragging', viewState.dragging);

      figures.forEach((figure, index) => {
        if (!(figure instanceof HTMLElement)) return;
        figure.classList.remove('is-zoomable', 'is-pannable', 'is-dragging');
        if (index !== activeIndex) return;

        if (viewState.dragging) {
          figure.classList.add('is-dragging');
        } else if (viewState.zoom > 1.02) {
          figure.classList.add('is-pannable');
        } else {
          figure.classList.add('is-zoomable');
        }
      });
    };

    const resetView = () => {
      viewState.zoom = 1;
      viewState.panX = 0;
      viewState.panY = 0;
      viewState.dragging = false;
      viewState.pointerId = null;
      viewState.touchMode = 'idle';
      viewState.touchMoved = false;
      updateFigureCursor();
    };

    const applyFrame = () => {
      const image = getActiveImage();
      const meta = getSlideMeta(activeIndex);
      if (image instanceof HTMLElement) {
        image.style.objectPosition = meta.objectPosition ?? 'center top';
        image.style.transformOrigin = meta.zoomOrigin ?? '50% 50%';
        const clamped = clampPan(viewState.panX, viewState.panY);
        viewState.panX = clamped.panX;
        viewState.panY = clamped.panY;
        image.style.transform = `translate(${(meta.offsetX ?? 0) + viewState.panX}px, ${(meta.offsetY ?? 0) + viewState.panY}px) scale(${((meta.baseScale ?? 1) * (meta.initialZoom ?? 1)) * viewState.zoom})`;
      }
      updateFigureCursor();
    };

    const preloadSlide = (index) => {
      const slide = slideData[index];
      if (!slide || preloaded.has(slide.image)) return;
      const image = new Image();
      image.decoding = 'async';
      image.src = slide.image;
      preloaded.add(slide.image);
    };

    const preloadAround = (index) => {
      preloadSlide(index);
      if (index + 1 < slideData.length) preloadSlide(index + 1);
      if (index > 0) preloadSlide(index - 1);
    };

    const updateRail = () => {
      jumpButtons.forEach((button, index) => {
        const isActive = index === activeIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const renderCopy = (index, animate) => {
      const slide = slideData[index];
      if (!(labelTarget instanceof HTMLElement) || !(titleTarget instanceof HTMLElement) || !(textTarget instanceof HTMLElement)) return;

      if (!animate || prefersReducedMotion) {
        labelTarget.textContent = slide.label;
        titleTarget.textContent = slide.title;
        textTarget.textContent = slide.text;
        return;
      }

      gsap
        .timeline({ defaults: { ease: 'power2.out' } })
        .to([labelTarget, titleTarget, textTarget], { autoAlpha: 0, y: 8, duration: 0.14, stagger: 0.03 })
        .add(() => {
          labelTarget.textContent = slide.label;
          titleTarget.textContent = slide.title;
          textTarget.textContent = slide.text;
        })
        .to([labelTarget, titleTarget, textTarget], { autoAlpha: 1, y: 0, duration: 0.2, stagger: 0.03 });
    };

    const renderSlide = (nextIndex, animate = true) => {
      if (nextIndex < 0 || nextIndex >= slides.length) return;
      const currentSlide = slides[activeIndex];
      const nextSlide = slides[nextIndex];
      if (!(nextSlide instanceof HTMLElement) || nextSlide === currentSlide) return;

      ensureSlideImage(nextIndex, 'high');

      if (counterCurrent instanceof HTMLElement) counterCurrent.textContent = String(nextIndex + 1);

      if (!animate || prefersReducedMotion) {
        if (currentSlide instanceof HTMLElement) currentSlide.hidden = true;
        nextSlide.hidden = false;
        activeIndex = nextIndex;
        resetView();
        updateRail();
        renderCopy(nextIndex, false);
        applyFrame();
        preloadAround(nextIndex);
        return;
      }

      nextSlide.hidden = false;
      gsap.set(nextSlide, { autoAlpha: 0, y: 16 });

      gsap.timeline({
        defaults: { ease: 'power2.out' },
        onStart: () => {
          activeIndex = nextIndex;
          resetView();
          updateRail();
          renderCopy(nextIndex, true);
          applyFrame();
          preloadAround(nextIndex);
        },
        onComplete: () => {
          if (currentSlide instanceof HTMLElement) currentSlide.hidden = true;
          gsap.set([currentSlide, nextSlide], { clearProps: 'opacity,visibility,transform' });
        },
      })
        .to(currentSlide, { autoAlpha: 0, y: -10, duration: 0.18 })
        .to(nextSlide, { autoAlpha: 1, y: 0, duration: 0.24 }, '-=0.02');
    };

    const zoomAtPoint = (targetZoom, clientX, clientY) => {
      const figure = getActiveFigure();
      if (!(figure instanceof HTMLElement)) return;

      const metrics = getFitMetrics();
      if (!metrics) return;

      const maxZoom = supportsCoarsePointer ? 4 : 3;
      const nextZoom = Math.min(maxZoom, Math.max(1, targetZoom));
      const ratio = nextZoom / viewState.zoom;
      const localX = clientX - metrics.rect.left - metrics.rect.width / 2;
      const localY = clientY - metrics.rect.top - metrics.rect.height / 2;

      viewState.panX = localX - ratio * (localX - viewState.panX);
      viewState.panY = localY - ratio * (localY - viewState.panY);
      viewState.zoom = nextZoom;

      if (viewState.zoom <= 1.01) {
        viewState.zoom = 1;
        viewState.panX = 0;
        viewState.panY = 0;
      }

      applyFrame();
    };

    const trapFocus = (event) => {
      if (!(event instanceof KeyboardEvent) || event.key !== 'Tab' || !(panel instanceof HTMLElement)) return;
      const focusables = Array.from(panel.querySelectorAll(focusableSelector)).filter(
        (element) => element instanceof HTMLElement && !element.hasAttribute('disabled')
      );
      if (!focusables.length) return;

      const first = focusables[0];
      const last = focusables[focusables.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    const openOverlay = () => {
      if (!(overlay instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      ensureSlideImage(activeIndex, 'high');
      preloadAround(activeIndex);
      resetView();
      applyFrame();
      overlay.hidden = false;
      overlay.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';

      if (prefersReducedMotion) {
        panel.focus();
        return;
      }

      gsap.set(panel, { autoAlpha: 0, y: 22, scale: 0.985 });
      gsap.to(panel, { autoAlpha: 1, y: 0, scale: 1, duration: 0.24, ease: 'power2.out' });
      panel.focus();
    };

    const closeOverlay = () => {
      if (!(overlay instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;

      const finish = () => {
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
        resetView();
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      };

      if (prefersReducedMotion) {
        finish();
        return;
      }

      gsap.to(panel, {
        autoAlpha: 0,
        y: 12,
        scale: 0.99,
        duration: 0.18,
        ease: 'power2.in',
        onComplete: finish,
      });
    };

    renderSlide(0, false);
    applyFrame();

    openButton?.addEventListener('click', openOverlay);
    openButton?.addEventListener('pointerenter', () => {
      ensureSlideImage(activeIndex, 'high');
      preloadAround(activeIndex);
    }, { once: true });
    openButton?.addEventListener('focus', () => {
      ensureSlideImage(activeIndex, 'high');
      preloadAround(activeIndex);
    }, { once: true });
    prevButton?.addEventListener('click', () => renderSlide((activeIndex - 1 + slides.length) % slides.length));
    nextButton?.addEventListener('click', () => renderSlide((activeIndex + 1) % slides.length));

    jumpButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextIndex = Number(button.getAttribute('data-tour-jump'));
        renderSlide(nextIndex);
      });
    });

    figures.forEach((figure, index) => {
      if (!(figure instanceof HTMLElement)) return;

      figure.addEventListener('dragstart', (event) => {
        event.preventDefault();
      });

      figure.addEventListener('selectstart', (event) => {
        event.preventDefault();
      });

      figure.addEventListener('wheel', (event) => {
        if (index !== activeIndex || !(overlay instanceof HTMLElement) || overlay.hidden) return;
        event.preventDefault();
        const delta = event.deltaY < 0 ? 1.18 : 1 / 1.18;
        zoomAtPoint(viewState.zoom * delta, event.clientX, event.clientY);
      }, { passive: false });

      figure.addEventListener('dblclick', (event) => {
        if (index !== activeIndex || !(overlay instanceof HTMLElement) || overlay.hidden) return;
        const nextZoom = viewState.zoom > 1.4 ? 1 : 2.1;
        zoomAtPoint(nextZoom, event.clientX, event.clientY);
      });

      figure.addEventListener('pointerdown', (event) => {
        if (
          index !== activeIndex ||
          viewState.zoom <= 1.02 ||
          !(overlay instanceof HTMLElement) ||
          overlay.hidden ||
          event.pointerType === 'touch' ||
          event.button !== 0
        ) {
          return;
        }
        event.preventDefault();
        viewState.dragging = true;
        viewState.pointerId = event.pointerId;
        viewState.dragStartX = event.clientX;
        viewState.dragStartY = event.clientY;
        viewState.dragPanX = viewState.panX;
        viewState.dragPanY = viewState.panY;
        figure.setPointerCapture(event.pointerId);
        updateFigureCursor();
      });

      figure.addEventListener('pointermove', (event) => {
        if (index !== activeIndex || !viewState.dragging || viewState.pointerId !== event.pointerId) return;
        viewState.panX = viewState.dragPanX + (event.clientX - viewState.dragStartX);
        viewState.panY = viewState.dragPanY + (event.clientY - viewState.dragStartY);
        applyFrame();
      });

      const releaseDrag = (event) => {
        if (viewState.pointerId !== event.pointerId) return;
        const pointerId = viewState.pointerId;
        viewState.dragging = false;
        viewState.pointerId = null;
        if (pointerId !== null && figure.hasPointerCapture(pointerId)) {
          figure.releasePointerCapture(pointerId);
        }
        updateFigureCursor();
      };

      figure.addEventListener('pointerup', releaseDrag);
      figure.addEventListener('pointercancel', releaseDrag);
      figure.addEventListener('lostpointercapture', releaseDrag);

      figure.addEventListener('touchstart', (event) => {
        if (index !== activeIndex || !(overlay instanceof HTMLElement) || overlay.hidden) return;

        if (event.touches.length === 2) {
          const [touchA, touchB] = event.touches;
          const center = getTouchCenter(touchA, touchB);
          viewState.touchMode = 'pinch';
          viewState.touchStartDistance = getTouchDistance(touchA, touchB) || 1;
          viewState.touchStartZoom = viewState.zoom;
          viewState.touchStartPanX = viewState.panX;
          viewState.touchStartPanY = viewState.panY;
          viewState.touchLastCenterX = center.x;
          viewState.touchLastCenterY = center.y;
          viewState.touchMoved = false;
          viewState.dragging = false;
          updateFigureCursor();
          return;
        }

        if (event.touches.length === 1 && viewState.zoom > 1.02) {
          const touch = event.touches[0];
          viewState.touchMode = 'pan';
          viewState.touchStartPanX = viewState.panX;
          viewState.touchStartPanY = viewState.panY;
          viewState.dragStartX = touch.clientX;
          viewState.dragStartY = touch.clientY;
          viewState.touchMoved = false;
        }
      }, { passive: true });

      figure.addEventListener('touchmove', (event) => {
        if (index !== activeIndex || !(overlay instanceof HTMLElement) || overlay.hidden) return;

        if (event.touches.length === 2) {
          event.preventDefault();
          const [touchA, touchB] = event.touches;
          const center = getTouchCenter(touchA, touchB);
          const distance = getTouchDistance(touchA, touchB) || viewState.touchStartDistance || 1;
          const targetZoom = viewState.touchStartZoom * (distance / (viewState.touchStartDistance || 1));
          const deltaX = center.x - viewState.touchLastCenterX;
          const deltaY = center.y - viewState.touchLastCenterY;

          zoomAtPoint(targetZoom, center.x, center.y);
          viewState.panX += deltaX;
          viewState.panY += deltaY;
          applyFrame();

          viewState.touchMode = 'pinch';
          viewState.touchLastCenterX = center.x;
          viewState.touchLastCenterY = center.y;
          viewState.touchMoved = true;
          return;
        }

        if (event.touches.length === 1 && viewState.zoom > 1.02) {
          event.preventDefault();
          const touch = event.touches[0];
          viewState.panX = viewState.touchStartPanX + (touch.clientX - viewState.dragStartX);
          viewState.panY = viewState.touchStartPanY + (touch.clientY - viewState.dragStartY);
          viewState.touchMode = 'pan';
          viewState.touchMoved = true;
          applyFrame();
        }
      }, { passive: false });

      figure.addEventListener('touchend', (event) => {
        if (index !== activeIndex) return;

        if (event.touches.length === 1 && viewState.zoom > 1.02) {
          const remainingTouch = event.touches[0];
          viewState.touchMode = 'pan';
          viewState.touchStartPanX = viewState.panX;
          viewState.touchStartPanY = viewState.panY;
          viewState.dragStartX = remainingTouch.clientX;
          viewState.dragStartY = remainingTouch.clientY;
          return;
        }

        if (event.touches.length > 1) return;

        const endedTouch = event.changedTouches[0];
        if (viewState.touchMode !== 'pinch' && endedTouch && !viewState.touchMoved) {
          const isDoubleTap =
            event.timeStamp - viewState.lastTapAt < 320 &&
            Math.hypot(endedTouch.clientX - viewState.lastTapX, endedTouch.clientY - viewState.lastTapY) < 28;

          if (isDoubleTap) {
            const nextZoom = viewState.zoom > 1.4 ? 1 : (supportsCoarsePointer ? 2.6 : 2.1);
            zoomAtPoint(nextZoom, endedTouch.clientX, endedTouch.clientY);
            viewState.lastTapAt = 0;
          } else {
            viewState.lastTapAt = event.timeStamp;
            viewState.lastTapX = endedTouch.clientX;
            viewState.lastTapY = endedTouch.clientY;
          }
        }

        viewState.touchMode = 'idle';
        viewState.touchMoved = false;
      });

      figure.addEventListener('touchcancel', () => {
        viewState.touchMode = 'idle';
        viewState.touchMoved = false;
      });
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeOverlay));

    overlay?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key === 'Escape') closeOverlay();
      const isZoomInKey = event.key === '+' || event.key === '=' || event.code === 'Equal' || event.code === 'NumpadAdd';
      const isZoomOutKey = event.key === '-' || event.key === '_' || event.code === 'Minus' || event.code === 'NumpadSubtract';
      const isResetKey = event.key === '0' || event.code === 'Digit0' || event.code === 'Numpad0';

      if (isZoomInKey) {
        event.preventDefault();
        const figure = getActiveFigure();
        if (!(figure instanceof HTMLElement)) return;
        const rect = figure.getBoundingClientRect();
        zoomAtPoint(viewState.zoom * 1.18, rect.left + rect.width / 2, rect.top + rect.height / 2);
      }
      if (isZoomOutKey) {
        event.preventDefault();
        const figure = getActiveFigure();
        if (!(figure instanceof HTMLElement)) return;
        const rect = figure.getBoundingClientRect();
        zoomAtPoint(viewState.zoom / 1.18, rect.left + rect.width / 2, rect.top + rect.height / 2);
      }
      if (isResetKey) {
        event.preventDefault();
        resetView();
        applyFrame();
      }
      if (event.key === 'ArrowLeft') renderSlide((activeIndex - 1 + slides.length) % slides.length);
      if (event.key === 'ArrowRight') renderSlide((activeIndex + 1) % slides.length);
      trapFocus(event);
    });

    if (!prefersReducedMotion) {
      gsap.set([intro, teaser], { autoAlpha: 0, y: 20 });

      gsap
        .timeline({
          defaults: { ease: 'power2.out' },
          scrollTrigger: {
            trigger: block,
            start: 'top 72%',
            once: true,
          },
          onComplete: () => {
            gsap.set([intro, teaser], { clearProps: 'opacity,visibility,transform' });
          },
        })
        .to(intro, { autoAlpha: 1, y: 0, duration: 0.42 })
        .to(teaser, { autoAlpha: 1, y: 0, duration: 0.5 }, '-=0.22');
    }
  }
</script>

