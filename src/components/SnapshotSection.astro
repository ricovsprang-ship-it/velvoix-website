    const triggers = Array.from(block.querySelectorAll<HTMLElement>('[data-showcase-trigger]'));
    const panels = Array.from(block.querySelectorAll<HTMLElement>('[data-showcase-panel]'));
    let activeId = triggers.find((trigger) => trigger.classList.contains('is-active'))?.dataset.domainId ?? 'event-page';
    let lastFocused: HTMLElement | null = null;

    const setActiveState = (nextId: string) => {
      activeId = nextId;
      for (const trigger of triggers) {
        const isActive = trigger.dataset.domainId === nextId;
        trigger.classList.toggle('is-active', isActive);
        trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
        trigger.tabIndex = isActive ? 0 : -1;
      }
    };

    const swapCopy = (trigger: HTMLElement) => {
      if (!kickerTarget || !titleTarget || !descriptionTarget) return;
      const next = {
        kicker: trigger.dataset.kicker ?? '',
        title: trigger.dataset.title ?? '',
        description: trigger.dataset.description ?? '',
      };

      if (prefersReducedMotion) {
        kickerTarget.textContent = next.kicker;
        titleTarget.textContent = next.title;
        descriptionTarget.textContent = next.description;
        return;
      }

      gsap
        .timeline({ defaults: { ease: 'power2.out' } })
        .to([kickerTarget, titleTarget, descriptionTarget], { autoAlpha: 0, y: 6, duration: 0.14, stagger: 0.02 })
        .add(() => {
          kickerTarget.textContent = next.kicker;
          titleTarget.textContent = next.title;
          descriptionTarget.textContent = next.description;
        })
        .to([kickerTarget, titleTarget, descriptionTarget], { autoAlpha: 1, y: 0, duration: 0.2, stagger: 0.03 });
    };

    const showPanel = (trigger: HTMLElement) => {
      const nextId = trigger.dataset.domainId;
      if (!nextId || nextId === activeId) return;

      const currentPanel = panels.find((panel) => panel.dataset.showcasePanel === activeId);
      const nextPanel = panels.find((panel) => panel.dataset.showcasePanel === nextId);
      if (!nextPanel) return;

      if (prefersReducedMotion) {
        if (currentPanel) currentPanel.hidden = true;
        nextPanel.hidden = false;
        setActiveState(nextId);
        swapCopy(trigger);
        return;
      }

      nextPanel.hidden = false;
      gsap.set(nextPanel, { autoAlpha: 0, y: 12 });

      gsap.timeline({
        defaults: { ease: 'power2.out' },
        onStart: () => {
          setActiveState(nextId);
          swapCopy(trigger);
        },
        onComplete: () => {
          if (currentPanel) currentPanel.hidden = true;
          gsap.set([currentPanel, nextPanel], { clearProps: 'opacity,visibility,transform' });
        },
      })
        .to(currentPanel, { autoAlpha: 0, y: -10, duration: 0.16 })
        .to(nextPanel, { autoAlpha: 1, y: 0, duration: 0.2 }, '-=0.04');
    };

    const populateOverlay = (domainId: string) => {
      if (!overlayPreview || !overlayKicker || !overlayTitle || !overlayWhat || !overlayWhy || !overlayValue) return;
      const activeTrigger = triggers.find((trigger) => trigger.dataset.domainId === domainId);
      const activePanel = panels.find((panel) => panel.dataset.showcasePanel === domainId);
      if (!activeTrigger || !activePanel) return;

      overlayKicker.textContent = activeTrigger.dataset.kicker ?? '';
      overlayTitle.textContent = activeTrigger.dataset.title ?? '';
      overlayWhat.textContent = activeTrigger.dataset.overlayWhat ?? '';
      overlayWhy.textContent = activeTrigger.dataset.overlayWhy ?? '';
      overlayValue.textContent = activeTrigger.dataset.overlayValue ?? '';

      const clone = activePanel.cloneNode(true);
      if (clone instanceof HTMLElement) {
        clone.hidden = false;
        overlayPreview.replaceChildren(clone);
      }
    };

    const openOverlay = (domainId: string = activeId) => {
      if (!overlay || !overlayPanel) return;
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      populateOverlay(domainId);
      overlay.hidden = false;
      overlay.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';

      if (prefersReducedMotion) {
        overlayPanel.focus();
        return;
      }

      gsap.set(overlayPanel, { autoAlpha: 0, y: 18, scale: 0.985 });
      gsap.to(overlayPanel, { autoAlpha: 1, y: 0, scale: 1, duration: 0.22, ease: 'power2.out' });
      overlayPanel.focus();
    };

    const closeOverlay = () => {
      if (!overlay || !overlayPanel) return;

      const completeClose = () => {
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
        if (lastFocused) lastFocused.focus();
      };

      if (prefersReducedMotion) {
        completeClose();
        return;
      }

      gsap.to(overlayPanel, {
        autoAlpha: 0,
        y: 12,
        scale: 0.99,
        duration: 0.18,
        ease: 'power2.in',
        onComplete: completeClose,
      });
    };

    for (const trigger of triggers) {
      trigger.addEventListener('click', () => {
        showPanel(trigger);
      });
      trigger.addEventListener('keydown', (event) => {
        if (!(event instanceof KeyboardEvent)) return;
        const currentIndex = triggers.indexOf(trigger);
        if (event.key === 'ArrowDown' || event.key === 'ArrowRight') {
          event.preventDefault();
          const nextTrigger = triggers[(currentIndex + 1) % triggers.length];
          nextTrigger.focus();
          showPanel(nextTrigger);
        }
        if (event.key === 'ArrowUp' || event.key === 'ArrowLeft') {
          event.preventDefault();
          const nextTrigger = triggers[(currentIndex - 1 + triggers.length) % triggers.length];
          nextTrigger.focus();
          showPanel(nextTrigger);
        }
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openOverlay();
        }
      });
    }

    openButton?.addEventListener('click', openOverlay);
    for (const closeButton of closeButtons) closeButton.addEventListener('click', closeOverlay);
    overlay?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key === 'Escape') closeOverlay();
    });

    if (prefersReducedMotion) continue;

    gsap.set([intro, shell], { autoAlpha: 0, y: 18 });

    gsap.timeline({
      defaults: { ease: 'power2.out' },
      scrollTrigger: {
        trigger: block,
        start: 'top 72%',
        once: true,
      },
      onComplete: () => {
        gsap.set([intro, shell], { clearProps: 'opacity,visibility,transform' });
      },
    })
      .to(intro, { autoAlpha: 1, y: 0, duration: 0.44 })
      .to(shell, { autoAlpha: 1, y: 0, duration: 0.52 }, '-=0.24');
  }
</script>

