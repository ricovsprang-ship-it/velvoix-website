---
import type { SnapshotSectionContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: SnapshotSectionContent;
}

const { content: _content } = Astro.props;
const isEnglish = Astro.url.pathname.startsWith('/en');

const sectionContent = isEnglish
  ? {
      eyebrow: 'Product Showcase',
      title: 'A controlled view into the platform',
      description:
        'A calm product tour through the screens that make the operational difference: events, context, follow-up, management and governance.',
      supporting:
        'A curated tour, not a document viewer: readable desktop views that show how Velvoix keeps worklist, context and operational control together.',
      cta: 'Open fullscreen platform tour',
      previewLabel: 'Preview',
      previewTitle: 'Nine curated desktop views',
      previewBody:
        'From worklist to event detail, assignment, handling, management and governance.',
      overlayLabel: 'Platform tour',
      counterLabel: 'Slide',
      closeLabel: 'Close',
      previousLabel: 'Previous',
      nextLabel: 'Next',
      railLabel: 'Tour sections',
      slides: [
        {
          id: 'login',
          label: 'Start',
          title: 'A calm entry into the platform',
          text: 'Velvoix starts with a clear and quiet entry point into the operational workflow.',
          image: '/products/platformtour/login.png',
          alt: 'Velvoix login screen',
        },
        {
          id: 'worklist',
          label: 'Worklist',
          title: 'Events that stay workable',
          text: 'Urgency, status and actions remain readable so teams can act faster without losing context.',
          image: '/products/platformtour/worklist.png',
          alt: 'Velvoix events worklist',
        },
        {
          id: 'event-detail',
          label: 'Event Detail',
          title: 'Why, action and context together',
          text: 'The event detail view keeps reason, context, timeline and actions together in one operational object.',
          image: '/products/platformtour/event-detail.png',
          alt: 'Velvoix event detail screen',
        },
        {
          id: 'assign',
          label: 'Assign',
          title: 'Link the right colleague quickly',
          text: 'Assignment stays calm and targeted without forcing teams to leave the event context.',
          image: '/products/platformtour/assign.png',
          alt: 'Velvoix assignment dialog',
        },
        {
          id: 'handover',
          label: 'Handling',
          title: 'Transfer and resolve with a clear reason',
          text: 'Transfer and completion remain structured, explainable and suitable for logging and audit.',
          image: '/products/platformtour/handover.png',
          alt: 'Velvoix handover and completion dialog',
        },
        {
          id: 'client-context',
          label: 'Client Context',
          title: 'Relevant context in one place',
          text: 'Care context, privacy boundaries and contact information remain directly available for safe follow-up.',
          image: '/products/platformtour/client-context.png',
          alt: 'Velvoix client context view',
        },
        {
          id: 'care-overview',
          label: 'Care Overview',
          title: 'Management flow instead of dashboard noise',
          text: 'Operational insight shows where pressure, trend and SLA risk rise most clearly.',
          image: '/products/platformtour/care-overview.png',
          alt: 'Velvoix care overview dashboard',
        },
        {
          id: 'management',
          label: 'Management',
          title: 'Control that remains calm and purposeful',
          text: 'Linking, availability and work order stay understandable without turning management into a burden.',
          image: '/products/platformtour/management.png',
          alt: 'Velvoix management and linking view',
        },
        {
          id: 'governance',
          label: 'Governance',
          title: 'Governance stays visible and manageable',
          text: 'Profiles, quality and the technical foundation remain understandable without overloading the work floor.',
          image: '/products/platformtour/governance.png',
          alt: 'Velvoix governance and profile view',
        },
      ],
    }
  : {
      eyebrow: 'Productshowcase',
      title: 'Een gecontroleerd inkijkje in het platform',
      description:
        'Een rustige producttour langs de schermen die in de dagelijkse operatie het verschil maken: events, context, opvolging, beheer en governance.',
      supporting:
        'Een gecureerde tour, geen documentviewer: leesbare desktopweergaven die laten zien hoe Velvoix werkvoorraad, context en operationele controle samenhoudt.',
      cta: 'Open fullscreen platformtour',
      previewLabel: 'Preview',
      previewTitle: 'Negen gecureerde desktopweergaven',
      previewBody:
        'Van werkvoorraad tot eventdetail, toewijzen, afhandeling, beheer en governance.',
      overlayLabel: 'Platformtour',
      counterLabel: 'Slide',
      closeLabel: 'Sluiten',
      previousLabel: 'Vorige',
      nextLabel: 'Volgende',
      railLabel: 'Onderdelen van de tour',
      slides: [
        {
          id: 'login',
          label: 'Start',
          title: 'Rustige instap in het platform',
          text: 'Velvoix begint met een duidelijke en rustige toegang tot de operationele workflow.',
          image: '/products/platformtour/login.png',
          alt: 'Velvoix login scherm',
        },
        {
          id: 'worklist',
          label: 'Werkvoorraad',
          title: 'Meldingen die werkbaar blijven',
          text: 'Urgentie, status en acties blijven helder zodat teams sneller kunnen handelen zonder contextverlies.',
          image: '/products/platformtour/worklist.png',
          alt: 'Velvoix meldingenlijst',
        },
        {
          id: 'event-detail',
          label: 'Eventdetail',
          title: 'Waarom, aanpak en onderbouwing samen',
          text: 'De melddetailpagina bundelt reden, context, tijdlijn en acties in een operationeel object.',
          image: '/products/platformtour/event-detail.png',
          alt: 'Velvoix eventdetailpagina',
        },
        {
          id: 'assign',
          label: 'Toewijzen',
          title: 'Snel de juiste collega koppelen',
          text: 'Toewijzen blijft rustig en doelgericht zonder de melddetailcontext te verlaten.',
          image: '/products/platformtour/assign.png',
          alt: 'Velvoix toewijzen dialoog',
        },
        {
          id: 'handover',
          label: 'Afhandeling',
          title: 'Overdragen en afhandelen met duidelijke reden',
          text: 'Overdracht en afhandeling blijven gestructureerd, uitlegbaar en geschikt voor log en audit.',
          image: '/products/platformtour/handover.png',
          alt: 'Velvoix overdracht- en afhandelingsdialoog',
        },
        {
          id: 'client-context',
          label: 'Cliëntcontext',
          title: 'Relevante context op één plek',
          text: 'Zorgcontext, privacygrenzen en contactinformatie blijven direct beschikbaar voor veilige opvolging.',
          image: '/products/platformtour/client-context.png',
          alt: 'Velvoix cliëntcontext',
        },
        {
          id: 'care-overview',
          label: 'Zorgoverzicht',
          title: 'Managementflow in plaats van losse dashboards',
          text: 'Operationeel inzicht maakt zichtbaar waar druk, trend en SLA-risico het meest oplopen.',
          image: '/products/platformtour/care-overview.png',
          alt: 'Velvoix zorgoverzicht',
        },
        {
          id: 'management',
          label: 'Koppelingen',
          title: 'Beheer dat rustig en doelgericht blijft',
          text: 'Koppelingen, beschikbaarheid en werkvolgorde blijven overzichtelijk zonder beheerdrukte.',
          image: '/products/platformtour/management.png',
          alt: 'Velvoix beheer en koppelingen',
        },
        {
          id: 'governance',
          label: 'Governance',
          title: 'Governance zichtbaar en beheersbaar',
          text: 'Profielen, kwaliteit en technische basis blijven inzichtelijk zonder de werkvloer te overladen.',
          image: '/products/platformtour/governance.png',
          alt: 'Velvoix governance en kernprofielen',
        },
      ],
    };

const previewSlide = sectionContent.slides[2];
---

<section class="section-block" data-platform-tour>
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.42fr_0.58fr] lg:items-center">
      <div class="max-w-[33rem]" data-platform-tour-intro>
        <SectionIntro eyebrow={sectionContent.eyebrow} title={sectionContent.title} description={sectionContent.description} />
        <p class="mt-5 max-w-[31rem] text-sm leading-6 text-slate-500">{sectionContent.supporting}</p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <button type="button" class="platform-tour-button" data-tour-open>
            {sectionContent.cta}
          </button>
          <span class="platform-tour-footnote">
            {sectionContent.slides.length} {isEnglish ? 'curated views' : 'gecureerde schermen'}
          </span>
        </div>
      </div>

      <div class="platform-tour-teaser" data-platform-tour-teaser>
        <div class="platform-tour-teaser__frame">
          <img
            src={previewSlide.image}
            alt={previewSlide.alt}
            class="platform-tour-teaser__image"
            loading="lazy"
            decoding="async"
          />
          <div class="platform-tour-teaser__copy">
            <p class="platform-tour-teaser__label">{sectionContent.previewLabel}</p>
            <h3>{sectionContent.previewTitle}</h3>
            <p>{sectionContent.previewBody}</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="platform-tour-overlay" data-tour-overlay hidden aria-hidden="true">
    <div class="platform-tour-overlay__backdrop" data-tour-close></div>
    <div
      class="platform-tour-overlay__panel"
      data-tour-panel
      role="dialog"
      aria-modal="true"
      aria-labelledby="platform-tour-title"
      tabindex="-1"
    >
      <header class="platform-tour-overlay__header">
        <div class="platform-tour-overlay__meta">
          <p class="platform-tour-overlay__eyebrow">{sectionContent.overlayLabel}</p>
          <div class="platform-tour-overlay__counter">
            <span data-tour-counter-current>1</span>
            <span>/</span>
            <span>{sectionContent.slides.length}</span>
          </div>
        </div>
        <div class="platform-tour-overlay__actions">
          <button type="button" class="platform-tour-nav is-ghost" data-tour-prev>{sectionContent.previousLabel}</button>
          <button type="button" class="platform-tour-nav is-ghost" data-tour-next>{sectionContent.nextLabel}</button>
          <button type="button" class="platform-tour-close" data-tour-close>{sectionContent.closeLabel}</button>
        </div>
      </header>

      <div class="platform-tour-overlay__body">
        <div class="platform-tour-stage" data-tour-stage>
          {sectionContent.slides.map((slide, index) => (
            <article class="platform-tour-slide" data-tour-slide data-slide-id={slide.id} hidden={index !== 0}>
              <figure class="platform-tour-slide__figure">
                <img src={slide.image} alt={slide.alt} loading="lazy" decoding="async" />
              </figure>
            </article>
          ))}
        </div>

        <aside class="platform-tour-copy">
          <div class="platform-tour-copy__main">
            <p class="platform-tour-copy__label" data-tour-label>{sectionContent.slides[0].label}</p>
            <h3 id="platform-tour-title" data-tour-title>{sectionContent.slides[0].title}</h3>
            <p data-tour-text>{sectionContent.slides[0].text}</p>
          </div>

          <nav class="platform-tour-rail" aria-label={sectionContent.railLabel}>
            {sectionContent.slides.map((slide, index) => (
              <button
                type="button"
                class:list={['platform-tour-rail__item', index === 0 && 'is-active']}
                data-tour-jump={index}
                aria-current={index === 0 ? 'true' : 'false'}
              >
                <span class="platform-tour-rail__index">{String(index + 1).padStart(2, '0')}</span>
                <span class="platform-tour-rail__copy">
                  <strong>{slide.label}</strong>
                  <span>{slide.title}</span>
                </span>
              </button>
            ))}
          </nav>
        </aside>
      </div>
    </div>
  </div>
</section>

<style>
  [data-platform-tour] .platform-tour-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.78rem 1.24rem;
    border-radius: 0.9rem;
    border: 1px solid rgba(22, 36, 64, 0.14);
    background: rgb(19 44 82);
    color: rgba(248, 250, 252, 0.98);
    font-size: 0.92rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    transition: background-color 160ms ease, transform 160ms ease;
  }

  [data-platform-tour] .platform-tour-button:hover,
  [data-platform-tour] .platform-tour-button:focus-visible {
    background: rgb(15 36 70);
    transform: translateY(-1px);
  }

  [data-platform-tour] .platform-tour-footnote {
    font-size: 0.83rem;
    font-weight: 600;
    color: rgb(100 116 139);
  }

  [data-platform-tour] .platform-tour-teaser__frame {
    position: relative;
    overflow: hidden;
    border-radius: 1.5rem;
    border: 1px solid rgba(218, 226, 236, 0.92);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 250, 252, 0.98));
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
  }

  [data-platform-tour] .platform-tour-teaser__image {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 10.2;
    object-fit: cover;
    object-position: top center;
  }

  [data-platform-tour] .platform-tour-teaser__copy {
    position: absolute;
    left: 1.25rem;
    bottom: 1.25rem;
    max-width: min(28rem, calc(100% - 2.5rem));
    padding: 1rem 1.05rem;
    border: 1px solid rgba(214, 223, 233, 0.94);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(10px);
    box-shadow: 0 16px 34px rgba(15, 23, 42, 0.08);
  }

  [data-platform-tour] .platform-tour-teaser__label,
  [data-platform-tour] .platform-tour-overlay__eyebrow,
  [data-platform-tour] .platform-tour-copy__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-teaser__copy h3 {
    margin-top: 0.45rem;
    font-size: clamp(1.35rem, 2.2vw, 1.7rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
  }

  [data-platform-tour] .platform-tour-teaser__copy p:last-child {
    margin-top: 0.45rem;
    font-size: 0.96rem;
    line-height: 1.65;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-overlay[hidden] {
    display: none;
  }

  [data-platform-tour] .platform-tour-overlay {
    position: fixed;
    inset: 0;
    z-index: 90;
    display: grid;
    place-items: center;
    padding: 1.4rem;
  }

  [data-platform-tour] .platform-tour-overlay__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.54);
    backdrop-filter: blur(7px);
  }

  [data-platform-tour] .platform-tour-overlay__panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    width: min(1360px, calc(100vw - 2.8rem));
    max-height: calc(100vh - 2.8rem);
    overflow: hidden;
    border: 1px solid rgba(214, 223, 233, 0.96);
    border-radius: 1.45rem;
    background: linear-gradient(180deg, rgba(251, 253, 255, 0.98), rgba(243, 248, 251, 0.98));
    box-shadow: 0 30px 72px rgba(15, 23, 42, 0.24);
  }

  [data-platform-tour] .platform-tour-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.05rem 1.15rem;
    border-bottom: 1px solid rgba(224, 231, 239, 0.92);
  }

  [data-platform-tour] .platform-tour-overlay__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    min-width: 0;
  }

  [data-platform-tour] .platform-tour-overlay__counter {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(216, 224, 232, 0.96);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.92);
    font-size: 0.82rem;
    font-weight: 700;
    color: rgb(51 65 85);
  }

  [data-platform-tour] .platform-tour-overlay__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  [data-platform-tour] .platform-tour-nav,
  [data-platform-tour] .platform-tour-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.5rem 0.95rem;
    border: 1px solid rgba(211, 220, 230, 0.96);
    border-radius: 0.9rem;
    background: rgba(255, 255, 255, 0.94);
    font-size: 0.86rem;
    font-weight: 600;
    color: rgb(30 41 59);
    transition: border-color 160ms ease, background-color 160ms ease, color 160ms ease;
  }

  [data-platform-tour] .platform-tour-nav:hover,
  [data-platform-tour] .platform-tour-nav:focus-visible,
  [data-platform-tour] .platform-tour-close:hover,
  [data-platform-tour] .platform-tour-close:focus-visible {
    border-color: rgba(20, 184, 166, 0.28);
    color: rgb(15 118 110);
    background: rgba(248, 252, 251, 0.98);
  }

  [data-platform-tour] .platform-tour-overlay__body {
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(22rem, 0.68fr);
    gap: 1.1rem;
    min-height: 0;
    padding: 1.15rem;
  }

  [data-platform-tour] .platform-tour-stage {
    min-width: 0;
    min-height: 0;
  }

  [data-platform-tour] .platform-tour-slide,
  [data-platform-tour] .platform-tour-slide__figure {
    height: 100%;
  }

  [data-platform-tour] .platform-tour-slide__figure {
    overflow: hidden;
    border: 1px solid rgba(216, 224, 232, 0.96);
    border-radius: 1.15rem;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.72);
  }

  [data-platform-tour] .platform-tour-slide__figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center top;
    background: linear-gradient(180deg, rgba(246, 249, 252, 1), rgba(241, 246, 250, 1));
  }

  [data-platform-tour] .platform-tour-copy {
    display: grid;
    grid-template-rows: auto minmax(0, 1fr);
    gap: 1rem;
    min-height: 0;
  }

  [data-platform-tour] .platform-tour-copy__main,
  [data-platform-tour] .platform-tour-rail {
    border: 1px solid rgba(216, 224, 232, 0.94);
    border-radius: 1.1rem;
    background: rgba(255, 255, 255, 0.94);
  }

  [data-platform-tour] .platform-tour-copy__main {
    padding: 1.1rem 1.05rem;
  }

  [data-platform-tour] .platform-tour-copy__main h3 {
    margin-top: 0.55rem;
    font-size: clamp(1.4rem, 2vw, 1.82rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
  }

  [data-platform-tour] .platform-tour-copy__main p:last-child {
    margin-top: 0.6rem;
    font-size: 0.97rem;
    line-height: 1.72;
    color: rgb(71 85 105);
  }

  [data-platform-tour] .platform-tour-rail {
    overflow: auto;
    padding: 0.35rem;
  }

  [data-platform-tour] .platform-tour-rail__item {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    width: 100%;
    padding: 0.86rem 0.88rem;
    border: 1px solid transparent;
    border-radius: 0.9rem;
    background: transparent;
    text-align: left;
    transition: border-color 160ms ease, background-color 160ms ease, transform 160ms ease;
  }

  [data-platform-tour] .platform-tour-rail__item + .platform-tour-rail__item {
    margin-top: 0.28rem;
  }

  [data-platform-tour] .platform-tour-rail__item:hover,
  [data-platform-tour] .platform-tour-rail__item:focus-visible {
    border-color: rgba(203, 213, 225, 0.94);
    background: rgba(248, 250, 252, 0.88);
  }

  [data-platform-tour] .platform-tour-rail__item.is-active {
    border-color: rgba(20, 184, 166, 0.22);
    background: rgba(244, 250, 249, 0.96);
  }

  [data-platform-tour] .platform-tour-rail__index {
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  [data-platform-tour] .platform-tour-rail__copy strong {
    display: block;
    font-size: 0.92rem;
    font-weight: 600;
    color: rgb(15 23 42);
  }

  [data-platform-tour] .platform-tour-rail__copy span {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.83rem;
    line-height: 1.5;
    color: rgb(71 85 105);
  }

  @media (max-width: 1023px) {
    [data-platform-tour] .platform-tour-overlay {
      padding: 0.9rem;
    }

    [data-platform-tour] .platform-tour-overlay__panel {
      width: calc(100vw - 1.8rem);
      max-height: calc(100vh - 1.8rem);
    }

    [data-platform-tour] .platform-tour-overlay__body {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      overflow: auto;
    }

    [data-platform-tour] .platform-tour-stage {
      min-height: 19rem;
    }

    [data-platform-tour] .platform-tour-slide__figure img {
      max-height: 54vh;
    }
  }

  @media (max-width: 767px) {
    [data-platform-tour] .platform-tour-teaser__copy {
      position: static;
      max-width: none;
      border-left: 0;
      border-right: 0;
      border-bottom: 0;
      border-radius: 0;
      background: rgba(255, 255, 255, 0.97);
      box-shadow: none;
      backdrop-filter: none;
    }

    [data-platform-tour] .platform-tour-overlay__header {
      flex-direction: column;
      align-items: flex-start;
    }

    [data-platform-tour] .platform-tour-overlay__actions {
      width: 100%;
      justify-content: space-between;
      flex-wrap: wrap;
    }

    [data-platform-tour] .platform-tour-nav,
    [data-platform-tour] .platform-tour-close {
      flex: 1 1 30%;
    }

    [data-platform-tour] .platform-tour-copy {
      grid-template-rows: auto auto;
    }

    [data-platform-tour] .platform-tour-rail {
      max-height: 15rem;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const blocks = document.querySelectorAll('[data-platform-tour]');

  for (const block of blocks) {
    if (!(block instanceof HTMLElement)) continue;
    if (block.dataset.bound === 'true') continue;
    block.dataset.bound = 'true';

    const intro = block.querySelector('[data-platform-tour-intro]');
    const teaser = block.querySelector('[data-platform-tour-teaser]');
    const openButton = block.querySelector('[data-tour-open]');
    const overlay = block.querySelector('[data-tour-overlay]');
    const panel = block.querySelector('[data-tour-panel]');
    const prevButton = block.querySelector('[data-tour-prev]');
    const nextButton = block.querySelector('[data-tour-next]');
    const closeButtons = block.querySelectorAll('[data-tour-close]');
    const counterCurrent = block.querySelector('[data-tour-counter-current]');
    const labelTarget = block.querySelector('[data-tour-label]');
    const titleTarget = block.querySelector('[data-tour-title]');
    const textTarget = block.querySelector('[data-tour-text]');
    const slides = Array.from(block.querySelectorAll('[data-tour-slide]'));
    const jumpButtons = Array.from(block.querySelectorAll('[data-tour-jump]'));
    const slideData = JSON.parse(JSON.stringify(sectionContent.slides));

    let activeIndex = 0;
    let lastFocused = null;

    const focusableSelector =
      'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';

    const updateRail = () => {
      jumpButtons.forEach((button, index) => {
        const isActive = index === activeIndex;
        button.classList.toggle('is-active', isActive);
        button.setAttribute('aria-current', isActive ? 'true' : 'false');
      });
    };

    const renderCopy = (index, animate) => {
      const slide = slideData[index];
      if (!(labelTarget instanceof HTMLElement) || !(titleTarget instanceof HTMLElement) || !(textTarget instanceof HTMLElement)) return;

      if (!animate || prefersReducedMotion) {
        labelTarget.textContent = slide.label;
        titleTarget.textContent = slide.title;
        textTarget.textContent = slide.text;
        return;
      }

      gsap
        .timeline({ defaults: { ease: 'power2.out' } })
        .to([labelTarget, titleTarget, textTarget], { autoAlpha: 0, y: 8, duration: 0.14, stagger: 0.03 })
        .add(() => {
          labelTarget.textContent = slide.label;
          titleTarget.textContent = slide.title;
          textTarget.textContent = slide.text;
        })
        .to([labelTarget, titleTarget, textTarget], { autoAlpha: 1, y: 0, duration: 0.2, stagger: 0.03 });
    };

    const renderSlide = (nextIndex, animate = true) => {
      if (nextIndex < 0 || nextIndex >= slides.length) return;
      const currentSlide = slides[activeIndex];
      const nextSlide = slides[nextIndex];
      if (!(nextSlide instanceof HTMLElement) || nextSlide === currentSlide) return;

      if (counterCurrent instanceof HTMLElement) counterCurrent.textContent = String(nextIndex + 1);

      if (!animate || prefersReducedMotion) {
        if (currentSlide instanceof HTMLElement) currentSlide.hidden = true;
        nextSlide.hidden = false;
        activeIndex = nextIndex;
        updateRail();
        renderCopy(nextIndex, false);
        return;
      }

      nextSlide.hidden = false;
      gsap.set(nextSlide, { autoAlpha: 0, y: 16 });

      gsap.timeline({
        defaults: { ease: 'power2.out' },
        onStart: () => {
          activeIndex = nextIndex;
          updateRail();
          renderCopy(nextIndex, true);
        },
        onComplete: () => {
          if (currentSlide instanceof HTMLElement) currentSlide.hidden = true;
          gsap.set([currentSlide, nextSlide], { clearProps: 'opacity,visibility,transform' });
        },
      })
        .to(currentSlide, { autoAlpha: 0, y: -10, duration: 0.18 })
        .to(nextSlide, { autoAlpha: 1, y: 0, duration: 0.24 }, '-=0.02');
    };

    const trapFocus = (event) => {
      if (!(event instanceof KeyboardEvent) || event.key !== 'Tab' || !(panel instanceof HTMLElement)) return;
      const focusables = Array.from(panel.querySelectorAll(focusableSelector)).filter(
        (element) => element instanceof HTMLElement && !element.hasAttribute('disabled')
      );
      if (!focusables.length) return;

      const first = focusables[0];
      const last = focusables[focusables.length - 1];

      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    const openOverlay = () => {
      if (!(overlay instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;
      lastFocused = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      overlay.hidden = false;
      overlay.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';

      if (prefersReducedMotion) {
        panel.focus();
        return;
      }

      gsap.set(panel, { autoAlpha: 0, y: 22, scale: 0.985 });
      gsap.to(panel, { autoAlpha: 1, y: 0, scale: 1, duration: 0.24, ease: 'power2.out' });
      panel.focus();
    };

    const closeOverlay = () => {
      if (!(overlay instanceof HTMLElement) || !(panel instanceof HTMLElement)) return;

      const finish = () => {
        overlay.hidden = true;
        overlay.setAttribute('aria-hidden', 'true');
        document.documentElement.style.overflow = '';
        if (lastFocused instanceof HTMLElement) lastFocused.focus();
      };

      if (prefersReducedMotion) {
        finish();
        return;
      }

      gsap.to(panel, {
        autoAlpha: 0,
        y: 12,
        scale: 0.99,
        duration: 0.18,
        ease: 'power2.in',
        onComplete: finish,
      });
    };

    renderSlide(0, false);

    openButton?.addEventListener('click', openOverlay);
    prevButton?.addEventListener('click', () => renderSlide((activeIndex - 1 + slides.length) % slides.length));
    nextButton?.addEventListener('click', () => renderSlide((activeIndex + 1) % slides.length));

    jumpButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextIndex = Number(button.getAttribute('data-tour-jump'));
        renderSlide(nextIndex);
      });
    });

    closeButtons.forEach((button) => button.addEventListener('click', closeOverlay));

    overlay?.addEventListener('keydown', (event) => {
      if (!(event instanceof KeyboardEvent)) return;
      if (event.key === 'Escape') closeOverlay();
      if (event.key === 'ArrowLeft') renderSlide((activeIndex - 1 + slides.length) % slides.length);
      if (event.key === 'ArrowRight') renderSlide((activeIndex + 1) % slides.length);
      trapFocus(event);
    });

    if (!prefersReducedMotion) {
      gsap.set([intro, teaser], { autoAlpha: 0, y: 20 });

      gsap
        .timeline({
          defaults: { ease: 'power2.out' },
          scrollTrigger: {
            trigger: block,
            start: 'top 72%',
            once: true,
          },
          onComplete: () => {
            gsap.set([intro, teaser], { clearProps: 'opacity,visibility,transform' });
          },
        })
        .to(intro, { autoAlpha: 1, y: 0, duration: 0.42 })
        .to(teaser, { autoAlpha: 1, y: 0, duration: 0.5 }, '-=0.22');
    }
  }
</script>
