---
import type { SnapshotSectionContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: SnapshotSectionContent;
}

const { content } = Astro.props;
const isEnglish = Astro.url.pathname.startsWith('/en');

const sectionContent = isEnglish
  ? {
      eyebrow: 'Product showcase',
      title: 'A controlled view into the platform',
      description:
        'Velvoix does not only surface signals, but keeps event truth, explainable follow-up, management and reconstruction together in one care-oriented operational environment.',
      supporting:
        'Not full screens, but readable desktop fragments that show how one operational truth carries status, explanation, ownership and management together.',
      domains: [
        { id: 'event-page', label: 'Event Page', kicker: 'Worklist', title: 'One operational event truth instead of loose signals', description: 'Urgency, resident context, recommended action and status stay tied to the same workable event.' },
        { id: 'handling', label: 'Handling', kicker: 'Follow-up', title: 'Explainability, SLA and action in one follow-up surface', description: 'Recommended action, ownership, transfer and completion stay part of the same operational object.' },
        { id: 'box-management', label: 'Box Management', kicker: 'Control', title: 'Management that stays controlled across rooms and devices', description: 'Box state, resident linking and availability stay visible in a role-aware management layer.' },
        { id: 'technical-insight', label: 'Technical Insight', kicker: 'Governance', title: 'Governance and observability without exposing internals', description: 'Publication state, active configuration and operational visibility stay clear without revealing product internals.' },
        { id: 'kpi-overview', label: 'KPI Overview', kicker: 'Steering', title: 'Steering from backend truth, not dashboard noise', description: 'Open events, SLA performance and escalations stay readable as operational steering rather than dashboard clutter.' },
        { id: 'client-history', label: 'Client History', kicker: 'Context', title: 'Reconstruction stays close to resident context', description: 'Recent events, follow-up history and pattern context stay connected instead of being spread across systems.' },
      ],
    }
  : {
      eyebrow: 'Productshowcase',
      title: 'Een gecontroleerd inkijkje in het platform',
      description:
        'Velvoix toont niet alleen signalen, maar houdt eventwaarheid, uitlegbare opvolging, beheer en reconstructie samen in een zorggerichte operationele omgeving.',
      supporting:
        'Geen volledige schermen, maar leesbare desktopfragmenten die laten zien hoe status, uitleg, eigenaarschap en beheer op een operationele waarheid samenkomen.',
      domains: [
        { id: 'event-page', label: 'Eventpagina', kicker: 'Werkvoorraad', title: 'Een operationele eventwaarheid in plaats van losse signalen', description: 'Urgentie, bewonercontext, aanbevolen aanpak en status blijven gekoppeld aan hetzelfde werkbare event.' },
        { id: 'handling', label: 'Afhandeling', kicker: 'Opvolging', title: 'Uitleg, SLA en actie in een werkbaar afhandelvlak', description: 'Aanbevolen aanpak, eigenaarschap, overdracht en afronding blijven onderdeel van hetzelfde operationele object.' },
        { id: 'box-management', label: 'Boxbeheer', kicker: 'Beheer', title: 'Beheer dat gecontroleerd blijft over kamers en devices', description: 'Boxstatus, bewonerkoppeling en beschikbaarheid blijven zichtbaar in een rolzuivere beheerlaag.' },
        { id: 'technical-insight', label: 'Technisch inzicht', kicker: 'Besturing', title: 'Governance en observability zonder internals te tonen', description: 'Publicatiestatus, actieve configuratie en operationele zichtbaarheid blijven helder zonder productinternals prijs te geven.' },
        { id: 'kpi-overview', label: 'KPI-overzicht', kicker: 'Sturing', title: 'Sturen vanuit backend-truth, niet vanuit dashboardruis', description: 'Open events, SLA-prestatie en escalaties blijven leesbaar als operationele sturing in plaats van dashboarddrukte.' },
        { id: 'client-history', label: 'Cliënthistorie', kicker: 'Context', title: 'Reconstructie blijft dichtbij de bewonercontext', description: 'Recente events, opvolghistorie en patrooncontext blijven verbonden in plaats van verspreid over systemen.' },
      ],
    };

const firstDomain = sectionContent.domains[0];
const detailContent = isEnglish
  ? {
      openLabel: 'Open product detail',
      closeLabel: 'Close',
      whatTitle: 'What this shows',
      whyTitle: 'Why this matters',
      valueTitle: 'Operational value',
      domains: {
        'event-page': {
          what: 'A desktop worklist where queue, urgency, resident context, recommended action and status stay attached to the same event object.',
          why: 'This shows that Velvoix is not just a signal feed, but one operational truth that remains workable for teams.',
          value: 'Teams can scan faster and act with less interpretation burden because explanation and follow-up are already connected.',
        },
        handling: {
          what: 'A handling surface with recommended action, urgency, SLA, ownership and direct action controls in one place.',
          why: 'This proves that follow-up becomes workable inside the product, not something teams have to reconstruct from separate signals.',
          value: 'Ownership, transfer and completion remain manageable in daily care workflow.',
        },
        'box-management': {
          what: 'A management view for device state, resident linking, room assignment and last check-in.',
          why: 'This shows that operational control over hardware and care context stays governed instead of drifting into ad hoc admin work.',
          value: 'Support and care operations can manage availability and linking without fragmentation.',
        },
        'technical-insight': {
          what: 'A high-level governance view with active configuration, publication state and operational visibility.',
          why: 'This demonstrates observability and governance without exposing rulesets, phrase packs or other sensitive internals.',
          value: 'The platform remains governable, observable and operationally trustworthy.',
        },
        'kpi-overview': {
          what: 'A compact steering workspace with open events, SLA performance, escalations and workload context.',
          why: 'This shows that Velvoix supports operational steering from the same underlying event truth, not from disconnected dashboard layers.',
          value: 'Teams and managers can steer on follow-up quality without analytics overload.',
        },
        'client-history': {
          what: 'A resident-oriented history view that keeps recent events, follow-up and pattern context connected.',
          why: 'This shows how reconstruction stays close to resident context instead of being spread across systems and exports.',
          value: 'Care teams can understand patterns and follow-up history faster and with more confidence.',
        },
      },
    }
  : {
      openLabel: 'Open detailweergave',
      closeLabel: 'Sluiten',
      whatTitle: 'Wat laat dit zien',
      whyTitle: 'Waarom dit belangrijk is',
      valueTitle: 'Operationele waarde',
      domains: {
        'event-page': {
          what: 'Een desktopwerkvoorraad waarin queue, urgentie, bewonercontext, aanbevolen aanpak en status gekoppeld blijven aan hetzelfde eventobject.',
          why: 'Dit laat zien dat Velvoix niet alleen een signalenstroom is, maar een operationele waarheid die werkbaar blijft voor teams.',
          value: 'Teams kunnen sneller scannen en handelen met minder interpretatielast omdat uitleg en opvolging al samenkomen.',
        },
        handling: {
          what: 'Een afhandelscherm met aanbevolen aanpak, urgentie, SLA, eigenaarschap en directe actieknoppen in een vlak.',
          why: 'Dit bewijst dat opvolging werkbaar wordt binnen het product zelf en niet opnieuw moet worden opgebouwd uit losse signalen.',
          value: 'Eigenaarschap, overdracht en afronding blijven bestuurbaar in de dagelijkse zorgworkflow.',
        },
        'box-management': {
          what: 'Een beheerweergave voor devicestatus, bewonerkoppeling, kamerkoppeling en laatste check-in.',
          why: 'Dit laat zien dat operationele controle over hardware en zorgcontext beheerst blijft in plaats van te versnipperen in ad hoc beheerwerk.',
          value: 'Support en zorgteams kunnen beschikbaarheid en koppelingen beheren zonder versnippering.',
        },
        'technical-insight': {
          what: 'Een governanceweergave op hoofdlijnen met actieve configuratie, publicatiestatus en operationele zichtbaarheid in beeld.',
          why: 'Dit toont observability en beheerbaarheid zonder rulesets, phrase packs of andere gevoelige internals prijs te geven.',
          value: 'Het platform blijft bestuurbaar, observeerbaar en operationeel betrouwbaar.',
        },
        'kpi-overview': {
          what: 'Een compacte sturingsweergave met open events, SLA-prestatie, escalaties en werkvoorraadcontext.',
          why: 'Dit laat zien dat Velvoix ook operationele sturing ondersteunt vanuit dezelfde eventwaarheid, niet vanuit losse dashboardlagen.',
          value: 'Teams en managers kunnen sturen op opvolgkwaliteit zonder analytics-overload.',
        },
        'client-history': {
          what: 'Een clientgerichte historie waarin recente events, opvolging en patrooncontext verbonden blijven.',
          why: 'Dit laat zien hoe reconstructie dicht bij de bewonercontext blijft in plaats van verspreid te raken over systemen en exports.',
          value: 'Zorgteams begrijpen patronen en opvolghistorie sneller en met meer vertrouwen.',
        },
      },
    };
---

<section class="section-block" data-product-showcase>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.37fr_0.63fr] lg:items-start" data-showcase-locale={isEnglish ? 'en' : 'nl'}>
    <div class="max-w-[31rem]" data-showcase-intro>
      <SectionIntro eyebrow={sectionContent.eyebrow} title={sectionContent.title} description={sectionContent.description} />
      <p class="mt-5 max-w-[30rem] text-sm leading-6 text-slate-500">{sectionContent.supporting}</p>

      <div class="showcase-rail mt-8" role="tablist" aria-label={sectionContent.eyebrow}>
        {sectionContent.domains.map((domain, index) => (
          <button
            type="button"
            class:list={['showcase-rail-item', index === 0 && 'is-active']}
            data-showcase-trigger
            data-domain-id={domain.id}
            data-kicker={domain.kicker}
            data-title={domain.title}
            data-description={domain.description}
            data-overlay-what={detailContent.domains[domain.id as keyof typeof detailContent.domains].what}
            data-overlay-why={detailContent.domains[domain.id as keyof typeof detailContent.domains].why}
            data-overlay-value={detailContent.domains[domain.id as keyof typeof detailContent.domains].value}
            aria-selected={index === 0 ? 'true' : 'false'}
            tabindex={index === 0 ? '0' : '-1'}
          >
            <span class="showcase-rail-label">{domain.label}</span>
            <span class="showcase-rail-kicker">{domain.kicker}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="showcase-shell" data-showcase-shell>
      <div class="showcase-frame">
        <div class="showcase-frame-head">
          <div>
            <p class="showcase-kicker" data-showcase-kicker>{firstDomain.kicker}</p>
            <h3 class="showcase-title" data-showcase-title>{firstDomain.title}</h3>
          </div>
          <div class="showcase-head-actions">
            <p class="showcase-description" data-showcase-description>{firstDomain.description}</p>
            <button type="button" class="showcase-open-button" data-showcase-open>{detailContent.openLabel}</button>
          </div>
        </div>

        <div class="showcase-stage">
          <article class="showcase-panel" data-showcase-panel="event-page">
            <div class="product-workspace">
              <div class="workspace-topbar">
                <span class="workspace-chip">{isEnglish ? 'Events' : 'Eventpagina'}</span>
                <div class="workspace-topmeta">
                  <span>{isEnglish ? 'Current shift' : 'Huidige dienst'}</span>
                  <span>{isEnglish ? 'Updated 07:42' : 'Laatste update 07:42'}</span>
                </div>
              </div>
              <div class="workspace-grid workspace-grid--events">
                <aside class="workspace-sidebar">
                  <div class="workspace-sidebar-block">
                    <div class="workspace-label">{isEnglish ? 'Filters' : 'Filters'}</div>
                    <div class="workspace-filter-list">
                      <span class="workspace-filter">{isEnglish ? 'All departments' : 'Alle afdelingen'}</span>
                      <span class="workspace-filter is-active">{isEnglish ? 'Direct' : 'Direct'}</span>
                      <span class="workspace-filter">{isEnglish ? 'Open' : 'Open'}</span>
                    </div>
                  </div>
                  <div class="workspace-sidebar-block">
                    <div class="workspace-label">{isEnglish ? 'Queue' : 'Werkvoorraad'}</div>
                    <div class="workspace-kpi-stack">
                      <div><span>{isEnglish ? 'Open' : 'Open'}</span><strong>38</strong></div>
                      <div><span>{isEnglish ? 'In progress' : 'In behandeling'}</span><strong>11</strong></div>
                    </div>
                  </div>
                </aside>

                <section class="workspace-listpanel">
                  <div class="workspace-table-head">
                    <span>{isEnglish ? 'Resident' : 'Bewoner'}</span>
                    <span>{isEnglish ? 'Signal' : 'Signaal'}</span>
                    <span>{isEnglish ? 'Status' : 'Status'}</span>
                  </div>
                  <article class="workspace-table-row is-active">
                    <div>
                      <strong>{isEnglish ? 'Mrs Anna de Vries' : 'Mevrouw Anna de Vries'}</strong>
                      <span>{isEnglish ? 'Room 01A-001' : 'Kamer 01A-001'}</span>
                    </div>
                    <div>
                      <strong>{isEnglish ? 'Repeated help call' : 'Helpoproep herhaald'}</strong>
                      <span>07:39</span>
                    </div>
                    <div class="workspace-status-group">
                      <span class="workspace-ring workspace-ring--urgent">{isEnglish ? 'Direct' : 'Direct'}</span>
                      <span class="workspace-ring">{isEnglish ? 'Open' : 'Open'}</span>
                    </div>
                  </article>
                  <article class="workspace-table-row">
                    <div>
                      <strong>{isEnglish ? 'Mr Jan Willems' : 'Meneer Jan Willems'}</strong>
                      <span>{isEnglish ? 'Room 01A-008' : 'Kamer 01A-008'}</span>
                    </div>
                    <div>
                      <strong>{isEnglish ? 'Voice input' : 'Spraakinput'}</strong>
                      <span>07:31</span>
                    </div>
                    <div class="workspace-status-group">
                      <span class="workspace-ring workspace-ring--follow">{isEnglish ? 'Under monitoring' : 'Volgen'}</span>
                      <span class="workspace-ring">{isEnglish ? 'Assigned for follow-up' : 'Toegewezen'}</span>
                    </div>
                  </article>
                  <article class="workspace-table-row">
                    <div>
                      <strong>{isEnglish ? 'Mrs Lotte Bakker' : 'Mevrouw Lotte Bakker'}</strong>
                      <span>{isEnglish ? 'Room 01A-003' : 'Kamer 01A-003'}</span>
                    </div>
                    <div>
                      <strong>{isEnglish ? 'Movement signal outside pattern' : 'Bewegingssignaal buiten patroon'}</strong>
                      <span>07:18</span>
                    </div>
                    <div class="workspace-status-group">
                      <span class="workspace-ring workspace-ring--today">{isEnglish ? 'Today' : 'Vandaag'}</span>
                      <span class="workspace-ring">{isEnglish ? 'Visible to team' : 'Team zichtbaar'}</span>
                    </div>
                  </article>
                </section>

                <aside class="workspace-detail">
                  <div class="workspace-label">{isEnglish ? 'Selected event' : 'Geselecteerd event'}</div>
                  <h4>{isEnglish ? 'Recommended action' : 'Aanbevolen aanpak'}</h4>
                  <p>{isEnglish ? 'Go directly to the resident; check the situation.' : 'Ga direct naar bewoner; controleer situatie.'}</p>
                  <div class="workspace-detail-grid">
                    <div><span>{isEnglish ? 'Urgency' : 'Urgentie'}</span><strong>{isEnglish ? 'Direct' : 'Direct'}</strong></div>
                    <div><span>{isEnglish ? 'Why' : 'Waarom'}</span><strong>{isEnglish ? 'Repeated shortly' : 'Herhaald kort na elkaar'}</strong></div>
                    <div><span>{isEnglish ? 'Owner' : 'Eigenaar'}</span><strong>{isEnglish ? 'Unassigned' : 'Niet toegewezen'}</strong></div>
                  </div>
                </aside>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="handling" hidden>
            <div class="product-workspace">
              <div class="workspace-topbar">
                <span class="workspace-chip">{isEnglish ? 'Handling' : 'Afhandeling'}</span>
                <div class="workspace-topmeta"><span>{isEnglish ? 'Action flow' : 'Actieflow'}</span></div>
              </div>
              <div class="workspace-grid workspace-grid--handling">
                <section class="workspace-primary-card">
                  <div class="workspace-card-head">
                    <div class="workspace-label">{isEnglish ? 'Explainable triage' : 'Uitlegbare triage'}</div>
                    <span class="workspace-ring workspace-ring--urgent">{isEnglish ? 'Direct' : 'Direct'}</span>
                  </div>
                  <h4>{isEnglish ? 'Go directly to the resident; check the situation.' : 'Ga direct naar bewoner; controleer situatie.'}</h4>
                  <p>{isEnglish ? 'Repeat behaviour, context and urgency are combined into one workable next step.' : 'Herhaling, context en urgentie worden samengebracht tot een werkbare vervolgactie.'}</p>
                  <div class="workspace-detail-grid">
                    <div><span>{isEnglish ? 'SLA' : 'SLA'}</span><strong>{isEnglish ? 'Critical' : 'Kritisch'}</strong></div>
                    <div><span>{isEnglish ? 'Status' : 'Status'}</span><strong>{isEnglish ? 'Open' : 'Open'}</strong></div>
                    <div><span>{isEnglish ? 'Owner' : 'Eigenaar'}</span><strong>{isEnglish ? 'Unassigned' : 'Niet toegewezen'}</strong></div>
                  </div>
                  <div class="workspace-actionbar">
                    <button type="button" class="workspace-action workspace-action--primary">{isEnglish ? 'Take ownership' : 'Pak op'}</button>
                    <button type="button" class="workspace-action">{isEnglish ? 'Assign' : 'Toewijzen'}</button>
                    <button type="button" class="workspace-action">{isEnglish ? 'Transfer' : 'Overdragen'}</button>
                    <button type="button" class="workspace-action">{isEnglish ? 'Resolve' : 'Afhandelen'}</button>
                  </div>
                </section>

                <aside class="workspace-sidecolumn">
                  <section class="workspace-sidecard">
                    <div class="workspace-label">{isEnglish ? 'Status flow' : 'Statusverloop'}</div>
                    <div class="workspace-flowline">
                      <span class="workspace-flowstep is-active">{isEnglish ? 'Open' : 'Open'}</span>
                      <span class="workspace-flowstep">{isEnglish ? 'Claimed' : 'Opgepakt'}</span>
                      <span class="workspace-flowstep">{isEnglish ? 'Resolved' : 'Afgehandeld'}</span>
                    </div>
                  </section>
                  <section class="workspace-sidecard">
                    <div class="workspace-label">{isEnglish ? 'Assignment' : 'Toewijzing'}</div>
                    <div class="workspace-minirows">
                      <div><span>{isEnglish ? 'Team' : 'Team'}</span><strong>{isEnglish ? 'Somatic care' : 'Somatiek'}</strong></div>
                      <div><span>{isEnglish ? 'Current owner' : 'Huidige eigenaar'}</span><strong>{isEnglish ? 'Unassigned' : 'Niet toegewezen'}</strong></div>
                    </div>
                  </section>
                </aside>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="box-management" hidden>
            <div class="product-workspace">
              <div class="workspace-topbar">
                <span class="workspace-chip">{isEnglish ? 'Box management' : 'Boxbeheer'}</span>
                <div class="workspace-topmeta">
                  <button type="button" class="workspace-inline-action">{isEnglish ? 'Add box' : 'Box toevoegen'}</button>
                  <button type="button" class="workspace-inline-action">{isEnglish ? 'Bulk link' : 'Bulk koppelen'}</button>
                </div>
              </div>
              <div class="workspace-grid workspace-grid--management">
                <section class="workspace-listpanel">
                  <div class="workspace-table-head">
                    <span>{isEnglish ? 'Box' : 'Box'}</span>
                    <span>{isEnglish ? 'Resident / room' : 'Bewoner / kamer'}</span>
                    <span>{isEnglish ? 'State' : 'Status'}</span>
                  </div>
                  <article class="workspace-table-row is-active">
                    <div><strong>BX-01A-004</strong><span>Demo floor 01A</span></div>
                    <div><strong>{isEnglish ? 'Mrs L. Bakker' : 'Mevrouw L. Bakker'}</strong><span>{isEnglish ? 'Room 01A-004' : 'Kamer 01A-004'}</span></div>
                    <div class="workspace-status-group"><span class="workspace-ring">{isEnglish ? 'Online' : 'Online'}</span></div>
                  </article>
                  <article class="workspace-table-row">
                    <div><strong>BX-01A-006</strong><span>Demo floor 01A</span></div>
                    <div><strong>{isEnglish ? 'Available' : 'Beschikbaar'}</strong><span>{isEnglish ? 'Living room slot' : 'Woonkamerslot'}</span></div>
                    <div class="workspace-status-group"><span class="workspace-ring workspace-ring--today">{isEnglish ? 'Available' : 'Beschikbaar'}</span></div>
                  </article>
                  <article class="workspace-table-row">
                    <div><strong>BX-01A-009</strong><span>Demo floor 01A</span></div>
                    <div><strong>{isEnglish ? 'Check required' : 'Controle nodig'}</strong><span>{isEnglish ? 'Last seen 06:54' : 'Laatst gezien 06:54'}</span></div>
                    <div class="workspace-status-group"><span class="workspace-ring workspace-ring--urgent">{isEnglish ? 'Offline' : 'Offline'}</span></div>
                  </article>
                </section>

                <aside class="workspace-detail">
                  <div class="workspace-label">{isEnglish ? 'Link detail' : 'Koppeldetail'}</div>
                  <h4>BX-01A-004</h4>
                  <div class="workspace-detail-grid">
                    <div><span>{isEnglish ? 'Resident' : 'Bewoner'}</span><strong>{isEnglish ? 'Mrs L. Bakker' : 'Mevrouw L. Bakker'}</strong></div>
                    <div><span>{isEnglish ? 'Room' : 'Kamer'}</span><strong>01A-004</strong></div>
                    <div><span>{isEnglish ? 'Last check-in' : 'Laatste check-in'}</span><strong>07:11</strong></div>
                  </div>
                </aside>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="technical-insight" hidden>
            <div class="product-workspace">
              <div class="workspace-topbar">
                <span class="workspace-chip">{isEnglish ? 'Technical Insight' : 'Technisch inzicht'}</span>
                <div class="workspace-topmeta"><span>{isEnglish ? 'High-level governance only' : 'Alleen hoofdlijnen'}</span></div>
              </div>
              <div class="workspace-grid workspace-grid--technical">
                <section class="workspace-primary-card">
                  <div class="workspace-metricrow">
                    <div class="workspace-metriccard"><span>{isEnglish ? 'Publication' : 'Publicatie'}</span><strong>{isEnglish ? 'Active' : 'Actief'}</strong></div>
                    <div class="workspace-metriccard"><span>{isEnglish ? 'Explainability' : 'Uitlegbaarheid'}</span><strong>{isEnglish ? 'Visible' : 'Zichtbaar'}</strong></div>
                  </div>
                  <div class="workspace-table-head">
                    <span>{isEnglish ? 'Control area' : 'Beheerlaag'}</span>
                    <span>{isEnglish ? 'State' : 'Status'}</span>
                  </div>
                  <article class="workspace-table-row"><div><strong>{isEnglish ? 'Active configuration' : 'Actieve configuratie'}</strong></div><div class="workspace-status-group"><span class="workspace-ring">{isEnglish ? 'Published' : 'Gepubliceerd'}</span></div></article>
                  <article class="workspace-table-row"><div><strong>{isEnglish ? 'Triage governance' : 'Triagegovernance'}</strong></div><div class="workspace-status-group"><span class="workspace-ring">{isEnglish ? 'Managed' : 'Beheerst'}</span></div></article>
                  <article class="workspace-table-row"><div><strong>{isEnglish ? 'Version control' : 'Versiebeheer'}</strong></div><div class="workspace-status-group"><span class="workspace-ring">{isEnglish ? 'Traceable' : 'Herleidbaar'}</span></div></article>
                </section>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="kpi-overview" hidden>
            <div class="product-workspace">
              <div class="workspace-topbar">
                <span class="workspace-chip">{isEnglish ? 'KPI overview' : 'KPI-overzicht'}</span>
                <div class="workspace-topmeta"><span>{isEnglish ? 'Operational steering' : 'Operationele sturing'}</span></div>
              </div>
              <div class="workspace-grid workspace-grid--kpi">
                <section class="workspace-metricrow">
                  <article class="workspace-metriccard"><span>{isEnglish ? 'Open events' : 'Open events'}</span><strong>38</strong></article>
                  <article class="workspace-metriccard"><span>{isEnglish ? 'Avg. response time' : 'Gem. opvolgtijd'}</span><strong>4m 12s</strong></article>
                  <article class="workspace-metriccard"><span>{isEnglish ? 'Within SLA' : 'Binnen SLA'}</span><strong>94%</strong></article>
                  <article class="workspace-metriccard"><span>{isEnglish ? 'Escalations' : 'Escalaties'}</span><strong>3</strong></article>
                </section>
                <section class="workspace-grid workspace-grid--kpi-detail">
                  <div class="workspace-sidecard">
                    <div class="workspace-label">{isEnglish ? 'Current workload' : 'Huidige werkvoorraad'}</div>
                    <div class="workspace-minirows">
                      <div><span>{isEnglish ? 'Direct' : 'Direct'}</span><strong>12</strong></div>
                      <div><span>{isEnglish ? 'In progress' : 'In behandeling'}</span><strong>11</strong></div>
                      <div><span>{isEnglish ? 'Escalated' : 'Geëscaleerd'}</span><strong>3</strong></div>
                    </div>
                  </div>
                  <div class="workspace-sidecard">
                    <div class="workspace-label">{isEnglish ? 'Follow-up quality' : 'Opvolgkwaliteit'}</div>
                    <div class="workspace-minirows">
                      <div><span>{isEnglish ? 'Claimed in SLA' : 'Op tijd opgepakt'}</span><strong>94%</strong></div>
