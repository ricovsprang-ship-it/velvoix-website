---
import type { SnapshotSectionContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: SnapshotSectionContent;
}

const { content } = Astro.props;
const isEnglish = content.eyebrow.toLowerCase().includes('product');

const sectionContent = isEnglish
  ? {
      eyebrow: 'Product showcase',
      title: 'A controlled view into the platform',
      description:
        'Velvoix does not only surface signals, but brings triage, follow-up, management and reconstruction together in one care-oriented operational environment.',
      supporting:
        'Not full screens, but readable product fragments that show how operational clarity, explainability and control come together.',
      domains: [
        {
          id: 'event-page',
          label: 'Event page',
          kicker: 'Operations',
          title: 'Scannable event worklist',
          description: 'Residents, urgency, room and signal remain directly readable in one calm worklist.',
        },
        {
          id: 'handling',
          label: 'Handling',
          kicker: 'Follow-up',
          title: 'Workable action and ownership',
          description: 'Recommended action, SLA status and handling decisions stay structured and immediately usable.',
        },
        {
          id: 'box-management',
          label: 'Box management',
          kicker: 'Control',
          title: 'Operational control over devices and linking',
          description: 'Device status, resident linking and room assignment remain manageable without becoming technical noise.',
        },
        {
          id: 'technical-insight',
          label: 'Technical insight',
          kicker: 'Governance',
          title: 'Managed configuration at a high level',
          description: 'Publication state, active configuration and explainability governance stay visible without exposing internals.',
        },
        {
          id: 'kpi-overview',
          label: 'KPI overview',
          kicker: 'Steering',
          title: 'Operational steering without analytics overload',
          description: 'A small set of metrics keeps attention on open workload, response performance and escalations.',
        },
        {
          id: 'client-history',
          label: 'Client history',
          kicker: 'Context',
          title: 'Recent signal and follow-up history in one line of sight',
          description: 'Recent events and follow-up stay readable as a calm history, not as fragmented notes.',
        },
      ],
    }
  : {
      eyebrow: 'Productshowcase',
      title: 'Een gecontroleerd inkijkje in het platform',
      description:
        'Velvoix toont niet alleen signalen, maar brengt triage, opvolging, beheer en reconstructie samen in één zorggerichte operationele omgeving.',
      supporting:
        'Niet volledige schermen, maar leesbare productfragmenten die laten zien hoe operationele duidelijkheid, explainability en beheer samenkomen.',
      domains: [
        {
          id: 'event-page',
          label: 'Eventpagina',
          kicker: 'Operations',
          title: 'Scanbare eventwerkvoorraad',
          description: 'Bewoner, urgentie, kamer en kernsignaal blijven direct leesbaar in één rustige worklist.',
        },
        {
          id: 'handling',
          label: 'Afhandeling',
          kicker: 'Follow-up',
          title: 'Werkbare aanpak en eigenaarschap',
          description: 'Aanbevolen aanpak, SLA-status en afhandelkeuzes blijven gestructureerd en direct bruikbaar.',
        },
        {
          id: 'box-management',
          label: 'Boxbeheer',
          kicker: 'Control',
          title: 'Operationele controle op devices en koppelingen',
          description: 'Boxstatus, bewonerkoppeling en kamertoewijzing blijven beheersbaar zonder technische ruis te worden.',
        },
        {
          id: 'technical-insight',
          label: 'Technisch inzicht',
          kicker: 'Governance',
          title: 'Beheerste configuratie op hoofdlijnen',
          description: 'Publicatiestatus, actieve configuratie en explainability-governance blijven zichtbaar zonder internals prijs te geven.',
        },
        {
          id: 'kpi-overview',
          label: 'KPI-overzicht',
          kicker: 'Sturing',
          title: 'Operationele sturing zonder analytics-overload',
          description: 'Een kleine set metrics houdt de aandacht op open werkvoorraad, opvolgsnelheid en escalaties.',
        },
        {
          id: 'client-history',
          label: 'Cliënthistorie',
          kicker: 'Context',
          title: 'Recente signalen en opvolging in één zichtlijn',
          description: 'Gebeurtenissen en opvolging blijven leesbaar als rustige historie, niet als losse notities.',
        },
      ],
    };

const firstDomain = sectionContent.domains[0];
---

<section class="section-block" data-product-showcase>
  <div class="section-shell grid gap-10 lg:grid-cols-[0.38fr_0.62fr] lg:items-start">
    <div class="max-w-[31rem]" data-showcase-intro>
      <SectionIntro
        eyebrow={sectionContent.eyebrow}
        title={sectionContent.title}
        description={sectionContent.description}
      />
      <p class="mt-5 max-w-[30rem] text-sm leading-6 text-slate-500">
        {sectionContent.supporting}
      </p>

      <div class="showcase-rail mt-8" role="tablist" aria-label={sectionContent.eyebrow} data-showcase-rail>
        {sectionContent.domains.map((domain, index) => (
          <button
            type="button"
            class:list={['showcase-rail-item', index === 0 && 'is-active']}
            data-showcase-trigger
            data-domain-id={domain.id}
            data-kicker={domain.kicker}
            data-title={domain.title}
            data-description={domain.description}
            aria-selected={index === 0 ? 'true' : 'false'}
            tabindex={index === 0 ? '0' : '-1'}
          >
            <span class="showcase-rail-label">{domain.label}</span>
            <span class="showcase-rail-kicker">{domain.kicker}</span>
          </button>
        ))}
      </div>
    </div>

    <div class="showcase-shell" data-showcase-shell>
      <div class="showcase-frame">
        <div class="showcase-frame-head">
          <div>
            <p class="showcase-kicker" data-showcase-kicker>{firstDomain.kicker}</p>
            <h3 class="showcase-title" data-showcase-title>{firstDomain.title}</h3>
          </div>
          <p class="showcase-description" data-showcase-description>{firstDomain.description}</p>
        </div>

        <div class="showcase-stage" data-showcase-stage>
          <article class="showcase-panel is-active" data-showcase-panel="event-page">
            <div class="product-window">
              <div class="window-toolbar">
                <span class="window-chip">{isEnglish ? 'Worklist' : 'Werkvoorraad'}</span>
                <span class="window-meta">{isEnglish ? 'Updated 07:42' : 'Laatste update 07:42'}</span>
              </div>
              <div class="event-list">
                <article class="event-row is-priority">
                  <div class="event-row-main">
                    <div class="event-row-top">
                      <span class="event-time">07:39</span>
                      <span class="event-urgency">{isEnglish ? 'Direct' : 'Direct'}</span>
                    </div>
                    <h4>{isEnglish ? 'Mrs Anna de Vries · Room 01A-001' : 'Mevrouw Anna de Vries · Kamer 01A-001'}</h4>
                    <p>{isEnglish ? 'Help button was triggered repeatedly within a short interval.' : 'Helpknop is herhaald binnen korte tijd.'}</p>
                  </div>
                  <div class="event-row-status">
                    <span>{isEnglish ? 'Open' : 'Open'}</span>
                    <span>{isEnglish ? 'Unassigned' : 'Niet toegewezen'}</span>
                  </div>
                </article>

                <article class="event-row">
                  <div class="event-row-main">
                    <div class="event-row-top">
                      <span class="event-time">07:31</span>
                      <span class="event-urgency is-medium">{isEnglish ? 'Monitor' : 'Volgen'}</span>
                    </div>
                    <h4>{isEnglish ? 'Mr Jan Willems · Room 01A-008' : 'Meneer Jan Willems · Kamer 01A-008'}</h4>
                    <p>{isEnglish ? 'Voice input asks for additional observation.' : 'Spraakinput vraagt aanvullende observatie.'}</p>
                  </div>
                  <div class="event-row-status">
                    <span>{isEnglish ? 'In progress' : 'In behandeling'}</span>
                    <span>{isEnglish ? 'Assigned' : 'Toegewezen'}</span>
                  </div>
                </article>

                <article class="event-row">
                  <div class="event-row-main">
                    <div class="event-row-top">
                      <span class="event-time">07:18</span>
                      <span class="event-urgency is-low">{isEnglish ? 'Today' : 'Vandaag'}</span>
                    </div>
                    <h4>{isEnglish ? 'Mrs Lotte Bakker · Room 01A-003' : 'Mevrouw Lotte Bakker · Kamer 01A-003'}</h4>
                    <p>{isEnglish ? 'Movement signal deviates from the normal pattern.' : 'Bewegingssignaal wijkt af van normaal patroon.'}</p>
                  </div>
                  <div class="event-row-status">
                    <span>{isEnglish ? 'Open' : 'Open'}</span>
                    <span>{isEnglish ? 'Visible to team' : 'Team zichtbaar'}</span>
                  </div>
                </article>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="handling" hidden>
            <div class="product-window">
              <div class="handling-grid">
                <section class="handling-main">
                  <p class="window-chip is-soft">{isEnglish ? 'Recommended action' : 'Aanbevolen aanpak'}</p>
                  <h4>{isEnglish ? 'Go directly to the resident; check the situation.' : 'Ga direct naar bewoner; controleer situatie.'}</h4>
                  <p>
                    {isEnglish
                      ? 'Explainable triage combines repeat behaviour, context and urgency into one workable next step.'
                      : 'Uitlegbare triage bundelt herhaling, context en urgentie tot één werkbare vervolgactie.'}
                  </p>
                </section>

                <section class="handling-meta">
                  <div class="meta-pill">
                    <span>{isEnglish ? 'Urgency' : 'Urgentie'}</span>
                    <strong>{isEnglish ? 'Direct' : 'Direct'}</strong>
                  </div>
                  <div class="meta-pill">
                    <span>{isEnglish ? 'SLA status' : 'SLA-status'}</span>
                    <strong>{isEnglish ? 'SLA critical' : 'SLA kritisch'}</strong>
                  </div>
                  <div class="meta-pill">
                    <span>Ownership</span>
                    <strong>{isEnglish ? 'Not yet assigned' : 'Nog niet toegewezen'}</strong>
                  </div>
                </section>

                <section class="status-flow">
                  <span class="status-node is-active">Open</span>
                  <span class="status-connector"></span>
                  <span class="status-node">{isEnglish ? 'Claimed' : 'Opgepakt'}</span>
                  <span class="status-connector"></span>
                  <span class="status-node">{isEnglish ? 'Resolved' : 'Afgehandeld'}</span>
                </section>

                <section class="action-row">
                  <button type="button" class="action-button is-primary">{isEnglish ? 'Claim' : 'Pak op'}</button>
                  <button type="button" class="action-button">{isEnglish ? 'Assign' : 'Toewijzen'}</button>
                  <button type="button" class="action-button">{isEnglish ? 'Transfer' : 'Overdragen'}</button>
                  <button type="button" class="action-button">{isEnglish ? 'Resolve' : 'Afhandelen'}</button>
                </section>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="box-management" hidden>
            <div class="product-window">
              <div class="window-toolbar">
                <span class="window-chip">{isEnglish ? 'Box management' : 'Boxbeheer'}</span>
                <button type="button" class="inline-tool">{isEnglish ? 'Add box' : 'Box toevoegen'}</button>
              </div>

              <div class="box-grid">
                <article class="box-row">
                  <div>
                    <h4>BX-01A-004</h4>
                    <p>{isEnglish ? 'Linked to DEMO-ROOM-01A-004 · Mrs L. Bakker' : 'Gekoppeld aan DEMO-ROOM-01A-004 · Mevrouw L. Bakker'}</p>
                  </div>
                  <div class="box-state is-online">{isEnglish ? 'Online' : 'Online'}</div>
                </article>

                <article class="box-row">
                  <div>
                    <h4>BX-01A-006</h4>
                    <p>{isEnglish ? 'Available for linking · Living room' : 'Beschikbaar voor koppeling · Woonkamer'}</p>
                  </div>
                  <div class="box-state is-idle">{isEnglish ? 'Available' : 'Beschikbaar'}</div>
                </article>

                <article class="box-row">
                  <div>
                    <h4>BX-01A-009</h4>
                    <p>{isEnglish ? 'Check required · Last check-in 06:54' : 'Controle nodig · Laatste check-in 06:54'}</p>
                  </div>
                  <div class="box-state is-offline">{isEnglish ? 'Offline' : 'Offline'}</div>
                </article>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="technical-insight" hidden>
            <div class="product-window">
              <div class="technical-stack">
                <article class="technical-card">
                  <p class="window-chip is-soft">{isEnglish ? 'Active configuration' : 'Actieve configuratie'}</p>
                  <h4>{isEnglish ? 'Demo care location · Production' : 'Zorglocatie Demo · Productie'}</h4>
                  <p>{isEnglish ? 'Latest publication 07:10 · controlled release for operations.' : 'Laatste publicatie 07:10 · gecontroleerd vrijgegeven voor operations.'}</p>
                </article>

                <article class="technical-card">
                  <p class="window-chip is-soft">Explainability governance</p>
                  <h4>{isEnglish ? 'Triage explanation active' : 'Triage-uitleg actief'}</h4>
                  <p>{isEnglish ? 'Rationale and care-language output are publishable and visible for follow-up.' : 'Onderbouwing en zorgtaal zijn publiceerbaar en zichtbaar voor opvolging.'}</p>
                </article>

                <article class="technical-card">
                  <p class="window-chip is-soft">{isEnglish ? 'Governance state' : 'Beheerstatus'}</p>
                  <h4>{isEnglish ? 'Controllable without internals' : 'Controleerbaar zonder internals'}</h4>
                  <p>{isEnglish ? 'Publication state, version control and management context stay visible at a high level.' : 'Publicatiestatus, versiecontrole en beheercontext zijn zichtbaar op hoofdlijnen.'}</p>
                </article>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="kpi-overview" hidden>
            <div class="product-window">
              <div class="kpi-grid">
                <article class="kpi-card">
                  <span>{isEnglish ? 'Open events' : 'Open events'}</span>
                  <strong>38</strong>
                  <p>{isEnglish ? 'currently visible in team worklist' : 'actueel zichtbaar in teamwerkvoorraad'}</p>
                </article>
                <article class="kpi-card">
                  <span>{isEnglish ? 'Avg. response time' : 'Gem. opvolgtijd'}</span>
                  <strong>4m 12s</strong>
                  <p>{isEnglish ? 'from open to first action' : 'vanaf open naar eerste actie'}</p>
                </article>
                <article class="kpi-card">
                  <span>{isEnglish ? 'Picked up within SLA' : 'Binnen SLA opgepakt'}</span>
                  <strong>94%</strong>
                  <p>{isEnglish ? 'for direct events this shift' : 'voor directe meldingen deze dienst'}</p>
                </article>
                <article class="kpi-card">
                  <span>{isEnglish ? 'Recent escalations' : 'Recente escalaties'}</span>
                  <strong>3</strong>
                  <p>{isEnglish ? 'visible for operational steering' : 'zichtbaar voor operationele bijsturing'}</p>
                </article>
              </div>
            </div>
          </article>

          <article class="showcase-panel" data-showcase-panel="client-history" hidden>
            <div class="product-window">
              <div class="history-stack">
                <article class="history-row">
                  <span class="history-time">07:39</span>
                  <div>
                    <h4>{isEnglish ? 'Repeated help call' : 'Helpoproep herhaald'}</h4>
                    <p>{isEnglish ? 'Claimed directly · resident visited · follow-up recorded' : 'Direct opgepakt · bewoner bezocht · vervolg geregistreerd'}</p>
                  </div>
                </article>
                <article class="history-row">
                  <span class="history-time">06:12</span>
                  <div>
                    <h4>{isEnglish ? 'Voice input: restlessness reported' : 'Spraakinput: onrust gemeld'}</h4>
                    <p>{isEnglish ? 'Set to in progress · observation added to resident context' : 'In behandeling gezet · observatie toegevoegd aan dossiercontext'}</p>
                  </div>
                </article>

                <article class="history-row">
                  <span class="history-time">{isEnglish ? 'Yesterday' : 'Gisteren'}</span>
                  <div>
                    <h4>{isEnglish ? 'Movement signal outside pattern' : 'Bewegingssignaal buiten patroon'}</h4>
                    <p>{isEnglish ? 'Monitored without escalation · pattern history updated' : 'Gevolgd zonder escalatie · patroonhistorie bijgewerkt'}</p>
                  </div>
                </article>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  [data-product-showcase] .showcase-rail {
    display: grid;
    gap: 0.6rem;
  }

  [data-product-showcase] .showcase-rail-item {
    display: grid;
    gap: 0.14rem;
    width: 100%;
    padding: 0.95rem 1rem;
    text-align: left;
    border-radius: 1rem;
    border: 1px solid rgba(226, 232, 240, 0.86);
    background: rgba(255, 255, 255, 0.7);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  [data-product-showcase] .showcase-rail-item:hover,
  [data-product-showcase] .showcase-rail-item:focus-visible,
  [data-product-showcase] .showcase-rail-item.is-active {
    border-color: rgba(31, 53, 87, 0.18);
    background: rgba(248, 251, 252, 0.96);
    box-shadow: 0 10px 22px rgba(31, 53, 87, 0.06);
    outline: none;
  }

  [data-product-showcase] .showcase-rail-item.is-active {
    transform: translateX(3px);
  }

  [data-product-showcase] .showcase-rail-label {
    font-size: 0.98rem;
    font-weight: 600;
    color: rgb(15 23 42);
  }

  [data-product-showcase] .showcase-rail-kicker {
    font-size: 0.73rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(100 116 139);
  }

  [data-product-showcase] .showcase-shell {
    min-width: 0;
  }

  [data-product-showcase] .showcase-frame {
    border-radius: 1.9rem;
    border: 1px solid rgba(226, 232, 240, 0.86);
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(240, 246, 248, 0.96));
    box-shadow: 0 18px 36px rgba(31, 53, 87, 0.06);
    overflow: hidden;
  }

  [data-product-showcase] .showcase-frame-head {
    display: grid;
    gap: 0.9rem;
    padding: 1.4rem 1.4rem 1.2rem;
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
  }

  [data-product-showcase] .showcase-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(84 101 128);
  }

  [data-product-showcase] .showcase-title {
    margin-top: 0.35rem;
    font-size: 1.38rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: rgb(15 23 42);
  }

  [data-product-showcase] .showcase-description {
    max-width: 42rem;
    font-size: 0.94rem;
    line-height: 1.7;
    color: rgb(71 85 105);
  }

  [data-product-showcase] .showcase-stage {
    position: relative;
    min-height: 28rem;
    padding: 1.35rem;
  }

  [data-product-showcase] .showcase-panel {
    position: absolute;
    inset: 1.35rem;
  }

  [data-product-showcase] .product-window {
    height: 100%;
    border-radius: 1.45rem;
    border: 1px solid rgba(226, 232, 240, 0.92);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(247, 250, 252, 0.98));
    box-shadow: 0 12px 30px rgba(31, 53, 87, 0.06);
    padding: 1.1rem;
  }

  [data-product-showcase] .window-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  [data-product-showcase] .window-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.22rem 0.72rem;
    border-radius: 0.78rem;
    border: 1px solid rgba(205, 215, 227, 0.9);
    background: rgba(248, 250, 252, 0.95);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(71 85 105);
  }

  [data-product-showcase] .window-chip.is-soft {
    border-color: rgba(25, 130, 121, 0.16);
    background: rgba(244, 250, 249, 0.96);
    color: rgb(56 88 101);
  }

  [data-product-showcase] .window-meta {
    font-size: 0.84rem;
    color: rgb(100 116 139);
  }

  [data-product-showcase] .event-list,
  [data-product-showcase] .box-grid,
  [data-product-showcase] .technical-stack,
  [data-product-showcase] .history-stack {
    display: grid;
    gap: 0.78rem;
  }

  [data-product-showcase] .event-row,
  [data-product-showcase] .box-row,
  [data-product-showcase] .technical-card,
  [data-product-showcase] .history-row {
    border-radius: 1.1rem;
    border: 1px solid rgba(226, 232, 240, 0.88);
    background: rgba(255, 255, 255, 0.97);
    padding: 0.95rem 1rem;
  }

  [data-product-showcase] .event-row {
    display: grid;
    gap: 0.85rem;
  }

  [data-product-showcase] .event-row.is-priority {
    border-color: rgba(25, 130, 121, 0.18);
    box-shadow: 0 10px 22px rgba(25, 130, 121, 0.06);
  }

  [data-product-showcase] .event-row-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  [data-product-showcase] .event-time {
    font-size: 0.8rem;
    font-weight: 700;
    color: rgb(100 116 139);
  }

  [data-product-showcase] .event-urgency {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.65rem;
    padding: 0.12rem 0.58rem;
    border-radius: 0.72rem;
    border: 1px solid rgba(241, 169, 79, 0.3);
    background: rgba(255, 247, 236, 0.96);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgb(168 111 21);
  }

  [data-product-showcase] .event-urgency.is-medium {
    border-color: rgba(25, 130, 121, 0.18);
    background: rgba(244, 250, 249, 0.96);
    color: rgb(17 94 89);
  }

  [data-product-showcase] .event-urgency.is-low {
    border-color: rgba(191, 219, 254, 0.65);
    background: rgba(239, 246, 255, 0.96);
    color: rgb(30 64 175);
  }

  [data-product-showcase] .event-row h4,
  [data-product-showcase] .box-row h4,
  [data-product-showcase] .technical-card h4,
  [data-product-showcase] .history-row h4,
  [data-product-showcase] .handling-main h4 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: rgb(15 23 42);
  }

  [data-product-showcase] .event-row p,
  [data-product-showcase] .box-row p,
  [data-product-showcase] .technical-card p,
  [data-product-showcase] .history-row p,
  [data-product-showcase] .handling-main p,
  [data-product-showcase] .kpi-card p {
    margin-top: 0.25rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgb(71 85 105);
  }

  [data-product-showcase] .event-row-status {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  [data-product-showcase] .event-row-status span,
  [data-product-showcase] .box-state,
  [data-product-showcase] .meta-pill strong {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.8rem;
    padding: 0.12rem 0.65rem;
    border-radius: 0.72rem;
