---
import type { SnapshotSectionContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: SnapshotSectionContent;
}

const { content } = Astro.props;
---

<section class="section-block">
  <div class="section-shell">
    <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />

    <div class="mt-10 grid gap-6 xl:grid-cols-3">
      {content.cards.map((card) => (
        <article class="panel overflow-hidden rounded-[2rem]">
          <div class="bg-[linear-gradient(180deg,#f6f2e9_0%,#eef3f7_100%)] p-5">
            <div class="overflow-hidden rounded-[1.5rem] border border-slate-200/70 bg-white shadow-[0_14px_28px_rgba(32,59,99,0.08)]">
                <img src={card.image} alt={card.title} class="h-full w-full object-cover object-top" loading="lazy" />
            </div>
          </div>
          <div class="p-6">
            <p class="eyebrow">{card.tone}</p>
            <h3 class="mt-4 text-2xl font-extrabold tracking-tight text-slate-950">{card.title}</h3>
            <p class="mt-4 text-base leading-7 text-slate-600">{card.caption}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
