---
import type { HeroContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
const visualLabels =
  locale === 'nl'
    ? ['Van signaal naar context en triage', 'Werkbaar event voor opvolging', 'Reconstructie en audit blijven intact']
    : ['From signal to context and triage', 'Workable event for operational follow-up', 'Reconstruction and audit stay intact'];
---

<section id="home" class="section-block pt-12 md:pt-20">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.96fr_1.04fr] lg:items-center">
    <div>
      <p class="eyebrow">{content.eyebrow}</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-950 md:text-6xl md:leading-[1.05]">
        {content.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">{content.subtitle}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button-primary" href="#pilot">{content.primaryCta}</a>
        <a class="button-secondary" href="#how-it-works">{content.secondaryCta}</a>
      </div>
      <p class="mt-6 max-w-2xl text-sm font-medium text-slate-500">{content.supporting}</p>

      <div class="mt-10 space-y-3 border-t border-slate-200/80 pt-6">
        {content.metrics.map((metric) => (
          <div class="flex items-start gap-4 rounded-[1.2rem] border border-slate-200/70 bg-white/68 px-5 py-4">
            <span class="mt-1 size-2.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
            <div>
              <div class="text-base font-extrabold text-slate-950">{metric.value}</div>
              <p class="mt-1 text-sm leading-6 text-slate-600">{metric.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-10 top-12 h-48 w-48 rounded-full bg-[rgba(25,130,121,0.16)] blur-3xl"></div>
      <div class="absolute right-0 top-0 h-40 w-40 rounded-full bg-[rgba(62,113,190,0.12)] blur-3xl"></div>
      <div class="relative overflow-hidden rounded-[2.6rem] border border-slate-200/75 bg-white shadow-[0_22px_48px_rgba(31,53,87,0.1)]">
        <div class="relative min-h-[35rem]">
          <img
            src="/media/care-team.jpg"
            alt={locale === 'nl' ? 'Zorgmedewerker in gesprek in een zorgomgeving' : 'Care professional in conversation in a care environment'}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-tr from-[#132742]/72 via-[#132742]/24 to-transparent"></div>
          <div class="absolute right-5 top-5 rounded-full border border-white/20 bg-white/12 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white backdrop-blur-sm md:right-8 md:top-8">
            {locale === 'nl' ? 'Geen notificatielaag' : 'Not a notification layer'}
          </div>
          <div class="absolute bottom-5 left-5 right-5 rounded-[2rem] bg-[linear-gradient(180deg,rgba(18,40,71,0.94),rgba(18,40,71,0.88))] p-5 text-white shadow-[0_18px_40px_rgba(10,20,36,0.32)] backdrop-blur-sm md:bottom-8 md:left-auto md:right-8 md:w-[26rem] md:p-6">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-sky-200">Velvoix flow</p>
            <p class="mt-3 text-2xl font-extrabold tracking-tight">
              {locale === 'nl' ? 'Signaal -> context -> triage -> event' : 'Signal -> context -> triage -> event'}
            </p>
            <p class="mt-2 text-sm leading-6 text-slate-200">
              {locale === 'nl'
                ? 'Niet meer losse meldingen, maar een gecontroleerde workflow voor opvolging, escalatie en reconstructie.'
                : 'Not isolated alerts, but a controlled workflow for follow-up, escalation and reconstruction.'}
            </p>
            <div class="mt-5 space-y-2.5">
              {visualLabels.map((label) => (
                <div class="flex items-center gap-3 rounded-[1.2rem] border border-white/10 bg-white/5 px-4 py-3">
                  <span class="size-2.5 shrink-0 rounded-full bg-[var(--vx-accent)]"></span>
                  <p class="text-sm font-semibold text-white md:text-base">{label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
