---
import type { HeroContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
---

<section id="home" class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/media/AdobeStock_1857436642.jpeg"
      alt={locale === 'nl' ? 'Handcontact in een zorgomgeving' : 'Hand contact in a care setting'}
      class="h-full w-full object-cover object-[72%_48%] md:object-[68%_45%]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(10,24,48,0.78)_0%,rgba(10,24,48,0.62)_26%,rgba(10,24,48,0.28)_48%,rgba(10,24,48,0.08)_68%,rgba(10,24,48,0)_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(246,249,252,0.08)_0%,rgba(246,249,252,0)_100%)]"></div>
  </div>

  <div class="relative">
    <div class="mx-auto flex min-h-[24rem] w-full max-w-[1280px] items-center px-5 py-10 md:min-h-[29rem] md:px-10 md:py-14 lg:min-h-[31rem]">
      <div class="max-w-[35rem] text-white">
        <p class="text-[0.8rem] font-bold uppercase tracking-[0.26em] text-white/76">{content.eyebrow}</p>
        <h1 class="mt-5 max-w-[10ch] text-[2.85rem] font-extrabold tracking-[-0.06em] leading-[0.96] text-white sm:text-[3.35rem] md:text-[4.25rem] lg:text-[4.7rem]">
          {content.title}
        </h1>
        <p class="mt-6 max-w-[33rem] text-base leading-7 text-slate-100 md:text-[1.15rem] md:leading-8">
          {content.subtitle}
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] bg-[linear-gradient(135deg,#173156_0%,#223d66_100%)] px-6 py-3 text-sm font-semibold text-white shadow-[0_14px_28px_rgba(12,26,48,0.2)] hover:-translate-y-0.5 hover:shadow-[0_18px_34px_rgba(12,26,48,0.24)] focus-visible:outline-none"
            href="#pilot"
          >
            {content.primaryCta}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] border border-white/28 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm hover:bg-white/14 focus-visible:outline-none"
            href="#how-it-works"
          >
            {content.secondaryCta}
          </a>
        </div>

        <p class="mt-6 max-w-[34rem] text-sm font-medium leading-6 text-white/78">{content.supporting}</p>

        <div class="mt-8 grid gap-4 border-t border-white/14 pt-5 md:grid-cols-3 md:gap-5">
          {content.metrics.map((metric) => (
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="size-2 rounded-full bg-[var(--vx-accent)]"></span>
                <p class="text-sm font-semibold text-white">{metric.value}</p>
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-200/92">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
