---
import type { HeroContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
const visualLabels =
  locale === 'nl'
    ? ['Signaal ontvangen', 'Context toegevoegd', 'Triage verklaard', 'Workflow actief']
    : ['Signal received', 'Context added', 'Triage explained', 'Workflow active'];
---

<section id="home" class="section-block pt-12 md:pt-20">
  <div class="section-shell grid gap-10 lg:grid-cols-[0.96fr_1.04fr] lg:items-center">
    <div>
      <p class="eyebrow">{content.eyebrow}</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-950 md:text-6xl md:leading-[1.05]">
        {content.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">{content.subtitle}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button-primary" href="#pilot">{content.primaryCta}</a>
        <a class="button-secondary" href="#how-it-works">{content.secondaryCta}</a>
      </div>
      <p class="mt-6 max-w-2xl text-sm font-medium text-slate-500">{content.supporting}</p>

      <div class="mt-10 grid gap-3 sm:grid-cols-1">
        {content.metrics.map((metric) => (
          <div class="flex items-start gap-4 rounded-[1.4rem] border border-slate-200/70 bg-white/72 px-5 py-4">
            <span class="mt-1 size-2.5 shrink-0 rounded-full bg-emerald-500"></span>
            <div>
              <div class="text-base font-extrabold text-slate-950">{metric.value}</div>
              <p class="mt-1 text-sm leading-6 text-slate-600">{metric.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="relative">
      <div class="absolute -left-8 top-10 h-48 w-48 rounded-full bg-emerald-300/18 blur-3xl"></div>
      <div class="panel relative overflow-hidden rounded-[2.4rem]">
        <div class="relative min-h-[34rem]">
          <img
            src="/media/care-team.jpg"
            alt={locale === 'nl' ? 'Zorgmedewerker in gesprek in een zorgomgeving' : 'Care professional in conversation in a care environment'}
            class="absolute inset-0 h-full w-full object-cover"
            loading="eager"
          />
          <div class="absolute inset-0 bg-gradient-to-tr from-[#142746]/78 via-[#142746]/22 to-transparent"></div>
          <div class="absolute right-5 top-5 rounded-full border border-white/16 bg-white/10 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-white backdrop-blur-sm md:right-8 md:top-8">
            {locale === 'nl' ? 'Uitlegbaar en auditbaar' : 'Explainable and auditable'}
          </div>
          <div class="absolute bottom-5 right-5 left-5 rounded-[2rem] bg-[linear-gradient(180deg,rgba(17,34,58,0.94),rgba(21,40,66,0.9))] p-5 text-white shadow-[0_18px_40px_rgba(10,20,36,0.3)] backdrop-blur-sm md:bottom-8 md:left-auto md:right-8 md:w-[25rem] md:p-6">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-sky-200">Velvoix chain</p>
            <p class="mt-3 text-2xl font-extrabold tracking-tight">
              {locale === 'nl' ? 'Van trigger naar bestuurbare opvolging' : 'From trigger to controllable follow-up'}
            </p>
            <div class="mt-5 space-y-3">
              {visualLabels.map((label, index) => (
                <div class="flex items-center gap-3 rounded-[1.35rem] border border-white/10 bg-white/5 px-4 py-3">
                  <div class="flex size-10 shrink-0 items-center justify-center rounded-2xl bg-white/10 text-sm font-extrabold text-white">
                    0{index + 1}
                  </div>
                  <p class="text-sm font-semibold text-white md:text-base">{label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
