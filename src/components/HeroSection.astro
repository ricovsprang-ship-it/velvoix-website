---
import type { HeroContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
const visualLabels =
  locale === 'nl'
    ? ['Signaal ontvangen', 'Context toegevoegd', 'Triage verklaard', 'Workflow actief']
    : ['Signal received', 'Context added', 'Triage explained', 'Workflow active'];
---

<section id="home" class="section-block pt-12 md:pt-20">
  <div class="section-shell grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="eyebrow">{content.eyebrow}</p>
      <h1 class="mt-5 max-w-3xl text-4xl font-extrabold tracking-tight text-slate-950 md:text-6xl md:leading-[1.05]">
        {content.title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600 md:text-xl">{content.subtitle}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a class="button-primary" href="#pilot">{content.primaryCta}</a>
        <a class="button-secondary" href="#how-it-works">{content.secondaryCta}</a>
      </div>
      <p class="mt-6 max-w-2xl text-sm font-medium text-slate-500">{content.supporting}</p>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        {content.metrics.map((metric) => (
          <div class="panel rounded-3xl p-5">
            <div class="text-base font-extrabold text-slate-950">{metric.value}</div>
            <p class="mt-2 text-sm leading-6 text-slate-600">{metric.label}</p>
          </div>
        ))}
      </div>
    </div>

    <div class="grid gap-4">
      <div class="panel overflow-hidden rounded-[2rem]">
        <div class="grid gap-0 lg:grid-cols-[1.15fr_0.85fr]">
          <div class="relative min-h-[23rem]">
            <img
              src="/media/care-team.jpg"
              alt={locale === 'nl' ? 'Zorgmedewerker in gesprek in een zorgomgeving' : 'Care professional in conversation in a care environment'}
              class="absolute inset-0 h-full w-full object-cover"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-tr from-slate-950/72 via-slate-950/24 to-transparent"></div>
            <div class="absolute inset-x-0 bottom-0 p-6 md:p-8">
              <p class="eyebrow !text-slate-200/80">{locale === 'nl' ? 'Zorgworkflow in context' : 'Care workflow in context'}</p>
              <p class="mt-3 max-w-lg text-2xl font-extrabold tracking-tight text-white md:text-3xl">
                {locale === 'nl'
                  ? 'Rust aan de voorkant, duidelijkheid in opvolging.'
                  : 'Calm on the surface, clarity in follow-up.'}
              </p>
            </div>
          </div>
          <div class="bg-[linear-gradient(180deg,#1e365d_0%,#162746_100%)] p-6 text-white md:p-8">
            <p class="text-xs font-bold uppercase tracking-[0.24em] text-sky-200">Velvoix flow</p>
            <p class="mt-3 text-2xl font-bold tracking-tight">
              {locale === 'nl' ? 'Van trigger naar bestuurbare opvolging' : 'From trigger to controllable follow-up'}
            </p>
            <div class="mt-4 rounded-full border border-sky-300/25 bg-sky-300/8 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-sky-100">
              {locale === 'nl' ? 'Publiek conceptueel' : 'Public conceptual'}
            </div>

            <div class="mt-6 space-y-3">
              {visualLabels.map((label, index) => (
                <div class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/5 px-4 py-4">
                  <div class="flex size-10 shrink-0 items-center justify-center rounded-2xl bg-white/10 text-sm font-extrabold text-white">
                    0{index + 1}
                  </div>
                  <div>
                    <p class="text-[0.72rem] font-bold uppercase tracking-[0.18em] text-slate-300">
                      {index === 0
                        ? locale === 'nl'
                          ? 'Start'
                          : 'Start'
                        : index === visualLabels.length - 1
                          ? locale === 'nl'
                            ? 'Uitkomst'
                            : 'Outcome'
                          : locale === 'nl'
                            ? 'Laag'
                            : 'Layer'}
                    </p>
                    <p class="mt-1 text-sm font-semibold text-white md:text-base">{label}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="grid gap-4 md:grid-cols-[0.9fr_1.1fr]">
        <div class="panel overflow-hidden rounded-[1.75rem]">
          <div class="relative min-h-[15rem]">
            <img
              src="/media/care-room.jpg"
              alt={locale === 'nl' ? 'Zorgomgeving met rustige visuele sfeer' : 'Care environment with a calm visual atmosphere'}
              class="absolute inset-0 h-full w-full object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-950/52 via-slate-950/8 to-transparent"></div>
          </div>
        </div>
        <div class="panel rounded-[1.75rem] p-6">
          <p class="eyebrow">{locale === 'nl' ? 'Merkuitgangspunt' : 'Brand principle'}</p>
          <p class="mt-4 text-2xl font-extrabold tracking-tight text-slate-950">
            {locale === 'nl'
              ? 'Geen losse AI-laag, maar een platform voor duidelijke zorgactie.'
              : 'Not a loose AI layer, but a platform for clear care action.'}
          </p>
          <p class="mt-4 text-base leading-7 text-slate-600">
            {locale === 'nl'
              ? 'Velvoix presenteert signalen niet als losse meldingen, maar als uitlegbare workflow met context, opvolging en reconstructie.'
              : 'Velvoix does not present signals as isolated alerts, but as explainable workflow with context, follow-up and reconstruction.'}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
