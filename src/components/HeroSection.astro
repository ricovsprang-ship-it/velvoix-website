---
import type { HeroContent, Locale } from '../content/site';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
---

<section id="home" class="relative overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/media/AdobeStock_1857436642.jpeg"
      alt={locale === 'nl' ? 'Handcontact in een zorgomgeving' : 'Hand contact in a care setting'}
      class="h-full w-full object-cover object-[72%_48%] md:object-[68%_45%]"
      loading="eager"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(10,24,48,0.72)_0%,rgba(10,24,48,0.56)_24%,rgba(10,24,48,0.24)_46%,rgba(10,24,48,0.06)_68%,rgba(10,24,48,0)_100%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(246,249,252,0.08)_0%,rgba(246,249,252,0)_100%)]"></div>
  </div>

  <div class="relative">
    <div class="mx-auto flex min-h-[28.75rem] w-full max-w-[1280px] items-center px-5 py-8 md:min-h-[32.5rem] md:px-10 md:py-10 xl:min-h-[35rem] xl:max-h-[36.25rem]">
      <div class="max-w-[35rem] text-white">
        <p class="text-[0.8rem] font-bold uppercase tracking-[0.26em] text-white/76">{content.eyebrow}</p>
        <h1 class="mt-4 max-w-[10.5ch] text-[2.7rem] font-extrabold tracking-[-0.055em] leading-[0.95] text-white sm:text-[3.05rem] md:text-[3.7rem] lg:text-[4.15rem]">
          {content.title}
        </h1>
        <p class="mt-5 max-w-[31rem] text-[0.98rem] leading-7 text-slate-100 md:text-[1.06rem] md:leading-7">
          {content.subtitle}
        </p>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] bg-[linear-gradient(135deg,#173156_0%,#223d66_100%)] px-6 py-3 text-sm font-semibold text-white shadow-[0_14px_28px_rgba(12,26,48,0.2)] hover:-translate-y-0.5 hover:shadow-[0_18px_34px_rgba(12,26,48,0.24)] focus-visible:outline-none"
            href="#pilot"
          >
            {content.primaryCta}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] border border-white/28 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm hover:bg-white/14 focus-visible:outline-none"
            href="#how-it-works"
          >
            {content.secondaryCta}
          </a>
        </div>

        <p class="mt-5 max-w-[31rem] text-[0.92rem] font-medium leading-6 text-white/74">{content.supporting}</p>

        <div class="mt-6 grid gap-3 border-t border-white/12 pt-4 md:grid-cols-3 md:gap-4">
          {content.metrics.map((metric) => (
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <span class="size-1.5 rounded-full bg-[var(--vx-accent)]"></span>
                <p class="text-[0.92rem] font-semibold text-white">{metric.value}</p>
              </div>
              <p class="mt-1.5 text-[0.84rem] leading-6 text-slate-200/88">{metric.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
