---
import { Picture } from 'astro:assets';
import type { HeroContent, Locale } from '../content/site';
import heroImage from '../assets/hero-care-contact.jpg';

interface Props {
  locale: Locale;
  content: HeroContent;
}

const { locale, content } = Astro.props;
const usesExpandedHeroFrame = locale !== 'nl';
const usesRelaxedHeroSpacing = locale === 'de' || locale === 'es';
const imageAltByLocale: Record<Locale, string> = {
  nl: 'Handcontact in een zorgomgeving',
  en: 'Hand contact in a care setting',
  de: 'Handkontakt in einer Pflegeumgebung',
  es: 'Contacto de manos en un entorno asistencial',
};
const heroImageClass = usesExpandedHeroFrame
  ? 'h-full w-full object-cover object-[72%_50%] md:object-[68%_47%]'
  : 'h-full w-full object-cover object-[72%_48%] md:object-[68%_45%]';
const heroFrameClass = usesRelaxedHeroSpacing
  ? 'mx-auto flex min-h-[31.5rem] w-full max-w-[1280px] items-center px-5 py-10 md:min-h-[36.5rem] md:px-10 md:py-12 xl:min-h-[39.5rem] xl:max-h-[40.5rem]'
  : usesExpandedHeroFrame
    ? 'mx-auto flex min-h-[30.5rem] w-full max-w-[1280px] items-center px-5 py-8 md:min-h-[35rem] md:px-10 md:py-10 xl:min-h-[38rem] xl:max-h-[39rem]'
    : 'mx-auto flex min-h-[28.75rem] w-full max-w-[1280px] items-center px-5 py-8 md:min-h-[32.5rem] md:px-10 md:py-10 xl:min-h-[35rem] xl:max-h-[36.25rem]';
const heroContentClass = usesRelaxedHeroSpacing
  ? 'max-w-[37.5rem] text-white'
  : 'max-w-[34rem] text-white';
const heroTitleClass = usesRelaxedHeroSpacing
  ? 'mt-6 max-w-[13.4ch] text-[2.22rem] font-extrabold leading-[0.98] tracking-[-0.048em] text-white sm:text-[2.55rem] md:mt-7 md:text-[2.95rem] lg:text-[3.28rem]'
  : 'mt-4 max-w-[10.8ch] text-[2.55rem] font-extrabold leading-[0.96] tracking-[-0.055em] text-white sm:text-[2.95rem] md:text-[3.45rem] lg:text-[3.95rem]';
const heroSubtitleClass = usesRelaxedHeroSpacing
  ? 'mt-6 max-w-[34rem] text-[0.93rem] leading-[1.68] text-slate-100 md:mt-7 md:text-[0.98rem] md:leading-[1.68]'
  : 'mt-5 max-w-[31rem] text-[0.98rem] leading-7 text-slate-100 md:text-[1.04rem] md:leading-7';
const heroCtasClass = usesRelaxedHeroSpacing
  ? 'mt-7 flex flex-col gap-3 sm:flex-row sm:flex-wrap md:mt-8'
  : 'mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap';
const heroSupportingClass = usesRelaxedHeroSpacing
  ? 'mt-6 max-w-[34rem] text-[0.84rem] font-medium leading-[1.58] text-white/74 md:mt-7 md:text-[0.88rem]'
  : 'mt-6 max-w-[31rem] text-[0.92rem] font-medium leading-6 text-white/74';
---

<section id="home" class="relative overflow-hidden" data-hero-layout={usesExpandedHeroFrame ? 'expanded' : 'default'}>
  <div class="absolute inset-0" data-hero-media>
    <Picture
      src={heroImage}
      alt={imageAltByLocale[locale]}
      class={heroImageClass}
      pictureAttributes={{ class: 'block h-full w-full' }}
      data-hero-image
      widths={[640, 960, 1280, 1600, 1920, 2560]}
      sizes="100vw"
      formats={['avif', 'webp']}
      fallbackFormat="jpg"
      quality={80}
      priority
      decoding="async"
    />
    <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(10,24,48,0.7)_0%,rgba(10,24,48,0.54)_24%,rgba(10,24,48,0.22)_46%,rgba(10,24,48,0.05)_68%,rgba(10,24,48,0)_100%)]" data-hero-overlay></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(246,249,252,0.08)_0%,rgba(246,249,252,0)_100%)]"></div>
  </div>

  <div class="relative" data-hero-block>
    <div class={heroFrameClass}>
      <div class={heroContentClass} data-hero-content>
        <p class="text-[0.8rem] font-bold uppercase tracking-[0.26em] text-white/76" data-hero-eyebrow>{content.eyebrow}</p>
        <h1
          class={heroTitleClass}
          data-hero-title
        >
          {content.title}
        </h1>
        <p class={heroSubtitleClass} data-hero-subtitle>
          {content.subtitle}
        </p>

        <div class={heroCtasClass} data-hero-ctas>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] bg-[linear-gradient(135deg,#173156_0%,#223d66_100%)] px-6 py-3 text-sm font-semibold text-white shadow-[0_14px_28px_rgba(12,26,48,0.2)] hover:-translate-y-0.5 hover:shadow-[0_18px_34px_rgba(12,26,48,0.24)] focus-visible:outline-none"
            href={content.primaryHref ?? '#why-velvoix'}
          >
            {content.primaryCta}
          </a>
          <a
            class="inline-flex min-h-12 items-center justify-center rounded-[0.95rem] border border-white/28 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-sm hover:bg-white/14 focus-visible:outline-none"
            href={content.secondaryHref ?? '#how-it-works'}
          >
            {content.secondaryCta}
          </a>
        </div>

        <p class={heroSupportingClass} data-hero-supporting>{content.supporting}</p>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroBlocks = document.querySelectorAll('[data-hero-block]');

  for (const heroBlock of heroBlocks) {
    if (!(heroBlock instanceof HTMLElement)) continue;
    if (heroBlock.dataset.gsapBound === 'true') continue;
    heroBlock.dataset.gsapBound = 'true';

    const eyebrow = heroBlock.querySelector<HTMLElement>('[data-hero-eyebrow]');
    const title = heroBlock.querySelector<HTMLElement>('[data-hero-title]');
    const subtitle = heroBlock.querySelector<HTMLElement>('[data-hero-subtitle]');
    const ctas = heroBlock.querySelector<HTMLElement>('[data-hero-ctas]');
    const supporting = heroBlock.querySelector<HTMLElement>('[data-hero-supporting]');
    const content = heroBlock.querySelector<HTMLElement>('[data-hero-content]');
    const image = heroBlock.parentElement?.querySelector<HTMLElement>('[data-hero-image]');
    const overlay = heroBlock.parentElement?.querySelector<HTMLElement>('[data-hero-overlay]');
    const usesExpandedHeroFrame = heroBlock.parentElement?.dataset.heroLayout === 'expanded';

    if (prefersReducedMotion) {
      gsap.set([eyebrow, title, subtitle, ctas, supporting, content, image, overlay], { clearProps: 'all' });
      continue;
    }

    gsap.set([eyebrow, title, subtitle, ctas, supporting], { autoAlpha: 0, y: 14 });
    gsap.set(title, { autoAlpha: 0, y: 18 });
    gsap.set(image, { scale: usesExpandedHeroFrame ? 1.015 : 1.035, y: 0 });
    gsap.set(content, { y: 0 });
    gsap.set(overlay, { opacity: 1 });

    const introTimeline = gsap.timeline({ defaults: { ease: 'power2.out' } });
    introTimeline
      .to(eyebrow, { autoAlpha: 1, y: 0, duration: 0.22 })
      .to(title, { autoAlpha: 1, y: 0, duration: 0.34 }, '-=0.06')
      .to(subtitle, { autoAlpha: 1, y: 0, duration: 0.24 }, '-=0.08')
      .to(ctas, { autoAlpha: 1, y: 0, duration: 0.22 }, '-=0.05')
      .to(supporting, { autoAlpha: 1, y: 0, duration: 0.22 }, '-=0.04');

    const mm = gsap.matchMedia();

    mm.add(
      {
        desktop: '(min-width: 1024px)',
        tablet: '(min-width: 768px) and (max-width: 1023px)',
        mobile: '(max-width: 767px)',
      },
      (context) => {
        const isDesktop = Boolean(context.conditions?.desktop);
        const isTablet = Boolean(context.conditions?.tablet);
        const imageShift = isDesktop ? 12 : isTablet ? 9 : 6;
        const contentShift = isDesktop ? -16 : isTablet ? -12 : -8;
        const imageScaleEnd = usesExpandedHeroFrame
          ? isDesktop
            ? 1
            : isTablet
              ? 1.003
              : 1.007
          : isDesktop
            ? 1
            : isTablet
              ? 1.006
              : 1.01;
        const overlayOpacityEnd = isDesktop ? 0.9 : isTablet ? 0.93 : 0.96;
        const scrubValue = isDesktop ? 0.75 : 0.55;
        const scrollEnd = isDesktop ? 'bottom top' : '85% top';

        if (image) {
          gsap.to(image, {
            y: imageShift,
            scale: imageScaleEnd,
            ease: 'none',
            scrollTrigger: {
              trigger: heroBlock,
              start: 'top top',
              end: scrollEnd,
              scrub: scrubValue,
            },
          });
        }

        if (content) {
          gsap.to(content, {
            y: contentShift,
            ease: 'none',
            scrollTrigger: {
              trigger: heroBlock,
              start: 'top top',
              end: scrollEnd,
              scrub: scrubValue,
            },
          });
        }

        if (overlay) {
          gsap.to(overlay, {
            opacity: overlayOpacityEnd,
            ease: 'none',
            scrollTrigger: {
              trigger: heroBlock,
              start: 'top top',
              end: scrollEnd,
              scrub: scrubValue,
            },
          });
        }
      }
    );
  }
</script>
