---
import type { ChallengeContent } from '../content/site';
import SectionIntro from './SectionIntro.astro';

interface Props {
  content: ChallengeContent;
}

const { content } = Astro.props;
const proof = content.proofPanels;
---

<section class="section-block" id="challenge-proof">
  <div class="section-shell grid gap-8 lg:grid-cols-[0.94fr_1.06fr] lg:items-center">
    <div class="max-w-[34rem]">
      <SectionIntro eyebrow={content.eyebrow} title={content.title} description={content.description} />
    </div>

    <div class="relative">
      <div class="absolute -left-8 top-10 hidden h-36 w-36 rounded-full bg-[rgba(25,130,121,0.08)] blur-3xl lg:block"></div>

      <div class="relative grid gap-4 lg:pr-8">
        <article class="relative z-[2] rounded-[2rem] border border-slate-200/85 bg-[linear-gradient(180deg,rgba(255,255,255,0.96),rgba(243,248,251,0.94))] p-6 shadow-[0_24px_46px_rgba(31,53,87,0.08)] md:p-7">
          <div class="flex items-center gap-2">
            <span class="size-2 rounded-full bg-[var(--vx-accent)]"></span>
            <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-600">{proof.explainabilityLabel}</p>
          </div>

          <div class="mt-5 rounded-[1.45rem] border border-[rgba(25,130,121,0.18)] bg-[linear-gradient(180deg,rgba(239,248,246,0.95),rgba(247,251,252,0.98))] p-5">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{proof.explainabilityTitle}</p>
            <p class="mt-3 text-[1.22rem] font-bold tracking-tight text-slate-950 md:text-[1.35rem]">{proof.explainabilitySummary}</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">{proof.explainabilitySupporting}</p>
          </div>

          <div class="mt-5 grid gap-3">
            {proof.explainabilityItems.map((item) => (
              <div class="grid gap-1 rounded-[1.2rem] border border-slate-200/75 bg-white/88 px-4 py-3 md:grid-cols-[9.5rem_1fr] md:items-start md:gap-3">
                <p class="text-[0.72rem] font-bold uppercase tracking-[0.15em] text-slate-500">{item.label}</p>
                <p class="text-sm font-semibold leading-6 text-slate-700">{item.value}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="relative z-[1] rounded-[1.8rem] border border-slate-200/85 bg-white/96 p-5 shadow-[0_18px_34px_rgba(31,53,87,0.06)] lg:ml-14 lg:-mt-6 md:p-6">
          <div class="flex items-center gap-2">
            <span class="size-2 rounded-full bg-[var(--vx-accent)]"></span>
            <p class="text-[0.74rem] font-bold uppercase tracking-[0.18em] text-slate-600">{proof.followUpLabel}</p>
          </div>

          <div class="mt-5 rounded-[1.35rem] border border-slate-200/75 bg-slate-50/90 p-5">
            <p class="text-[0.72rem] font-bold uppercase tracking-[0.16em] text-slate-500">{proof.followUpTitle}</p>
            <p class="mt-3 text-[1.1rem] font-bold tracking-tight text-slate-950 md:text-[1.22rem]">{proof.followUpSummary}</p>
          </div>

          <div class="mt-4 grid gap-3 md:grid-cols-3">
            {proof.followUpItems.map((item) => (
              <div class="rounded-[1.2rem] border border-slate-200/75 bg-white px-4 py-3">
                <p class="text-[0.7rem] font-bold uppercase tracking-[0.15em] text-slate-500">{item.label}</p>
                <p class="mt-2 text-sm font-semibold leading-6 text-slate-700">{item.value}</p>
              </div>
            ))}
          </div>

          <div class="mt-5">
            <button
              type="button"
              class="inline-flex min-h-11 items-center justify-center rounded-[0.95rem] bg-[linear-gradient(135deg,#173156_0%,#223d66_100%)] px-5 py-3 text-sm font-semibold text-white shadow-[0_12px_24px_rgba(23,49,86,0.18)]"
            >
              {proof.followUpAction}
            </button>
          </div>
        </article>
      </div>
    </div>
  </div>
</section>
