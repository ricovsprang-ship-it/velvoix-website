RewriteEngine On

# Retire known WordPress legacy routes from the public footprint.
RewriteRule ^sample-page/?$ - [G,L]
RewriteRule ^hello-world/?$ - [G,L]
RewriteRule ^category/uncategorized/?$ - [G,L]
RewriteRule ^tag(?:/.*)?$ - [G,L]
RewriteRule ^author(?:/.*)?$ - [G,L]

# Keep crawlers and users on the canonical non-www HTTPS host.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} ^www\.velvoix\.com$ [NC]
RewriteRule ^ https://velvoix.com%{REQUEST_URI} [R=301,L]

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), geolocation=(), microphone=()"
  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self'; form-action 'self'; base-uri 'self'; frame-ancestors 'self'; object-src 'none'; upgrade-insecure-requests"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" "expr=%{HTTPS} == 'on'"

  # Keep HTML and PHP responses fresh so locale pages cannot get stuck on stale cached markup.
  <FilesMatch "\.(?:html?|php)$">
    Header always set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    Header always set Pragma "no-cache"
    Header always set Expires "0"
  </FilesMatch>
</IfModule>

<Files ".contact-mailer-config.php">
  Require all denied
</Files>
